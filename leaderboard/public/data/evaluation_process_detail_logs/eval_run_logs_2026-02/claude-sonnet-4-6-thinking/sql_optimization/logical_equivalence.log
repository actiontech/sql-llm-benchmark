## Translated SQL:
SELECT customer_id, COUNT(CASE WHEN booking_status IN ('Completed','Cancelled','No Show') AND booking_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 180 DAY) THEN booking_id END) AS total_bookings, SUM(CASE WHEN booking_status IN ('Completed','Cancelled','No Show') AND booking_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 180 DAY) THEN booking_value END) AS total_revenue, AVG(driver_rating) AS avg_driver_rating, MAX(booking_date) AS last_booking_date FROM ride_bookings GROUP BY customer_id HAVING total_bookings > 10 ORDER BY total_revenue DESC, avg_driver_rating ASC;

