   tt.jobpriorpersname,
   tt.jobtype,
   tt.createtime,
   tt.tranname,
   tt.issucc,
   tt.tranprop,
   tt.trandata,
   tt.jbjg,
   tt.jbgy,
   tt.ldlcid
