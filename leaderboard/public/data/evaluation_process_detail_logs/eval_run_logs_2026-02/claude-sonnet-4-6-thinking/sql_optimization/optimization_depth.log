SELECT /*+ USE_HASH(b s pp r nt t1) LEADING(b r nt s pp t1) */ s.spriden_id AS EID, s.spriden_last_name||', '||s.spriden_first_name AS "NAME", b.nobtran_transaction_no AS "TRANS NO.", nt.posn AS "POSN NO", b.nobtran_effective_date AS "QUERY DATE", b.nobtran_acat_code AS "ACAT CODE", nt.hire_date AS "CURRENT HIRE DATE", nt.begin_pers_date AS "BEGIN PERSONNEL DATE", nt.salary_group AS "SALARY GROUP", nt.appt_pct AS "APPOINTMENT PERCENT", nt.ann_salary AS "ANNUAL SALARY", t1.nortern_effective_date AS "PAY DATA EFFECTIVE DATE", t1.nortern_earn_code AS "PAY DATA EARNINGS", t1.nortern_hrs AS "PAY DATA HOURS", t1.nortern_special_rate AS "PAY DATA SPECIAL RATE", nt.end_job_eff_date AS "END JOB EFFECTIVE DATE", nt.end_pers_date AS "END PERSONNEL DATE", CASE b.nobtran_trans_status_ind WHEN 'A' THEN 'Approved' WHEN 'C' THEN 'Completed' WHEN 'V' THEN 'Voided' WHEN 'D' THEN 'Disapproved' WHEN 'R' THEN 'Return for Correction' WHEN 'P' THEN 'Pending' WHEN 'W' THEN 'Waiting' WHEN 'T' THEN 'Partially Completed' WHEN 'N' THEN 'Cancelled' WHEN 'U' THEN 'Superuser Update' END AS trans_status, CASE r.norrout_queue_status_ind WHEN 'A' THEN 'Approved by that Approver' WHEN 'D' THEN 'Disapproved' WHEN 'F' THEN 'FYI' WHEN 'I' THEN 'In Queue' WHEN 'K' THEN 'Acknowledged' WHEN 'L' THEN 'Applied by Applier' WHEN 'M' THEN 'More Information' WHEN 'O' THEN 'Overridden' WHEN 'P' THEN 'Pending Action by Approver/Applier' WHEN 'Q' THEN 'Removed from Queue' WHEN 'R' THEN 'Return for Correction' END AS queue_status, r.norrout_level_no FROM nobtran b JOIN norrout r ON b.nobtran_transaction_no = r.norrout_transaction_no AND r.norrout_level_no = 90 AND r.norrout_queue_status_ind <> 'A' JOIN (SELECT nortran_transaction_no, MAX(CASE WHEN nortran_aufd_code = 'PEBEMPL_CURRENT_HIRE_DATE' THEN nortran_value END) AS hire_date, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_PERS_CHG_DATE' THEN nortran_value END) AS begin_pers_date, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_SGRP_CODE' THEN nortran_value END) AS salary_group, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_APPT_PCT' THEN nortran_value END) AS appt_pct, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_ANN_SALARY' THEN nortran_value END) AS ann_salary, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_EFFECTIVE_DATE' AND nortran_apty_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') THEN nortran_value END) AS end_job_eff_date, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_PERS_CHG_DATE' AND nortran_apty_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') THEN nortran_value END) AS end_pers_date, MAX(CASE WHEN nortran_posn IS NOT NULL THEN nortran_posn END) AS posn FROM nortran GROUP BY nortran_transaction_no) nt ON b.nobtran_transaction_no = nt.nortran_transaction_no JOIN spriden s ON b.nobtran_pidm = s.spriden_pidm AND s.spriden_change_ind IS NULL JOIN pebempl pp ON s.spriden_pidm = pp.pebempl_pidm AND pp.pebempl_ecls_code NOT IN ('RE','FW','GS','MW') LEFT JOIN nortern t1 ON b.nobtran_transaction_no = t1.nortern_transaction_no WHERE b.nobtran_acat_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') AND b.nobtran_apply_ind = 'N' AND b.nobtran_trans_status_ind <> 'V' ORDER BY b.nobtran_transaction_no

