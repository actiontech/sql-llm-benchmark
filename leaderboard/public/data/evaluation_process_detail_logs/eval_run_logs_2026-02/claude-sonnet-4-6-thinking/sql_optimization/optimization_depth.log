  where
   t1.jobid = t2.jobid
   and t1.jobstatus = 'O'
   and substr(jobid, 0, 1) = 'A'
  )
   group by
  t2.jobid
   having
  count(decode(t2.jobstatus, 'N', 1, null)) = 0
  )
   ) tt
  where
   tt.rn = 1
  union all
  select
   t.jobid,
   t.tellercode,
   t.jobname,
   t.jobstatus,
   t.jobstartpersname,
   t.jobpriorpersname,
   t.jobtype,
   t.createtime,
   t.tranname,
   t.issucc,
   t.tranprop,
   t.trandata,
   t.jbjg,
   t.jbgy,
   t.ldlcid
  from
   jobinfo_his t,
   businodeinst t1,
   busiflowinst t2
  where
