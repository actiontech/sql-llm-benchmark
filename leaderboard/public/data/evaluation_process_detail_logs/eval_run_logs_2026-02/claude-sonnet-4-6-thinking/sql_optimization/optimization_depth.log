 AND audd.audd_old_value IS NULL AND audd.audd_new_value = '1' AND ah.audh_table_prefix = 'ACC' AND ah.audh_change_type = 'I') onhold_accounts ON opened_accounts.acc_account_no = onhold_accounts.audh_key1 AND opened_accounts.acc_subacc_no = onhold_accounts.audh_key2 JOIN ACCOUNT_LINKS al ON al.accl_account_no = opened_accounts.ACC_ACCOUNT_NO AND al.accl_subacc_no = opened_accounts.ACC_SUBACC_NO AND al.accl_holder_pos = 1 JOIN SUMMIT.ACCOUNT_HOLDING_TAX htax ON htax.ACCTAX_ACCOUNT_NO = al.ACCL_ACCOUNT_NO AND htax.ACCTAX_SUBACC_NO = al.ACCL_SUBACC_NO AND htax.ACCTAX_CUST_SEQNO = al.ACCL_CUST_SEQNO)

