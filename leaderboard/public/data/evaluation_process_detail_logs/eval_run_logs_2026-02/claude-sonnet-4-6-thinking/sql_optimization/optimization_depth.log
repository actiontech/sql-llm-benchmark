_subacc_no = al.accl_subacc_no AND htax.acctax_cust_seqno = al.accl_cust_seqno WHERE ah.audh_table_prefix = 'ACC' AND ah.audh_change_type = 'I' GROUP BY a.acc_account_no, a.acc_subacc_no, acch.acch_title, a.acc_incep_date, htax.ACCTAX_EFF_DATE_FROM, ah.audh_date, act.act_long_name, t.tran_amount_cr, t.tran_create_by, acch.acch_brn_code

