WITH tmep_ip AS (SELECT a.register_no AS patientid, a.inpatient_name AS patientname, a.age, a.sex AS gender, date(a.in_date) AS indate, date(a.out_date) AS outdate, a.times AS inhospitaltimes, a.person_type AS persontype, a.patient_no AS serialno, b.total_cost AS medicalcost, 'doctor' AS entrymode, 'remind' AS defaulttab, a.current_dept_code AS deptcode, '440100' AS citycode FROM his_temp_ip_patient_info a LEFT JOIN his_temp_ip_settle b ON a.register_no = b.register_no AND a.times = b.times WHERE a.out_date > '2025-01-01'), diagnosis AS (SELECT inp_no, visit_id AS times, type, diagnosis_type_name, diagnosis_flag, CASE WHEN diagnosis_flag = '1' THEN string_agg(diagnosis_code, ',' ORDER BY diagnosis_no) END AS diagnosis_codes, CASE WHEN diagnosis_flag = '0' THEN string_agg(diagnosis_code, ',' ORDER BY diagnosis_no) END AS chinese_diagnosis_codes, CASE WHEN diagnosis_flag = '0' THEN string_agg(diagnosis_name, ',' ORDER BY diagnosis_no) END AS chinese_diagnosis_names FROM emr_temp_ip_patient_diagnosis WHERE file_visit_type = '2' GROUP BY inp_no, visit_id, type, diagnosis_type_name, diagnosis_flag), diagnosis_ranked AS (SELECT *, row_number() OVER (PARTITION BY inp_no, times, type ORDER BY CASE WHEN type = '病历诊断' AND diagnosis_type_name = '最后诊断' THEN 1 WHEN type = '病历诊断' AND diagnosis_type_name = '初步诊断' THEN 2 WHEN type = '首页诊断' AND diagnosis_type_name = '出院诊断' THEN 1 WHEN type = '首页诊断' AND diagnosis_type_name = '门诊诊断' THEN 2 ELSE 3 END) AS rn FROM diagnosis), diagnosis_end AS (SELECT inp_no, times, type, diagnosis_type_name, max(CASE WHEN diagnosis_flag = '1' THEN diagnosis_codes END) AS diagnosis_codes, max(CASE WHEN diagnosis_flag = '0' THEN chinese_diagnosis_codes END) AS chinese_diagnosis_codes, max(CASE WHEN diagnosis_flag = '0' THEN chinese_diagnosis_names END) AS chinese_diagnosis_names FROM diagnosis_ranked WHERE rn = 1 GROUP BY inp_no, times, type, diagnosis_type_name), operations AS (SELECT inp_no, visit_id AS times, string_agg(operation_code, ',' ORDER BY operation_no) AS operation_codes FROM emr_temp_ip_patient_operation GROUP BY inp_no, visit_id) SELECT t.patientid, t.patientname, t.age, t.gender, t.indate, t.outdate, t.inhospitaltimes, d.type, d.diagnosis_codes AS diagnosiscode, o.operation_codes AS operationcode, t.medicalcost, t.persontype, t.entrymode, t.serialno, t.defaulttab, d.chinese_diagnosis_codes AS chinesediagnosiscode, d.chinese_diagnosis_names AS chinesediagnosename, t.deptcode, t.citycode FROM tmep_ip t LEFT JOIN diagnosis_end d ON t.patientid = d.inp_no AND t.inhospitaltimes = d.times LEFT JOIN operations o ON t.patientid = o.inp_no AND t.inhospitaltimes = o.times ORDER BY t.outdate DESC

