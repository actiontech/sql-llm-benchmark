   partition by
  t3.jobid
   order by
  t3.createtime desc
  ) as rn
  from
  jobinfo_his t3
  where
  exists (
   select
  t2.jobid
   from
  jobinfo_his t2
   where
  t2.jobid = t3.jobid
  and exists (
  select
   t1.jobid
  from
