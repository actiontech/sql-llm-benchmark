    FROM
      mrtopration A
    LEFT JOIN mrtrecordinfo B ON
      A.ID = B.ID
    WHERE
      B.ID LIKE '%' || 'ABC' || '%'
    GROUP BY
      B.ID,
      B.IN_DATE)
  WHERE
    rn BETWEEN 0 + 0 AND 10 + 0)
ORDER BY
  A.OPERDATE DESC

