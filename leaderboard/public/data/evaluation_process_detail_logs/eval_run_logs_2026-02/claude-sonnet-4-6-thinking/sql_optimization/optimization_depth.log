   (
  select
  t3.jobid,
  t3.tellercode,
  t3.jobname,
  t3.jobstatus,
  t3.jobstartpersname,
  t3.jobpriorpersname,
  t3.jobtype,
  t3.createtime,
  t3.tranname,
  t3.issucc,
  t3.tranprop,
  t3.trandata,
  t3.jbjg,
  t3.jbgy,
