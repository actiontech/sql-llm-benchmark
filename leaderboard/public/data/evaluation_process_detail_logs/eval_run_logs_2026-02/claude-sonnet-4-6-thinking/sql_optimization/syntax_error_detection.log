## SQL:
SELECT /*+ USE_HASH(c m) */ c.inst_id, m.end_time AS checktime, c.conn, c.activeconn, m.sqlthroughput, m.sqlavgtime, m.user_commits, m.user_rollbacks, m.user_commits + m.user_rollbacks AS transactioncount, m.transactionavgtime FROM (SELECT inst_id, COUNT(*) AS conn, COUNT(CASE WHEN status = 'ACTIVE' THEN 1 END) AS activeconn FROM gv$session WHERE TYPE = 'USER' GROUP BY inst_id) c JOIN (SELECT * FROM (SELECT inst_id, end_time, metric_name, CASE WHEN metric_name IN ('Executions Per Sec', 'User Commits Per Sec', 'User Rollbacks Per Sec') THEN ROUND(VALUE, 2) ELSE ROUND(VALUE * 10, 2) END AS VALUE FROM gv$sysmetric WHERE intsize_csec >= 5950 AND intsize_csec < 6050 AND metric_name IN ('Executions Per Sec', 'SQL Service Response Time', 'User Commits Per Sec', 'User Rollbacks Per Sec', 'Response Time Per Txn')) PIVOT (AVG(VALUE) FOR metric_name IN ('Executions Per Sec' sqlthroughput, 'SQL Service Response Time' sqlavgtime, 'User Commits Per Sec' user_commits, 'User Rollbacks Per Sec' user_rollbacks, 'Response Time Per Txn' transactionavgtime))) m ON c.inst_id = m.inst_id ORDER BY c.inst_id

