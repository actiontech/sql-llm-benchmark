SELECT /*+ LEADING(ah ad a acch act ft t al htax) USE_NL(ad) USE_NL(a) USE_NL(acch) USE_NL(act) USE_NL(ft) USE_NL(t) USE_NL(al) USE_NL(htax) INDEX(ah idx_audh_table_prefix) INDEX(ad idx_audd_audh_seqno) INDEX(a SYS_C008302) INDEX(acch SYS_C008303) INDEX(act SYS_C008304) INDEX(al idx_accl_account_subacc) INDEX(htax idx_acctax_composite) INDEX(t SYS_C008308) */ a.acc_account_no, a.acc_subacc_no, acch.acch_title, TO_CHAR(a.acc_incep_date,'DD/MM/YYYY') acc_incep_date, htax.ACCTAX_EFF_DATE_FROM, TO_CHAR(ah.audh_date,'DD-MON-YYYY') approved_date, act.act_long_name, t.tran_amount_cr, t.tran_create_by, GREATEST(0, TRUNC(a.acc_incep_date) - TRUNC(ah.audh_date)) time_on_approved, acch.acch_brn_code FROM audit_header ah JOIN audit_detail ad ON ad.audd_audh_seqno = ah.audh_seqno AND ad.audd_col_sufix = 'PROCESS_STATUS' AND ad.audd_old_value IS NULL AND ad.audd_new_value = '1' JOIN accounts a ON a.acc_account_no = ah.audh_key1 AND a.acc_subacc_no = ah.audh_key2 AND a.acc_gact_type IN ('S','IC') AND a.acc_incep_date BETWEEN IN_INCEP_FROM_DATE AND IN_INCEP_TO_DATE JOIN account_headers acch ON acch.acch_account_no = a.acc_account_no JOIN account_types act ON act.act_code = a.acc_act_code JOIN (SELECT /*+ INDEX(tr idx_trans_account_subacc) INDEX(tr idx_trans_trans_code) INDEX(tr idx_trans_pay_method) */ tr.tran_account_no, tr.tran_subacc_no, MIN(tr.tran_seqno) first_tran_seq FROM transactions tr WHERE tr.tran_amount_cr IS NOT NULL AND tr.tran_trans_code IN ('RIC','RSAV') AND tr.tran_date BETWEEN IN_FUND_FROM_DATE AND IN_FUND_TO_DATE AND tr.tran_pay_method NOT IN ('C','CQ') GROUP BY tr.tran_account_no, tr.tran_subacc_no) ft ON ft.tran_account_no = a.acc_account_no AND ft.tran_subacc_no = a.acc_subacc_no JOIN transactions t ON t.tran_seqno = ft.first_tran_seq JOIN account_links al ON al.accl_account_no = a.acc_account_no AND al.accl_subacc_no = a.acc_subacc_no AND al.accl_holder_pos = 1 JOIN SUMMIT.account_holding_tax htax ON htax.acctax_account_no = al.accl_account_no AND htax.acctax_subacc_no = al.accl_subacc_no AND htax.acctax_cust_seqno = al.accl_cust_seqno WHERE ah.audh_table_prefix = 'ACC' AND ah.audh_change_type = 'I' GROUP BY a.acc_account_no, a.acc_subacc_no, acch.acch_title, a.acc_incep_date, htax.ACCTAX_EFF_DATE_FROM, ah.audh_date, act.act_long_name, t.tran_amount_cr, t.tran_create_by, acch.acch_brn_code

