SELECT temp.*, t_rmm_store.STORE_NAME, t_rmm_location.LOCATION_NAME, t_qdm_standard.STANDARD_NAME, t_bdm_column.COLUMN_NAME AS `STEEL_GRADE_NAME`, t_dgm_send_info.SEND_ID AS `CONNECT_ID`, t_dgm_send_info_detail.SEND_PRODUCT_DETAIL_ID AS `CONNECT_DETAIL_ID`, IF(t_dgm_send_info_detail.SPOT_TYPE = '40', IFNULL(t_dgm_send_info_detail.WEIGHT, 0), IFNULL(t_dgm_send_info_detail.NUMBER, 0)) AS `SEND_NUMBER`, IF(t_dgm_send_info_detail.SPOT_TYPE = '40', IFNULL(t_dgm_send_info_return_detail.WEIGHT, 0), IFNULL(t_dgm_send_info_return_detail.NUMBER, 0)) AS `RETURN_NUMBER` FROM t_dgm_send_info_detail INNER JOIN t_dgm_send_info ON t_dgm_send_info.SEND_ID = t_dgm_send_info_detail.SEND_ID AND t_dgm_send_info.SEND_STATE = '70' LEFT JOIN t_dgm_send_info_return_detail ON t_dgm_send_info_return_detail.CONNECT_DETAIL_ID = t_dgm_send_info_detail.SEND_PRODUCT_DETAIL_ID INNER JOIN (SELECT v_pre_product_material.PRODUCE_MATERIAL_ID, IFNULL(v_pre_product_material.PACKAGE_NO, v_pre_product_material.MATERIAL_NO) AS MIXED_NO, '30' AS SPOT_TYPE, v_pre_product_material.MATERIAL_NO, v_pre_product_material.PACKAGE_NO, v_pre_product_material.PSR_ID, v_pre_product_material.CUSTOMER_ID, v_pre_product_material.CONTRACT_ID, v_pre_product_material.CONTRACT_NO, v_pre_product_material.NUMBER, v_pre_product_material.NET_WEIGHT, v_pre_product_material.GROSS_WT, v_pre_product_material.STORE_ID, v_pre_product_material.LOCATION_ID, v_pre_product_material.STANDARD_ID, v_pre_product_material.STEEL_GRADE, v_pre_product_material.SURFACE_GROUP_DESC, v_pre_product_material.CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, IF((v_pre_product_material.LENGTH IS NOT NULL) AND (v_pre_product_material.LENGTH != 0), CONCAT(v_pre_product_material.THICK, '*', v_pre_product_material.WIDTH, '*', v_pre_product_material.LENGTH), CONCAT(v_pre_product_material.THICK, '*', v_pre_product_material.WIDTH, '*C')) AS specs, SUM(IF(t_sam_contract_detail.BUY_UNIT = '10', t_sam_contract_detail.TAX_PRICE * v_pre_product_material.NET_WEIGHT, t_sam_contract_detail.TAX_PRICE * IFNULL(t_sam_contract_detail.NUMBER, 1))) AS `PRICE` FROM v_pre_product_material LEFT JOIN t_dgm_send_plan_detail material ON v_pre_product_material.MATERIAL_NO = material.MATERIAL_NO LEFT JOIN t_dgm_send_plan_detail package ON v_pre_product_material.PACKAGE_NO = package.PACKAGE_NO LEFT JOIN t_mao_contract_delivery_subkey ON t_mao_contract_delivery_subkey.CONTRACT_DELIVERY_ID = v_pre_product_material.CONTRACT_DELIVERY_ID LEFT JOIN t_sam_contract_detail ON t_mao_contract_delivery_subkey.CONTRACT_DETAIL_ID = t_sam_contract_detail.CONTRACT_DETAILS_ID WHERE v_pre_product_material.IS_ISSUED = '1' AND v_pre_product_material.IS_SPOT_RESOURCE = '0' AND v_pre_product_material.NI36_TAG = '0' AND v_pre_product_material.MATERIAL_STATE != '110' AND v_pre_product_material.CONTRACT_TYPE != '60' AND v_pre_product_material.CUSTOMER_ID = '1930921074703462401' AND NOT EXISTS (SELECT 1 FROM v_pre_product_material v2 WHERE v2.PACKAGE_NO = v_pre_product_material.PACKAGE_NO AND v2.IS_ISSUED != '1') AND NOT EXISTS (SELECT 1 FROM v_pre_product_material v2 WHERE v2.MATERIAL_NO = v_pre_product_material.MATERIAL_NO AND v2.IS_ISSUED != '1') GROUP BY COALESCE(v_pre_product_material.PACKAGE_NO, v_pre_product_material.MATERIAL_NO) UNION ALL SELECT t_sam_contract_detail.CONTRACT_DETAILS_ID AS `PRODUCE_MATERIAL_ID`, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MIXED_NO`, '10' AS SPOT_TYPE, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MATERIAL_NO`, NULL AS `PACKAGE_NO`, t_bdm_column.COLUMN_NAME AS `PSR_ID`, t_sam_contract.CUSTOMER_ID, t_sam_contract.CONTRACT_ID, t_sam_contract.CONTRACT_NO, 1 AS NUMBER, t_inm_store_info.NEW_WEIGHT AS `NET_WEIGHT`, t_inm_store_info.GROSS_WT AS GROSS_WT, t_inm_store_info.STORE_ID AS STORE_ID, t_inm_store_info.LOCATION_ID AS LOCATION_ID, NULL AS STANDARD_ID, t_inm_store_info.STEEL_GRADE, NULL AS SURFACE_GROUP_DESC, t_sam_contract_detail.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, t_inm_store_info.VARIETY_ID, IF(t_inm_store_info.MATERIAL_LENGTH IS NOT NULL AND t_inm_store_info.MATERIAL_LENGTH != 0, CONCAT_WS('*', t_inm_store_info.MATERIAL_THICK, t_inm_store_info.MATERIAL_WIDTH, t_inm_store_info.MATERIAL_LENGTH), CONCAT_WS('*', t_inm_store_info.MATERIAL_THICK, t_inm_store_info.MATERIAL_WIDTH, 'C')) AS specs, t_sam_contract_detail.IN_TAX_TOTAL AS `PRICE` FROM t_sam_contract_detail INNER JOIN t_sam_contract ON t_sam_contract.CONTRACT_ID = t_sam_contract_detail.CONTRACT_ID AND t_sam_contract.CONTRACT_TYPE = '20' AND t_sam_contract.IS_DELETE = '0' AND t_sam_contract.CONTRACT_STATE IN ('40', '50', '70') AND t_sam_contract.CUSTOMER_ID = '1930921074703462401' LEFT JOIN t_inm_store_info ON t_inm_store_info.MATERIAL_NO = t_sam_contract_detail.PRODUCT_MATERIAL_NO LEFT JOIN zjjs_mpm.t_bdm_column t_bdm_column ON t_inm_store_info.VARIETY_ID = t_bdm_column.COLUMN_ID WHERE t_sam_contract_detail.IS_DELETE = '0' AND t_sam_contract_detail.SPOT_TYPE = '10' AND t_inm_store_info.STOCK_ID IS NOT NULL GROUP BY t_sam_contract_detail.PRODUCT_MATERIAL_NO UNION ALL SELECT t_pre_product_material.PRODUCE_MATERIAL_ID AS `PRODUCE_MATERIAL_ID`, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MIXED_NO`, '30' AS SPOT_TYPE, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MATERIAL_NO`, t_pre_product_material.PACKAGE_NO AS `PACKAGE_NO`, t_pre_product_material.PSR_ID, t_sam_contract.CUSTOMER_ID, t_sam_contract.CONTRACT_ID, t_sam_contract.CONTRACT_NO, t_pre_product_material.NUMBER AS NUMBER, t_pre_product_material.NET_WEIGHT AS NET_WEIGHT, t_pre_product_material.GROSS_WT AS GROSS_WT, t_pre_product_material.STORE_ID AS STORE_ID, t_pre_product_material.LOCATION_ID AS LOCATION_ID, t_pre_product_material.STANDARD_ID AS STANDARD_ID, t_pre_product_material.STEEL_GRADE, t_pre_product_material.SURFACE_GROUP_DESC AS SURFACE_GROUP_DESC, t_sam_contract_detail.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, IF((t_pre_product_material.LENGTH IS NOT NULL) AND (t_pre_product_material.LENGTH != 0), CONCAT(t_pre_product_material.THICK, '*', t_pre_product_material.WIDTH, '*', t_pre_product_material.LENGTH), CONCAT(t_pre_product_material.THICK, '*', t_pre_product_material.WIDTH, '*C')) AS specs, t_sam_contract_detail.IN_TAX_TOTAL AS `PRICE` FROM t_sam_contract_detail INNER JOIN t_sam_contract ON t_sam_contract.CONTRACT_ID = t_sam_contract_detail.CONTRACT_ID AND t_sam_contract.CONTRACT_TYPE = '20' AND t_sam_contract.IS_DELETE = '0' AND t_sam_contract.CONTRACT_STATE IN ('40', '50', '70') AND t_sam_contract.CUSTOMER_ID = '1930921074703462401' LEFT JOIN t_pre_product_material ON t_sam_contract_detail.PRODUCT_MATERIAL_NO = t_pre_product_material.PACKAGE_NO OR t_sam_contract_detail.PRODUCT_MATERIAL_NO = t_pre_product_material.MATERIAL_NO WHERE t_sam_contract_detail.IS_DELETE = '0' AND t_sam_contract_detail.SPOT_TYPE IN ('20', '30') AND t_pre_product_material.PRODUCE_MATERIAL_ID IS NOT NULL GROUP BY t_sam_contract_detail.PRODUCT_MATERIAL_NO UNION ALL SELECT t_sam_contract_detail.SCRAP_INFO_ID AS `PRODUCE_MATERIAL_ID`, t_pre_scrap.BATCH_NO AS `MIXED_NO`, t_sam_contract_detail.SPOT_TYPE AS SPOT_TYPE, t_pre_scrap.BATCH_NO AS `MATERIAL_NO`, t_pre_scrap.BATCH_NO AS `PACKAGE_NO`, t_pre_scrap.PRODUCT_NAME AS PSR_ID, t_sam_contract.CUSTOMER_ID, t_sam_contract.CONTRACT_ID, t_sam_contract.CONTRACT_NO, NULL AS NUMBER, t_pre_scrap.WEIGHT AS NET_WEIGHT, NULL AS GROSS_WT, '/' AS STORE_ID, '/' AS LOCATION_ID, NULL AS STANDARD_ID, t_pre_scrap.STEEL_GRADE, NULL AS SURFACE_GROUP_DESC, t_sam_contract_detail.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, NULL AS specs, t_pre_scrap.WEIGHT * t_sam_contract_detail.TAX_PRICE AS `PRICE` FROM t_sam_contract_detail INNER JOIN t_sam_contract ON t_sam_contract.CONTRACT_ID = t_sam_contract_detail.CONTRACT_ID AND t_sam_contract.CONTRACT_TYPE = '20' AND t_sam_contract.IS_DELETE = '0' AND t_sam_contract.CONTRACT_STATE IN ('40', '50', '70') AND t_sam_contract.CUSTOMER_ID = '1930921074703462401' LEFT JOIN t_pre_scrap ON t_pre_scrap.SCRAP_INFO_ID = t_sam_contract_detail.SCRAP_INFO_ID WHERE t_sam_contract_detail.IS_DELETE = '0' AND t_sam_contract_detail.SPOT_TYPE = '40' GROUP BY t_pre_scrap.BATCH_NO) AS temp ON temp.MIXED_NO = t_dgm_send_info_detail.MIXED_NO LEFT JOIN zjjs_rmm.t_rmm_store t_rmm_store ON t_rmm_store.STORE_ID = temp.STORE_ID LEFT JOIN zjjs_rmm.t_rmm_location t_rmm_location ON t_rmm_location.LOCATION_ID = temp.LOCATION_ID LEFT JOIN zjjs_qdm.t_qdm_standard t_qdm_standard ON t_qdm_standard.STANDARD_ID = temp.STANDARD_ID LEFT JOIN zjjs_mpm.t_bdm_column t_bdm_column ON t_bdm_column.COLUMN_ID = temp.STEEL_GRADE GROUP BY temp.MIXED_NO HAVING SEND_NUMBER > RETURN_NUMBER LIMIT 100

