 AS MNT_MFR_ID_TEXT, RES_ENTITY.SF_GET_STAFF_NAME(EE.MODIFY_OP) AS MODIFY_OP_TEXT, RES_ENTITY.SF_GET_STAFF_NAME(EE.CREATE_OP) AS CREATE_OP_TEXT, RES_ENTITY.SF_GET_STAFF_NAME(EE.CHECK_PERSON) AS CHECK_PERSON_TEXT, ST.DISTRICT_PROVINCE_ID, ST.DISTRICT_REGION_ID, ST.DISTRICT_COUNTY_ID, ST.STATION_NAME, ST.STATION_NAME AS STATION_ID_TEXT, D.APP_REGION_ID, RM.REGION_NAME AS APP_REGION_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_PROVINCE_ID) AS DISTRICT_PROVINCE_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_REGION_ID) AS DISTRICT_REGION_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_COUNTY_ID) AS DISTRICT_COUNTY_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_PROVINCE_ID)||res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_REGION_ID)||res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_COUNTY_ID) AS REGION_ID_TEXT, P.RN FROM PAGED P JOIN RES_ENTITY.ENT_ENTITY EE ON EE.ENTITY_ID=P.ENTITY_ID LEFT JOIN RES_ENTITY.ENT_ROOM B ON B.ENTITY_ID=EE.ENTITY_ID LEFT JOIN RES_ENTITY.STA_STATION ST ON ST.STATION_CODE=EE.STATION_CODE LEFT JOIN RES_ENTITY.STA_APP_INFO D ON ST.STATION_ID=D.STATION_ID LEFT JOIN RES_ENTITY.REG_MANAGE RM ON RM.REGION_ID=D.APP_REGION_ID AND RM.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR M1 ON M1.MFR_ID=B.INTEG_CABINET_AC_MFR_ID AND M1.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR M2 ON M2.MFR_ID=EE.MFR_ID AND M2.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR M3 ON M3.MFR_ID=EE.DW_MFR_ID AND M3.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR M4 ON M4.MFR_ID=EE.OLD_DW_MFR_ID AND M4.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR M5 ON M5.MFR_ID=EE.MNT_MFR_ID AND M5.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_EQP_TYPE DT1 ON DT1.EQP_TYPE_ID=B.MANUAL_IDENT_RESULT_ID AND DT1.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_EQP_TYPE DT2 ON DT2.EQP_TYPE_ID=EE.DEV_TYPE_ID AND DT2.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_RME_EQP_MODEL EM1 ON EM1.EQP_MODEL_ID=EE.DEV_MODEL_ID AND EM1.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_RME_EQP_MODEL EM2 ON EM2.EQP_MODEL_ID=EE.OLD_DEV_MODEL_ID AND EM