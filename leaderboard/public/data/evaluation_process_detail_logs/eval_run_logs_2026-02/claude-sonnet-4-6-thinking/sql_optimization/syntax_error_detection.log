SELECT s.s_id, s.s_name, s.s_sex, sc.course_count, sc.avg_score, sc.excellent_course_count, RANK() OVER (PARTITION BY s.s_sex ORDER BY sc.avg_score DESC) AS gender_rank FROM (SELECT s_id, COUNT(DISTINCT c_id) AS course_count, AVG(s_score) AS avg_score, SUM(CASE WHEN s_score > 90 THEN 1 ELSE 0 END) AS excellent_course_count FROM Score GROUP BY s_id HAVING AVG(s_score) > 80 AND SUM(CASE WHEN s_score > 90 THEN 1 ELSE 0 END) >= 2) sc JOIN Student s ON s.s_id = sc.s_id ORDER BY sc.avg_score DESC;

