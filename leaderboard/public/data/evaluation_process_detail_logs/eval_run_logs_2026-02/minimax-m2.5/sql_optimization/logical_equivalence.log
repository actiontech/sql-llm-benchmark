id = 1065587309019136 AND A.acctg_period NOT LIKE '%00' AND (A.base_posted_dr != IFNULL(acctg.base_posted_dr1, 0) OR A.base_posted_cr != IFNULL(acctg.base_posted_cr1, 0))) AS combined LIMIT 50001;

