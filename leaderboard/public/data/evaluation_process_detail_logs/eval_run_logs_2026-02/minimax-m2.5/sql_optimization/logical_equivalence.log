ional,0) WHEN 9<=MONTH(GETDATE()) THEN ISNULL(mes9_compra_adicional,0) WHEN 10<=MONTH(GETDATE()) THEN ISNULL(mes10_compra_adicional,0) WHEN 11<=MONTH(GETDATE()) THEN ISNULL(mes11_compra_adicional,0) WHEN 12<=MONTH(GETDATE()) THEN ISNULL(mes12_compra_adicional,0) ELSE 0 END) AS abierto_otr FROM otr.otr_consulta GROUP BY id_tienda,id_departamento,id_subdepartamento,id_clase,id_subclase,tipo_articulo) otr ON otr.id_tienda=c.tienda AND otr.id_departamento=me.departamento AND otr.id_subdepartamento=me.subdepartamento AND otr.id_clase=me.clase AND otr.id_subclase=me.subclase AND otr.tipo_articulo=me.tipo_articulo WHERE c.centro_comercial=1 AND c.tienda=3064 AND c.clima LIKE '%calor todo el tiempo%'
