en s ON b.nobtran_pidm=s.spriden_pidm AND s.spriden_change_ind IS NULL JOIN pebempl pp ON s.spriden_pidm=pp.pebempl_pidm AND pp.pebempl_ecls_code NOT IN ('RE','FW','GS','MW') JOIN norrout r ON b.nobtran_transaction_no=r.norrout_transaction_no AND r.norrout_level_no=90 AND r.norrout_queue_status_ind<>'A' LEFT JOIN (SELECT nortran_transaction_no,nortran_aufd_code,nortran_apty_code,nortran_value FROM nortran WHERE nortran_aufd_code IN ('PEBEMPL_CURRENT_HIRE_DATE','NBRJOBS_PERS_CHG_DATE','NBRJOBS_SGRP_CODE','NBRJOBS_APPT_PCT','NBRJOBS_ANN_SALARY','NBRJOBS_EFFECTIVE_DATE')) n ON b.nobtran_transaction_no=n.nortran_transaction_no LEFT JOIN (SELECT nortern_transaction_no,nortern_effective_date,nortern_earn_code,nortern_hrs,nortern_special_rate FROM nortern) t1 ON b.nobtran_transaction_no=t1.nortern_transaction_no LEFT JOIN (SELECT nortran_transaction_no,MAX(nortran_posn) nortran_posn FROM nortran WHERE nortran_posn IS NOT NULL GROUP BY nortran_transaction_no) z ON b.nobtran_transaction_no=z.nortran_transaction_no WHERE b.nobtran_acat_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') AND b.nobtran_apply_ind='N' AND b.nobtran_trans_status_ind<>'V' GROUP BY s.spriden_id,s.spriden_last_name,s.spriden_first_name,b.nobtran_transaction_no,z.nortran_posn,b.nobtran_effective_date,b.nobtran_acat_code,t1.nortern_effective_date,t1.nortern_earn_code,t1.nortern_hrs,t1.nortern_special_rate,b.nobtran_trans_status_ind,r.norrout_queue_status_ind,r.norrout_level_no ORDER BY 3

