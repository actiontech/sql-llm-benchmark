## Translated SQL:
SELECT u.user_id,u.username,COUNT(DISTINCT o.order_id) AS total_orders,SUM(oi.quantity*oi.unit_price*(1-oi.discount/100)) AS total_spent,AVG(oi.quantity*oi.unit_price*(1-oi.discount/100)) AS avg_order_value,MAX(o.order_date) AS last_order_date,top.top_products FROM users u INNER JOIN orders o ON u.user_id=o.user_id AND o.order_date>=DATE_SUB(CURDATE(),INTERVAL 3 YEAR) LEFT JOIN order_items oi ON o.order_id=oi.order_id CROSS JOIN LATERAL (SELECT GROUP_CONCAT(p.product_name ORDER BY p.product_name SEPARATOR ', ') AS top_products FROM (SELECT oi2.product_id, SUM(oi2.quantity*oi2.unit_price*(1-oi2.discount/100)) AS prod_sum FROM order_items oi2 JOIN orders o2 ON oi2.order_id=o2.order_id WHERE o2.user_id=u.user_id AND o2.order_date>=DATE_SUB(CURDATE(),INTERVAL 3 YEAR) GROUP BY oi2.product_id ORDER BY prod_sum DESC LIMIT 3) prod JOIN products p ON prod.product_id=p.product_id) top WHERE u.status='active' GROUP BY u.user_id,u.username HAVING COUNT(DISTINCT o.order_id)>0 ORDER BY total_spent DESC;

