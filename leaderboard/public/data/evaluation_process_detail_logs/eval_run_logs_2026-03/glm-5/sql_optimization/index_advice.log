SELECT 
  COUNT(DISTINCT id) 
FROM 
  ( 
    SELECT id 
    FROM hotel_price_adjustment pa1 
    WHERE HOTEL_CODE IN ('6199', 'JJXRSEH802967') 
    UNION 
    SELECT id 
    FROM hotel_price_adjustment pa1 
    WHERE CREATE_USER_ID = '289865' 
  ) AS temp;

