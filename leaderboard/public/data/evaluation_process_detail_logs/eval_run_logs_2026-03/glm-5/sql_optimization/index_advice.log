  `pay_state` int(5) unsigned DEFAULT NULL COMMENT '支付状态 0未付款 1已付款 2退款处理中 3已退款',
  `can_cancel` int(5) DEFAULT NULL COMMENT '是否可以取消',
  `need_invoice` int(5) DEFAULT NULL COMMENT '是否需要发票',
