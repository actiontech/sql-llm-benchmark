## SQL:
SELECT u.user_id, u.username, COUNT(DISTINCT o.order_id) AS total_orders, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS total_spent, AVG(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS avg_order_value, MAX(o.order_date) AS last_order_date, top_sq.top_products FROM users u INNER JOIN orders o ON u.user_id = o.user_id LEFT JOIN order_items oi ON o.order_id = oi.order_id LEFT JOIN (SELECT sub.user_id, GROUP_CONCAT(DISTINCT sub.product_name ORDER BY sub.product_name SEPARATOR ', ') AS top_products FROM (SELECT o2.user_id, p2.product_name, ROW_NUMBER() OVER (PARTITION BY o2.user_id ORDER BY SUM(oi2.quantity * oi2.unit_price * (1 - oi2.discount / 100)) DESC) AS rank_num FROM order_items oi2 INNER JOIN products p2 ON oi2.product_id = p2.product_id INNER JOIN orders o2 ON oi2.order_id = o2.order_id INNER JOIN users u2 ON o2.user_id = u2.user_id WHERE u2.status = 'active' AND o2.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL '3' YEAR) GROUP BY o2.user_id, p2.product_name) sub WHERE sub.rank_num <= 3 GROUP BY sub.user_id) top_sq ON u.user_id = top_sq.user_id WHERE u.status = 'active' AND o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL '3' YEAR) GROUP BY u.user_id, u.username ORDER BY total_spent DESC;

