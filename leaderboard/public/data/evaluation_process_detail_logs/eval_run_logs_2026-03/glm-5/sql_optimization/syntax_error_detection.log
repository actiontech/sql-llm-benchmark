SELECT s.spriden_id EID, s.spriden_last_name || ', ' || s.spriden_first_name "NAME", b.nobtran_transaction_no "TRANS NO.", n.posn_no "POSN NO", b.nobtran_effective_date "QUERY DATE", b.nobtran_acat_code "ACAT CODE", n.curr_hire_date "CURRENT HIRE DATE", n.beg_pers_date "BEGIN PERSONNEL DATE", n.sal_grp "SALARY GROUP", n.appt_pct "APPOINTMENT PERCENT", n.ann_sal "ANNUAL SALARY", t1.nortern_effective_date "PAY DATA EFFECTIVE DATE", t1.nortern_earn_code "PAY DATA EARNINGS", t1.nortern_hrs "PAY DATA HOURS", t1.nortern_special_rate "PAY DATA SPECIAL RATE", n.end_job_eff_date "END JOB EFFECTIVE DATE", n.end_pers_date "END PERSONNEL DATE", CASE b.nobtran_trans_status_ind WHEN 'A' THEN 'Approved' WHEN 'C' THEN 'Completed' WHEN 'V' THEN 'Voided' WHEN 'D' THEN 'Disapproved' WHEN 'R' THEN 'Return for Correction' WHEN 'P' THEN 'Pending' WHEN 'W' THEN 'Waiting' WHEN 'T' THEN 'Partially Completed' WHEN 'N' THEN 'Cancelled' WHEN 'U' THEN 'Superuser Update' END trans_status, CASE r.norrout_queue_status_ind WHEN 'A' THEN 'Approved by that Approver' WHEN 'D' THEN 'Disapproved' WHEN 'F' THEN 'FYI' WHEN 'I' THEN 'In Queue' WHEN 'K' THEN 'Acknowledged' WHEN 'L' THEN 'Applied by Applier' WHEN 'M' THEN 'More Information' WHEN 'O' THEN 'Overridden' WHEN 'P' THEN 'Pending Action by Approver/Applier ' WHEN 'Q' THEN 'Removed from Queue' WHEN 'R' THEN 'Return for Correction' END queue_status, r.norrout_level_no FROM nobtran b INNER JOIN spriden s ON b.nobtran_pidm = s.spriden_pidm INNER JOIN pebempl pp ON s.spriden_pidm = pp.pebempl_pidm INNER JOIN norrout r ON b.nobtran_transaction_no = r.norrout_transaction_no LEFT JOIN nortern t1 ON b.nobtran_transaction_no = t1.nortern_transaction_no LEFT JOIN (SELECT nortran_transaction_no, MAX(CASE WHEN nortran_aufd_code = 'PEBEMPL_CURRENT_HIRE_DATE' THEN nortran_value END) AS curr_hire_date, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_PERS_CHG_DATE' THEN nortran_value END) AS beg_pers_date, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_SGRP_CODE' THEN nortran_value END) AS sal_grp, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_APPT_PCT' THEN nortran_value END) AS appt_pct, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_ANN_SALARY' THEN nortran_value END) AS ann_sal, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_EFFECTIVE_DATE' AND nortran_apty_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') THEN nortran_value END) AS end_job_eff_date, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_PERS_CHG_DATE' AND nortran_apty_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') THEN nortran_value END) AS end_pers_date, MAX(nortran_posn) AS posn_no FROM nortran GROUP BY nortran_transaction_no) n ON b.nobtran_transaction_no = n.nortran_transaction_no WHERE b.nobtran_acat_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') AND s.spriden_change_ind IS NULL AND r.norrout_level_no = 90 AND b.nobtran_apply_ind = 'N' AND b.nobtran_trans_status_ind <> 'V' AND r.norrout_queue_status_ind <> 'A' AND pp.pebempl_ecls_code NOT IN ('RE','FW','GS','MW') ORDER BY 3

