## SQL:
with tmep_ip as (select a.register_no as patientid, a.inpatient_name as patientname, a.age, a.sex as gender, date(a.in_date) as indate, date(a.out_date) as outdate, a.times as inhospitaltimes, a.person_type as persontype, a.patient_no as serialno, b.total_cost as medicalcost, 'doctor' as entrymode, 'remind' as defaulttab, a.current_dept_code as deptcode, '440100' as citycode from his_temp_ip_patient_info a left join his_temp_ip_settle b on a.register_no = b.register_no and a.times = b.times where a.out_date >= '2025-01-02'), best_diagnosis_type as (select distinct on (inp_no, visit_id, type) inp_no, visit_id as times, type, diagnosis_type_name from emr_temp_ip_patient_diagnosis where file_visit_type = '2' order by inp_no, visit_id, type, case when type = '病历诊断' and diagnosis_type_name = '最后诊断' then 1 when type = '病历诊断' and diagnosis_type_name = '初步诊断' then 2 when type = '首页诊断' and diagnosis_type_name = '出院诊断' then 1 when type = '首页诊断' and diagnosis_type_name = '门诊诊断' then 2 else 3 end), diagnosis_agg as (select d.inp_no, d.visit_id as times, d.type, d.diagnosis_type_name, d.diagnosis_flag, string_agg(d.diagnosis_code, ',' order by d.diagnosis_no) as diagnosis_codes, string_agg(d.diagnosis_name, ',' order by d.diagnosis_no) as diagnosis_names from emr_temp_ip_patient_diagnosis d join best_diagnosis_type b on d.inp_no = b.inp_no and d.visit_id = b.times and d.type = b.type and d.diagnosis_type_name = b.diagnosis_type_name where d.file_visit_type = '2' group by d.inp_no, d.visit_id, d.type, d.diagnosis_type_name, d.diagnosis_flag), diagnosis_end as (select inp_no, times, type, diagnosis_type_name, max(case when diagnosis_flag = '1' then diagnosis_codes end) as diagnosis_codes, max(case when diagnosis_flag = '0' then diagnosis_codes end) as chinese_diagnosis_codes, max(case when diagnosis_flag = '0' then diagnosis_names end) as chinese_diagnosis_names from diagnosis_agg group by inp_no, times, type, diagnosis_type_name), operations as (select inp_no, visit_id as times, string_agg(operation_code, ',' order by operation_no) as operation_codes from emr_temp_ip_patient_operation group by inp_no, visit_id) select t.patientid, t.patientname, t.age, t.gender, t.indate, t.outdate, t.inhospitaltimes, d.type, d.diagnosis_codes as diagnosiscode, o.operation_codes as operationcode, t.medicalcost, t.persontype, t.entrymode, t.serialno, t.defaulttab, d.chinese_diagnosis_codes as chinesediagnosiscode, d.chinese_diagnosis_names as chinesediagnosename, t.deptcode, t.citycode from tmep_ip t left join diagnosis_end d on t.patientid = d.inp_no and t.inhospitaltimes::varchar = d.times left join operations o on t.patientid = o.inp_no and t.inhospitaltimes::varchar = o.times order by t.outdate desc

