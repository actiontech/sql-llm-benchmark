SELECT s.s_id, s.s_name, s.s_sex, COUNT(DISTINCT sc.c_id) AS course_count, AVG(sc.s_score) AS avg_score, SUM(CASE WHEN sc.s_score > 90 THEN 1 ELSE 0 END) AS excellent_course_count, RANK() OVER (PARTITION BY s.s_sex ORDER BY AVG(sc.s_score) DESC) AS gender_rank FROM Student s JOIN (SELECT s_id FROM Score WHERE s_score > 90 GROUP BY s_id HAVING COUNT(*) >= 2) AS qs ON s.s_id = qs.s_id JOIN Score sc ON s.s_id = sc.s_id GROUP BY s.s_id, s.s_name, s.s_sex HAVING AVG(sc.s_score) > 80 ORDER BY avg_score DESC;

