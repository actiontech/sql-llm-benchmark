tract_detail.NUMBER, 1))) AS `PRICE` FROM v_pre_product_material INNER JOIN (SELECT COALESCE(PACKAGE_NO, MATERIAL_NO) AS VALID_KEY FROM v_pre_product_material GROUP BY COALESCE(PACKAGE_NO, MATERIAL_NO) HAVING SUM(CASE WHEN IS_ISSUED != '1' THEN 1 ELSE 0 END) = 0) valid_keys ON IFNULL(v_pre_product_material.PACKAGE_NO, v_pre_product_material.MATERIAL_NO) = valid_keys.VALID_KEY LEFT JOIN t_dgm_send_plan_detail material ON v_pre_product_material.MATERIAL_NO = material.MATERIAL_NO LEFT JOIN t_dgm_send_plan_detail package ON v_pre_product_material.PACKAGE_NO = package.PACKAGE_NO LEFT JOIN t_mao_contract_delivery_subkey ON t_mao_contract_delivery_subkey.CONTRACT_DELIVERY_ID = v_pre_product_material.CONTRACT_DELIVERY_ID LEFT JOIN t_sam_contract_detail ON t_mao_contract_delivery_subkey.CONTRACT_DETAIL_ID = t_sam_contract_detail.CONTRACT_DETAILS_ID WHERE v_pre_product_material.IS_ISSUED = '1' AND v_pre_product_material.IS_SPOT_RESOURCE = '0' AND v_pre_product_material.NI36_TAG = '0' AND v_pre_product_material.MATERIAL_STATE != '110' AND v_pre_product_material.CONTRACT_TYPE != '60' AND v_pre_product_material.CUSTOMER_ID = '1930921074703462401' GROUP BY COALESCE(v_pre_product_material.PACKAGE_NO, v_pre_product_material.MATERIAL_NO) UNION ALL SELECT t_sam_contract_detail.CONTRACT_DETAILS_ID AS `PRODUCE_MATERIAL_ID`, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MIXED_NO`, '10' AS SPOT_TYPE, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MATERIAL_NO`, NULL AS `PACKAGE_NO`, t_bdm_column.COLUMN_NAME AS `PSR_ID`, t_sam_contract.CUSTOMER_ID, t_sam_contract.CONTRACT_ID, t_sam_contract.CONTRACT_NO, 1 AS NUMBER, t_inm_store_info.NEW_WEIGHT AS `NET_WEIGHT`, t_inm_store_info.GROSS_WT AS GROSS_WT, t_inm_store_info.STORE_ID AS STORE_ID, t_inm_store_info.LOCATION_ID AS LOCATION_ID, NULL AS STANDARD_ID, t_inm_store_info.STEEL_GRADE, NULL AS SURFACE_GROUP_DESC, t_sam_contract_detail.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, t_inm_store_info.VARIETY_ID, IF(t_inm_store_info.MATERIAL_LENGTH IS NOT NULL AND t_inm_store_info.MATERIAL_LENGTH != 0, CONCAT_WS("*", t_inm_store_info.MATERIAL_THICK, t_inm_store_info.MATERIAL_WIDTH, t_inm_store_info.MATERIAL_LENGTH), CONCAT_WS("*", t_inm_store_info.MATERIAL_THICK, t_inm_store_info.MATERIAL_WIDTH, 'C')) AS specs, t_sam_contract_detail.IN_TAX_TOTAL AS `PRICE` FROM t_sam_contract_detail INNER JOIN t_sam_contract ON t_sam_contract.CONTRACT_ID = t_sam_contract_detail.CONTRACT_ID LEFT JOIN t_inm_store_info ON t_inm_store_info.MATERIAL_NO = t_sam_contract_detail.PRODUCT_MATERIAL_NO LEFT JOIN zjjs_mpm.t_bdm_column t_bdm_column ON t_inm_store_info.VARIETY_ID = t_bdm_column.COLUMN_ID WHERE t_sam_contract.CONTRACT_TYPE = '20' AND t_sam_contract_detail.IS_DELETE = '0' AND t_sam_contract.IS_DELETE = '0' AND t_sam_contract_detail.SPOT_TYPE = '10' AND t_inm_store_info.STOCK_ID IS NOT NULL AND t_sam_contract.CONTRACT_STATE IN ('40', '50', '70') AND t_sam_contract.CUSTOMER_ID = '1930921074703462401' GROUP BY t_sam_contract_detail.PRODUCT_MATERIAL_NO UNION ALL SELECT t_pre_product_material.PRODUCE_MATERIAL_ID AS `PRODUCE_MATERIAL_ID`, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MIXED_NO`, '30' AS SPOT_TYPE, t_sam_contract_detail.PRODUCT_MATERIAL_NO AS `MATERIAL_NO`, t_pre_product_material.PACKAGE_NO AS `PACKAGE_NO`, t_pre_product_material.PSR_ID, t_sam_contract.CUSTOMER_ID, t_sam_contract.CONTRACT_ID, t_sam_contract.CONTRACT_NO, t_pre_product_material.NUMBER AS NUMBER, t_pre_product_material.NET_WEIGHT AS NET_WEIGHT, t_pre_product_material.GROSS_WT AS GROSS_WT, t_pre_product_material.STORE_ID AS STORE_ID, t_pre_product_material.LOCATION_ID AS LOCATION_ID, t_pre_product_material.STANDARD_ID AS STANDARD_ID, t_pre_product_material.STEEL_GRADE, t_pre_product_material.SURFACE_GROUP_DESC AS SURFACE_GROUP_DESC, t_sam_contract_detail.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, IF((t_pre_product_material.LENGTH IS NOT NULL) AND (t_pre_product_material.LENGTH != 0), CONCAT(t_pre_product_material.THICK, '*', t_pre_product_