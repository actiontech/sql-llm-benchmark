an_value END) AS sal_grp, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_APPT_PCT' THEN nortran_value END) AS appt_pct, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_ANN_SALARY' THEN nortran_value END) AS ann_sal, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_EFFECTIVE_DATE' AND nortran_apty_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') THEN nortran_value END) AS end_job_eff_date, MAX(CASE WHEN nortran_aufd_code = 'NBRJOBS_PERS_CHG_DATE' AND nortran_apty_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') THEN nortran_value END) AS end_pers_date, MAX(nortran_posn) AS posn_no FROM nortran GROUP BY nortran_transaction_no) n ON b.nobtran_transaction_no = n.nortran_transaction_no WHERE b.nobtran_acat_code IN ('CFOAP','NWHIR','NWTMP','ADCOMP','JBTERM') AND s.spriden_change_ind IS NULL AND r.norrout_level_no = 90 AND b.nobtran_apply_ind = 'N' AND b.nobtran_trans_status_ind <> 'V' AND r.norrout_queue_status_ind <> 'A' AND pp.pebempl_ecls_code NOT IN ('RE','FW','GS','MW') ORDER BY 3

