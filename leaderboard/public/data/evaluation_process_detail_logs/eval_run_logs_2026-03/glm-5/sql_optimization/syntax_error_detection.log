## SQL:
SELECT a.acc_account_no, a.acc_subacc_no, h.acch_title, TO_CHAR(a.acc_incep_date, 'DD/MM/YYYY') acc_incep_date, t.ACCTAX_EFF_DATE_FROM, TO_CHAR(au.audh_date, 'DD-MON-YYYY') approved_date, ty.act_long_name, tr.tran_amount_cr, tr.tran_create_by, CASE WHEN (TRUNC(a.acc_incep_date) - TRUNC(au.audh_date)) < 0 THEN 0 ELSE (TRUNC(a.acc_incep_date) - TRUNC(au.audh_date)) END time_on_approved, h.acch_brn_code FROM (SELECT tran_account_no, tran_subacc_no, tran_amount_cr, tran_create_by, ROW_NUMBER() OVER (PARTITION BY tran_account_no, tran_subacc_no ORDER BY tran_date, tran_seqno) rn FROM transactions WHERE tran_amount_cr IS NOT NULL AND tran_trans_code IN ('RIC','RSAV') AND tran_date BETWEEN IN_FUND_FROM_DATE AND IN_FUND_TO_DATE AND tran_pay_method NOT IN ('C','CQ')) tr JOIN accounts a ON a.acc_account_no = tr.tran_account_no AND a.acc_subacc_no = tr.tran_subacc_no JOIN account_headers h ON h.acch_account_no = a.acc_account_no JOIN account_types ty ON ty.act_code = a.acc_act_code JOIN audit_header au ON au.audh_key1 = a.acc_account_no AND au.audh_key2 = a.acc_subacc_no AND au.audh_table_prefix = 'ACC' AND au.audh_change_type = 'I' JOIN audit_detail ad ON ad.audd_audh_seqno = au.audh_seqno AND ad.audd_col_sufix = 'PROCESS_STATUS' AND ad.audd_old_value IS NULL AND ad.audd_new_value = 1 JOIN account_links l ON l.accl_account_no = a.acc_account_no AND l.accl_subacc_no = a.acc_subacc_no AND l.accl_holder_pos = 1 JOIN SUMMIT.ACCOUNT_HOLDING_TAX t ON t.ACCTAX_ACCOUNT_NO = l.ACCL_ACCOUNT_NO AND t.ACCTAX_SUBACC_NO = l.ACCL_SUBACC_NO AND t.ACCTAX_CUST_SEQNO = l.ACCL_CUST_SEQNO WHERE a.acc_gact_type IN ('S', 'IC') AND a.acc_incep_date BETWEEN IN_INCEP_FROM_DATE AND IN_INCEP_TO_DATE AND tr.rn = 1

