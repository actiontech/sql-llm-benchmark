WITH me AS (SELECT departamento, subdepartamento, clase, subclase, proveedor, estilo, tipo_articulo FROM catalogos.maestro_estilos WHERE proveedor = 1162 AND estilo = 'C21031101'), rank_general AS (SELECT ta.TIENDA AS id, ROW_NUMBER() OVER (ORDER BY SUM(v.MERCANCIASINIVA) DESC) AS actual_rank_global FROM catalogos.tiendas ta LEFT JOIN flashdeventas.vetas_y_formas_de_pago v ON v.TIENDA = ta.TIENDA WHERE ta.tipo = 'S' AND ta.estatus = 'A' AND ta.marca = 30 GROUP BY ta.TIENDA), otr AS (SELECT id_tienda, id_departamento, id_subdepartamento, id_clase, id_subclase, tipo_articulo, SUM(CASE WHEN n >= MONTH(GETDATE()) THEN ISNULL(val, 0) ELSE 0 END) AS abierto_otr FROM otr.otr_consulta CROSS APPLY (VALUES (1, mes1_compra_adicional), (2, mes2_compra_adicional), (3, mes3_compra_adicional), (4, mes4_compra_adicional), (5, mes5_compra_adicional), (6, mes6_compra_adicional), (7, mes7_compra_adicional), (8, mes8_compra_adicional), (9, mes9_compra_adicional), (10, mes10_compra_adicional), (11, mes11_compra_adicional), (12, mes12_compra_adicional)) m(n, val) WHERE id_tienda = 3064 GROUP BY id_tienda, id_departamento, id_subdepartamento, id_clase, id_subclase, tipo_articulo) SELECT rg.actual_rank_global, t.nombre, vw_r.nombre AS regional, vw_s.nombre AS supervisor, t.estado, 'RUTA' AS ruta, t.m2 AS tienda_m2, 'TAMAÑO' AS tamanio, rj.ranking AS rank_jerarquia_n4, t.ciudad, cam.matrices_min AS propuesta, otr.abierto_otr, c.* FROM clusters.tienda_atributos c LEFT JOIN catalogos.tiendas t ON c.tienda = t.tienda LEFT JOIN catalogos.vw_supervisores vw_s ON c.tienda = vw_s.tienda LEFT JOIN catalogos.vw_regionales vw_r ON c.tienda = vw_r.tienda LEFT JOIN rank_general rg ON c.tienda = rg.id CROSS JOIN me LEFT JOIN catalogos.ranking_tda_jerarquia rj ON c.tienda = rj.id_tienda AND rj.departamento = me.departamento AND rj.subdepartamento = me.subdepartamento AND rj.clase = me.clase AND rj.subclase = me.subclase LEFT JOIN catalogos.control_asignacion_matrices cam ON rj.ranking = cam.clasificacion LEFT JOIN otr ON otr.id_tienda = c.tienda AND otr.id_departamento = me.departamento AND otr.id_subdepartamento = me.subdepartamento AND otr.id_clase = me.clase AND otr.id_subclase = me.subclase AND otr.tipo_articulo = me.tipo_articulo WHERE c.centro_comercial = 1 AND c.clima LIKE '%calor todo el tiempo%' AND c.tienda = 3064

