SELECT s.s_id, s.s_name, s.s_sex, sa.course_count, sa.avg_score, sa.excellent_course_count, RANK() OVER (PARTITION BY s.s_sex ORDER BY sa.avg_score DESC) AS gender_rank FROM Student s JOIN (SELECT sc.s_id, COUNT(DISTINCT sc.c_id) AS course_count, AVG(sc.s_score) AS avg_score, SUM(CASE WHEN sc.s_score > 90 THEN 1 ELSE 0 END) AS excellent_course_count FROM Score sc JOIN (SELECT s_id FROM Score WHERE s_score > 90 GROUP BY s_id HAVING COUNT(*) >= 2) q ON sc.s_id = q.s_id GROUP BY sc.s_id HAVING AVG(sc.s_score) > 80) sa ON s.s_id = sa.s_id ORDER BY sa.avg_score DESC

