## SQL:
WITH MaxIds AS (SELECT claim_folder_id, MAX(id) AS max_id FROM claim WHERE claim_folder_id IS NOT NULL GROUP BY claim_folder_id) SELECT c.id, c.sap_code, c.claim_folder_id, DATEDIFF(day, c.repair_date, GETDATE()) AS DATE_REPAIR_DIFF, c.claim_status_id AS status, c.is_e2e AS e2e FROM claim c LEFT JOIN serie ON serie.id = c.serie_id LEFT JOIN serie exchange_serie ON exchange_serie.id = c.exchange_serie_id LEFT JOIN MaxIds m ON m.claim_folder_id = c.claim_folder_id WHERE (((serie.sap_code = @P0 OR serie.sap_code = CONCAT('4000', @P1)) AND c.serial_number = @P2 AND c.production_code = @P3) OR ((exchange_serie.sap_code = @P4 OR exchange_serie.sap_code = CONCAT('4000', @P5)) AND c.exchange_serial_number = @P6 AND c.exchange_production_code = @P7)) AND (c.serial_number NOT IN (@P8) AND c.production_code NOT IN (@P9, @P10, @P11)) AND (c.claim_folder_id IS NULL OR c.id = m.max_id) ORDER BY c.id DESC

