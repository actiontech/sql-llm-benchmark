## SQL:
SELECT u.user_id,u.username,COUNT(DISTINCT o.order_id) AS total_orders,SUM(oi.quantity*oi.unit_price*(1-oi.discount/100)) AS total_spent,AVG(oi.quantity*oi.unit_price*(1-oi.discount/100)) AS avg_order_value,MAX(o.order_date) AS last_order_date,tp.top_products FROM users u INNER JOIN orders o ON u.user_id=o.user_id AND o.order_date>=DATE_SUB(CURRENT_DATE(),INTERVAL 3 YEAR) LEFT JOIN order_items oi ON o.order_id=oi.order_id LEFT JOIN (SELECT user_id,GROUP_CONCAT(product_name ORDER BY product_revenue DESC SEPARATOR ', ') AS top_products FROM (SELECT o.user_id,p.product_name,SUM(oi.quantity*oi.unit_price*(1-oi.discount/100)) AS product_revenue,ROW_NUMBER() OVER (PARTITION BY o.user_id ORDER BY SUM(oi.quantity*oi.unit_price*(1-oi.discount/100)) DESC) AS rn FROM orders o INNER JOIN order_items oi ON o.order_id=oi.order_id INNER JOIN products p ON oi.product_id=p.product_id WHERE o.order_date>=DATE_SUB(CURRENT_DATE(),INTERVAL 3 YEAR) GROUP BY o.user_id,p.product_id,p.product_name) t WHERE rn<=3 GROUP BY user_id) tp ON tp.user_id=u.user_id WHERE u.status='active' GROUP BY u.user_id,u.username ORDER BY total_spent DESC;

