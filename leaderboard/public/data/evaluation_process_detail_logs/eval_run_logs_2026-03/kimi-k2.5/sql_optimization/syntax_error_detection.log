## SQL:
with tmep_ip as (select a.register_no as patientid, a.inpatient_name as patientname, a.age, a.sex as gender, date(a.in_date) as indate, date(a.out_date) as outdate, a.times as inhospitaltimes, a.person_type as persontype, a.patient_no as serialno, b.total_cost as medicalcost, 'doctor' as entrymode, 'remind' as defaulttab, a.current_dept_code as deptcode, '440100' as citycode from his_temp_ip_patient_info a left join his_temp_ip_settle b on a.register_no = b.register_no and a.times = b.times where a.out_date >= '2025-01-02'::timestamp), diagnosis as (select inp_no, visit_id as times, type, diagnosis_type_name, diagnosis_flag, case when diagnosis_flag = '1' then string_agg(diagnosis_code, ',' order by diagnosis_no) end as diagnosis_codes, case when diagnosis_flag = '0' then string_agg(diagnosis_code, ',' order by diagnosis_no) end as chinese_diagnosis_codes, case when diagnosis_flag = '0' then string_agg(diagnosis_name, ',' order by diagnosis_no) end as chinese_diagnosis_names from emr_temp_ip_patient_diagnosis where file_visit_type = '2' group by inp_no, visit_id, type, diagnosis_type_name, diagnosis_flag), diagnosis_ranked as (select *, row_number() over (partition by inp_no, times, type order by case when type = '病历诊断' and diagnosis_type_name = '最后诊断' then 1 when type = '病历诊断' and diagnosis_type_name = '初步诊断' then 2 when type = '首页诊断' and diagnosis_type_name = '出院诊断' then 1 when type = '首页诊断' and diagnosis_type_name = '门诊诊断' then 2 else 3 end) as rn from diagnosis), diagnosis_end as (select inp_no, times, type, diagnosis_type_name, max(case when diagnosis_flag = '1' then diagnosis_codes end) as diagnosis_codes, max(case when diagnosis_flag = '0' then chinese_diagnosis_codes end) as chinese_diagnosis_codes, max(case when diagnosis_flag = '0' then chinese_diagnosis_names end) as chinese_diagnosis_names from diagnosis_ranked where rn = 1 group by inp_no, times, type, diagnosis_type_name), operations as (select inp_no, visit_id as times, string_agg(operation_code, ',' order by operation_no) as operation_codes from emr_temp_ip_patient_operation group by inp_no, visit_id) select t.patientid, t.patientname, t.age, t.gender, t.indate, t.outdate, t.inhospitaltimes, d.type, d.diagnosis_codes as diagnosiscode, o.operation_codes as operationcode, t.medicalcost, t.persontype, t.entrymode, t.serialno, t.defaulttab, d.chinese_diagnosis_codes as chinesediagnosiscode, d.chinese_diagnosis_names as chinesediagnosename, t.deptcode, t.citycode from tmep_ip t left join diagnosis_end d on t.patientid = d.inp_no and t.inhospitaltimes = d.times left join operations o on t.patientid = o.inp_no and t.inhospitaltimes = o.times order by t.outdate desc

