SELECT DISTINCT a.acc_account_no, a.acc_subacc_no, h.acch_title, TO_CHAR(a.acc_incep_date,'DD/MM/YYYY') acc_incep_date, t.ACCTAX_EFF_DATE_FROM, TO_CHAR(oh.audh_date, 'DD-MON-YYYY') approved_date, at.act_long_name, tr.tran_amount_cr, tr.tran_create_by, CASE WHEN (TRUNC(a.acc_incep_date) - TRUNC(oh.audh_date)) < 0 THEN 0 ELSE (TRUNC(a.acc_incep_date) - TRUNC(oh.audh_date)) END time_on_approved, h.acch_brn_code FROM accounts a JOIN account_headers h ON h.acch_account_no = a.acc_account_no JOIN account_types at ON at.act_code = a.acc_act_code JOIN (SELECT tran_account_no, tran_subacc_no, MIN(tran_seqno) first_tran_seq, MIN(tran_date) first_tran_date FROM transactions WHERE tran_amount_cr IS NOT NULL AND tran_trans_code IN ('RIC','RSAV') AND tran_date BETWEEN IN_FUND_FROM_DATE AND IN_FUND_TO_DATE AND tran_pay_method NOT IN ('C','CQ') GROUP BY tran_account_no, tran_subacc_no) ft ON ft.tran_account_no = a.acc_account_no AND ft.tran_subacc_no = a.acc_subacc_no JOIN transactions tr ON tr.tran_seqno = ft.first_tran_seq JOIN (SELECT ah.audh_key1, ah.audh_key2, ah.audh_date, ad.audd_old_value, ad.audd_new_value FROM audit_header ah JOIN audit_detail ad ON ad.audd_audh_seqno = ah.audh_seqno WHERE ah.audh_table_prefix = 'ACC' AND ah.audh_change_type = 'I' AND ad.audd_col_sufix = 'PROCESS_STATUS' AND ad.audd_old_value IS NULL AND ad.audd_new_value = '1') oh ON oh.audh_key1 = a.acc_account_no AND oh.audh_key2 = a.acc_subacc_no JOIN ACCOUNT_LINKS al ON al.accl_account_no = a.acc_account_no AND al.accl_subacc_no = a.acc_subacc_no AND al.accl_holder_pos = 1 JOIN SUMMIT.ACCOUNT_HOLDING_TAX t ON t.ACCTAX_ACCOUNT_NO = al.ACCL_ACCOUNT_NO AND t.ACCTAX_SUBACC_NO = al.ACCL_SUBACC_NO AND t.ACCTAX_CUST_SEQNO = al.ACCL_CUST_SEQNO WHERE a.acc_gact_type IN ('S', 'IC') AND a.acc_incep_date BETWEEN IN_INCEP_FROM_DATE AND IN_INCEP_TO_DATE

