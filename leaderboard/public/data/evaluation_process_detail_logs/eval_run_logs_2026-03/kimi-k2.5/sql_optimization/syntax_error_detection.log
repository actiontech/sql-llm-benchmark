TY.ENT_ENTITY EE JOIN (SELECT DISTINCT STATION_CODE FROM RES_ENTITY.STA_BIZ_INFO SBI JOIN (SELECT REGION_ID FROM RES_ENTITY.REG_MANAGE WHERE DELETE_STATE='0' CONNECT BY PRIOR REGION_ID=SUPER_REGION_ID START WITH REGION_ID IN ('000102000000000000370100')) REG ON SBI.REGION_ID=REG.REGION_ID) STATIONS ON EE.STATION_CODE=STATIONS.STATION_CODE LEFT JOIN RES_ENTITY.ENT_ROOM B ON B.ENTITY_ID=EE.ENTITY_ID LEFT JOIN RES_ENTITY.STA_STATION ST ON ST.STATION_CODE=EE.STATION_CODE LEFT JOIN RES_ENTITY.STA_APP_INFO D ON ST.STATION_ID=D.STATION_ID LEFT JOIN RES_SYS.PUB_MFR PM1 ON PM1.MFR_ID=B.INTEG_CABINET_AC_MFR_ID AND PM1.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_EQP_TYPE PDET1 ON PDET1.EQP_TYPE_ID=B.MANUAL_IDENT_RESULT_ID AND PDET1.DELETE_STATE='0' LEFT JOIN RES_ENTITY.ENT_ENTITY ROOM ON ROOM.ENTITY_ID=EE.ROOM_ID AND ROOM.RES_TYPE_ID='205' AND ROOM.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_RES_TYPE PRT ON PRT.RES_TYPE_ID=EE.RES_TYPE_ID AND PRT.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_EQP_TYPE PDET2 ON PDET2.EQP_TYPE_ID=EE.DEV_TYPE_ID AND PDET2.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_RME_EQP_MODEL PRM1 ON PRM1.EQP_MODEL_ID=EE.DEV_MODEL_ID AND PRM1.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_RME_EQP_MODEL PRM2 ON PRM2.EQP_MODEL_ID=EE.OLD_DEV_MODEL_ID AND PRM2.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR PM2 ON PM2.MFR_ID=EE.MFR_ID AND PM2.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR PM3 ON PM3.MFR_ID=EE.DW_MFR_ID AND PM3.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR PM4 ON PM4.MFR_ID=EE.OLD_DW_MFR_ID AND PM4.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR PM5 ON PM5.MFR_ID=EE.MNT_MFR_ID AND PM5.DELETE_STATE='0' LEFT JOIN RES_ENTITY.REG_MANAGE RM ON RM.REGION_ID=D.APP_REGION_ID AND RM.DELETE_STATE='0' WHERE EE.DELETE_STATE='0' AND EE.RES_TYPE_ID=205) t WHERE ROWNUM<=10) WHERE rn>0

