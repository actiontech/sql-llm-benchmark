CREATE PROCEDURE usp_UpdateOrderStatus(
    IN p_CustomerID INT, 
    IN p_OldStatus VARCHAR(20), 
    IN p_NewStatus VARCHAR(20), 
    OUT p_RowsUpdated INT, 
    OUT p_ErrorMessage VARCHAR(200)
)
AS $$
DECLARE
    v_OrderCount INT;
    v_TranCount INT := txid_current();
    v_ProcessingFee DECIMAL(10,2);
    v_OrderID_INT;
    fee_cursor CURSOR FOR SELECT Fee FROM OrderDetails WHERE OrderID IN (SELECT OrderID FROM Orders WHERE CustomerID = p_CustomerID AND Status = p_NewStatus);
BEGIN
    IF p_OldStatus = p_NewStatus THEN
        p_ErrorMessage := 'ж–°ж—§зҠ¶жҖҒдёҚиғҪзӣёеҗҢ';
        RETURN 400;
    END IF;
    
    BEGIN
        IF v_TranCount = 0 THEN
            START TRANSACTION;
        END IF;
        
        UPDATE Orders 
        SET Status = p_NewStatus, 
            LastUpdated = CURRENT_TIMESTAMP 
        WHERE CustomerID = p_CustomerID 
          AND Status = p_OldStatus 
          AND OrderDate > CURRENT_TIMESTAMP - INTERVAL '3 months';
        
        GET DIAGNOSTICS p_RowsUpdated = ROW_COUNT;
        
        IF p_RowsUpdated = 0 THEN
            p_ErrorMessage := 'жңӘжүҫеҲ°з¬ҰеҗҲжқЎд»¶зҡ„и®ўеҚ•';
            RETURN 404;
        END IF;
        
        INSERT INTO OrderLog (OrderID, OldStatus, NewStatus, ChangeDate)
        SELECT OrderID, p_OldStatus, p_NewStatus, CURRENT_TIMESTAMP
        FROM Orders 
        WHERE CustomerID = p_CustomerID 
          AND Status = p_NewStatus;
        
        OPEN fee_cursor;
        FETCH fee_cursor INTO v_ProcessingFee;
        WHILE FOUND LOOP
            v_ProcessingFee := v_ProcessingFee * 0.95;
            FETCH fee_cursor INTO v_ProcessingFee;
        END LOOP;
        CLOSE fee_cursor;
        
        IF v_TranCount = 0 THEN
            COMMIT;
        END IF;
        
        p_ErrorMessage := 'жӣҙж–°жҲҗеҠҹ';
        RETURN 200;
    EXCEPTION
        WHEN OTHERS THEN
            IF v_TranCount = 0 AND txid_current() != v_TranCount THEN
                ROLLBACK;
            END IF;
            p_ErrorMessage := SQLERRM || ' (Line:' || SQLCODE || ')';
            RETURN 500;
    END;
END;
$$ LANGUAGE plpgsql;
