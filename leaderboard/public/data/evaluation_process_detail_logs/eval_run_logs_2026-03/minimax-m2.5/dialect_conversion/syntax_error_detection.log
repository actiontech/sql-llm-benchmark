concatеҮҪж•°иҝ”еӣһеҖјзұ»еһӢдёәеҸҳй•ҝзұ»еһӢпјҢе’ҢиЎЁдёӯж•°жҚ®жҜ”иҫғж—¶пјҢдјҡеӣ дёәжӢјжҺҘз»“жһңдёўеӨұеӯ—з¬ҰдёІй•ҝеәҰпјҢеҜјиҮҙжҜ”иҫғз»“жһңдёҚзӣёзӯүгҖӮ
иҝ”еӣһеҖјзұ»еһӢпјҡtext
зӨәдҫӢпјҡ
gaussdb=# SELECT concat('Hello', ' World!');
concat
Hello World!
(1 row)
gaussdb=# SELECT concat('Hello', NULL);
concat
Hello
(1 row)
gaussdb=# CREATE TABLE test_space(c char(10));
CREATE TABLE
gaussdb=# CREATE TABLE test_space VALUES('a');
INSERT 0 1
-- еЎ«е……з©әж јеҗҺд»Қз„¶жҳҜе®ҡй•ҝеӯ—з¬ҰдёІпјҢйў„жңҹеҸҜд»ҘжҹҘжүҫеҲ°з»“жһң
gaussdb=# SELECT * FROM test_space WHERE c = 'a ';
c
a 
(1 row)
-- жӢјжҺҘз»“жһңдёәеҸҳй•ҝеӯ—з¬ҰдёІпјҢжҜ”еҜ№еӨұиҙҘпјҢжүҫдёҚеҲ°з»“жһң
gaussdb=# SELECT * FROM test_space WHERE c = 'a' || ' ';
c
(0 rows)

**BEGIN**:
иҜӯжі•: `BEGIN [ WORK | TRANSACTION ] [ { ISOLATION LEVEL { READ COMMITTED | SERIALIZABLE | REPEATABLE READ } | { READ WRITE | READ ONLY } } [...] ];`
еҠҹиғҪжҸҸиҝ°: йҖҡиҝҮBEGINеҗҜеҠЁдәӢеҠЎгҖӮеҰӮжһңеЈ°жҳҺдәҶйҡ”зҰ»зә§еҲ«гҖҒиҜ»еҶҷжЁЎејҸпјҢйӮЈд№Ҳж–°дәӢеҠЎе°ұдҪҝз”Ёиҝҷдәӣзү№жҖ§пјҢзұ»дјјжү§иЎҢдәҶSET TRANSACTIONгҖӮ
еҸӮж•°иҜҙжҳҺ:
WORK | TRANSACTION: BEGINж јејҸдёӯзҡ„еҸҜйҖүе…ій”®еӯ—пјҢжІЎжңүе®һйҷ…дҪңз”ЁгҖӮ
ISOLATION LEVEL: жҢҮе®ҡдәӢеҠЎйҡ”зҰ»зә§еҲ«пјҢе®ғеҶіе®ҡеҪ“дёҖдёӘдәӢеҠЎдёӯеӯҳеңЁе…¶д»–е№¶еҸ‘иҝҗиЎҢдәӢеҠЎж—¶е®ғиғҪеӨҹзңӢеҲ°д»Җд№Ҳж•°жҚ®гҖӮ
  иҜҙжҳҺ: еңЁдәӢеҠЎдёӯз¬¬дёҖдёӘж•°жҚ®дҝ®ж”№иҜӯеҸҘпјҲSELECT, INSERTпјҢDELETEпјҢUPDATEпјҢFETCHпјҢCOPYпјүжү§иЎҢд№ӢеҗҺпјҢдәӢеҠЎйҡ”зҰ»зә§еҲ«е°ұдёҚиғҪеҶҚж¬Ўи®ҫзҪ®гҖӮ
  еҸ–еҖјиҢғеӣҙпјҡ
  READ COMMITTEDпјҡиҜ»е·ІжҸҗдәӨйҡ”зҰ»зә§еҲ«пјҢеҸӘиғҪиҜ»еҲ°е·Із»ҸжҸҗдәӨзҡ„ж•°жҚ®пјҢиҖҢдёҚдјҡиҜ»еҲ°жңӘжҸҗдәӨзҡ„ж•°жҚ®гҖӮиҝҷжҳҜзјәзңҒеҖјгҖӮ
  REPEATABLE READпјҡ еҸҜйҮҚеӨҚиҜ»йҡ”зҰ»зә§еҲ«пјҢд»…д»…зңӢеҲ°дәӢеҠЎејҖе§Ӣд№ӢеүҚжҸҗдәӨзҡ„ж•°жҚ®пјҢе®ғдёҚиғҪзңӢеҲ°жңӘжҸҗдәӨзҡ„ж•°жҚ®пјҢд»ҘеҸҠеңЁдәӢеҠЎжү§иЎҢжңҹй—ҙз”ұе…¶е®ғе№¶еҸ‘дәӢеҠЎжҸҗдәӨзҡ„дҝ®ж”№гҖӮ
  SERIALIZABLEпјҡGaussDBзӣ®еүҚеҠҹиғҪдёҠдёҚж”ҜжҢҒжӯӨйҡ”зҰ»зә§еҲ«пјҢзӯүд»·дәҺ REPEATABLE READгҖӮ
READ WRITE | READ ONLY: жҢҮе®ҡдәӢеҠЎи®ҝй—®жЁЎејҸпјҲиҜ»/еҶҷжҲ–иҖ…еҸӘиҜ»пјүгҖӮ
зӨәдҫӢ: `BEGIN;`

**BEGIN**:
еҠҹиғҪжҸҸиҝ°: BEGINеҸҜд»Ҙз”ЁдәҺејҖе§ӢдёҖдёӘеҢҝеҗҚеқ—пјҢд№ҹеҸҜд»Ҙз”ЁдәҺејҖе§ӢдёҖдёӘдәӢеҠЎгҖӮжң¬иҠӮжҸҸиҝ°з”ЁBEGINејҖе§ӢеҢҝеҗҚеқ—зҡ„иҜӯжі•пјҢд»ҘBEGINејҖе§ӢдәӢеҠЎзҡ„иҜӯжі•и§ҒSTART TRANSACTIONгҖӮеҢҝеҗҚеқ—жҳҜиғҪеӨҹеҠЁжҖҒең°еҲӣе»әе’Ңжү§иЎҢиҝҮзЁӢд»Јз Ғзҡ„з»“жһ„пјҢиҖҢдёҚйңҖиҰҒд»ҘжҢҒд№…еҢ–зҡ„ж–№ејҸе°Ҷд»Јз ҒдҪңдёәж•°жҚ®еә“еҜ№иұЎеӮЁеӯҳеңЁж•°жҚ®еә“дёӯгҖӮ
жіЁж„ҸдәӢйЎ№: ж— гҖӮ
иҜӯжі•пјҡ
ејҖеҗҜеҢҝеҗҚеқ—гҖӮ
[DECLARE [declare_statements]] BEGIN
execution_statements
END;
/
ејҖеҗҜдәӢеҠЎгҖӮ
BEGIN [ WORK | TRANSACTION ]
[ { ISOLATION LEVEL { READ COMMITTED | SERIALIZABLE | REPEATABLE READ } | { READ WRITE | READ ONLY } } [, ...]
];
еҸӮж•°иҜҙжҳҺ:
declare_statements: еЈ°жҳҺеҸҳйҮҸпјҢеҢ…жӢ¬еҸҳйҮҸеҗҚе’ҢеҸҳйҮҸзұ»еһӢпјҢеҰӮвҖңsales_cnt intвҖқгҖӮ
execution_statements: еҢҝеҗҚеқ—дёӯиҰҒжү§иЎҢзҡ„иҜӯеҸҘгҖӮеҸ–еҖјиҢғеӣҙпјҡDMLж“ҚдҪң(ж•°жҚ®ж“Қзәөж“ҚдҪңпјҡselectгҖҒinsertгҖҒdeleteгҖҒupdate)жҲ–зі»з»ҹиЎЁдёӯе·ІжіЁеҶҢзҡ„еҮҪж•°еҗҚз§°гҖӮ
зӨәдҫӢ: --дҪҝз”ЁеҢҝеҗҚеқ—иҫ“еҮәеӯ—з¬ҰдёІгҖӮ
BEGIN
dbe_output.print_line('Hello');END;
/

**з§»йҷӨ SET NOCOUNT ON**:
GaussDB дёҚж”ҜжҢҒ SET NOCOUNT иҜӯжі•, е®ғз”ЁдәҺзҰҒжӯў T-SQL иҫ“еҮәеҸ—еҪұе“ҚиЎҢж•°дҝЎжҒҜ, еңЁ GaussDB еӯҳеӮЁиҝҮзЁӢжҲ–еҮҪж•°дёӯй»ҳи®ӨдёҚдјҡиҫ“еҮәиЎҢи®Ўж•°жҸҗзӨә, еӣ жӯӨеҸҜд»ҘеҲ йҷӨиҜҘиҜӯеҸҘгҖӮ

**NUMERIC**:
жҸҸиҝ°: зІҫеәҰpеҸ–еҖјиҢғеӣҙдёә [1,1000]пјҢж ҮеәҰsеҸ–еҖјиҢғеӣҙдёә[0,p]гҖӮиҜҙжҳҺ pдёәжҖ»дҪҚж•°пјҢsдёәе°Ҹж•°дҪҚж•°гҖӮ
еӯҳеӮЁз©әй—ҙ: з”ЁжҲ·еЈ°жҳҺзІҫеәҰгҖӮжҜҸеӣӣдҪҚпјҲеҚҒиҝӣеҲ¶дҪҚпјүеҚ з”ЁдёӨдёӘеӯ—иҠӮпјҢз„¶еҗҺеңЁж•ҙдёӘж•°жҚ®дёҠеҠ дёҠе…«дёӘеӯ—иҠӮзҡ„йўқеӨ–ејҖй”ҖгҖӮ
иҢғеӣҙ: жңӘжҢҮе®ҡзІҫеәҰзҡ„жғ…еҶөдёӢпјҢе°Ҹж•°зӮ№еүҚжңҖеӨ§131,072дҪҚпјҢе°Ҹж•°зӮ№еҗҺжңҖеӨ§16,383дҪҚгҖӮ
иҜҙжҳҺ: дёҺж•ҙж•°зұ»еһӢзӣёжҜ”пјҢд»»ж„ҸзІҫеәҰзұ»еһӢйңҖиҰҒжӣҙеӨ§зҡ„еӯҳеӮЁз©әй—ҙпјҢе…¶еӯҳеӮЁж•ҲзҺҮгҖҒиҝҗз®—ж•ҲзҺҮд»ҘеҸҠеҺӢзј©жҜ”ж•ҲжһңйғҪиҰҒе·®дёҖдәӣгҖӮеңЁиҝӣиЎҢж•°еҖјзұ»еһӢе®ҡд№үж—¶пјҢдјҳе…ҲйҖүжӢ©ж•ҙж•°зұ»еһӢгҖӮеҪ“ж•°еҖји¶…еҮәж•ҙж•°еҸҜиЎЁзӨәжңҖеӨ§иҢғеӣҙж—¶пјҢеҶҚйҖүз”Ёд»»ж„ҸзІҫеәҰзұ»еһӢгҖӮдҪҝз”ЁNUMERIC/DECIMALиҝӣиЎҢеҲ—е®ҡд№үж—¶пјҢе»әи®®жҢҮе®ҡиҜҘеҲ—зҡ„зІҫеәҰpд»ҘеҸҠж ҮеәҰsгҖӮ

**numeric**:
жҸҸиҝ°пјҡе°Ҷдј е…ҘеҸӮж•°иҪ¬жҚўдёәnumericзұ»еһӢеҖје№¶иҝ”еӣһгҖӮж”ҜжҢҒзҡ„е…ҘеҸӮзұ»еһӢеҢ…жӢ¬пјҡbigintгҖҒbooleanгҖҒdouble precisionгҖҒint16гҖҒintegerгҖҒmoneyгҖҒrealгҖҒsmallintгҖӮ
иҝ”еӣһеҖјзұ»еһӢпјҡnumeric
зӨәдҫӢпјҡ
gaussdb=# SELECT "numeric"('789'); numeric  
789 (1 row) 
gaussdb=# SELECT "numeric"(99.9); numeric  
99.9 (1 row)

**иҪ¬жҚў TRY...CATCH ејӮеёёеӨ„зҗҶеқ—**:
SQLServer зҡ„ BEGIN TRY ... END TRY / BEGIN CATCH ... END CATCH еҸҜд»ҘиҪ¬жҚўдёә GaussDB PL/pgSQL зҡ„ BEGIN ... EXCEPTION WHEN OTHERS THEN ... END; ејӮеёёеӨ„зҗҶеқ—гҖӮ

**RAISERROR иҪ¬жҚў**:
е°Ҷ SQLServer зҡ„ RAISERROR еҮҪж•°иҪ¬жҚўдёә GaussDB зҡ„ RAISE EXCEPTIONгҖӮ

**й”ҷиҜҜдҝЎжҒҜеҮҪж•°иҪ¬жҚў**:
е°ҶSQL Serverзҡ„ERROR_MESSAGE()е’ҢERROR_LINE()иҪ¬жҚўдёәGaussDB PL/pgSQLзҡ„GET STACKED DIAGNOSTICS MESSAGE_TEXTе’ҢPG_EXCEPTION_CONTEXTпјҢд»ҘиҺ·еҸ–й”ҷиҜҜжҸҸиҝ°е’ҢдёҠдёӢж–ҮгҖӮ

**жёёж ҮеҲ°еҫӘзҺҜиҜӯжі•иҪ¬жҚў**:
T-SQL:
DECLARE c_names CURSOR FOR SELECT name FROM syscolumns ...;
OPEN c_names;
FETCH NEXT FROM c_names INTO @colname;
WHILE @@FETCH_STATUS=0
BEGIN
  ...
  FETCH NEXT FROM c_names INTO @colname;
END
CLOSE c_names;
DEALLOCATE c_names;

GaussDB:
FOR col_rec IN
  SELECT column_name FROM information_schema.columns
  WHERE table_name='t_pj_bond_info_all' AND column_name LIKE 'def%'
LOOP
  colname := col_rec.column_name;
  -- еҫӘзҺҜдҪ“йҖ»иҫ‘
END LOOP;

жіЁж„Ҹ: PL/pgSQL ж”ҜжҢҒ FOR ... IN ... LOOP дёҖж¬ЎжҖ§йҒҚеҺҶз»“жһңйӣҶпјҢж— йңҖжҳҫејҸ OPEN/FETCH/CLOSE/DEALLOCATEпјҢеҸҜз”Ё EXIT WHEN жҺ§еҲ¶йҖҖеҮәгҖӮ

**жёёж Үе’ҢеҫӘзҺҜжҺ§еҲ¶иҜӯжі•иҪ¬жҚў**:
SQLServer дёӯдҪҝз”Ё DECLARE c_names CURSOR FOR ...; OPEN c_names; WHILE 1=1 BEGIN FETCH NEXT FROM c_names INTO @colname; IF @@FETCH_STATUS<>0 BREAK; ... END; CLOSE c_names; DEALLOCATE c_names; GaussDB PL/pgSQL дёӯйңҖеңЁеҮҪж•°дҪ“дҪҝз”Ё DECLARE c_names CURSOR FOR SELECT ...; OPEN c_names; LOOP FETCH c_names INTO colname; EXIT WHEN NOT FOUND; ... END LOOP; CLOSE c_names; е№¶з§»йҷӨ DEALLOCATEпјҢPL/pgSQL иҮӘеҠЁйҮҠж”ҫгҖӮ

**жёёж ҮиҜӯжі•иҪ¬жҚў**:
е°Ҷ T-SQL зҡ„
CURSOR еЈ°жҳҺгҖҒOPENгҖҒFETCH NEXTвҖҰINTOгҖҒ@@FETCH_STATUSгҖҒCLOSEгҖҒDEALLOCATE
иҪ¬жҚўдёә PL/pgSQL зҡ„ CURSOR + LOOP з»“жһ„пјҢдҫӢеҰӮпјҡ
DECLARE fee_cursor CURSOR FOR SELECT ...;
OPEN fee_cursor;
LOOP
  FETCH fee_cursor INTO processing_fee;
  EXIT WHEN NOT FOUND;
  -- еӨ„зҗҶйҖ»иҫ‘
END LOOP;
CLOSE fee_cursor;

**жёёж ҮеҫӘзҺҜиҪ¬жҚў**:
SQLServer дёӯйҖҡиҝҮ DECLARE CURSORгҖҒOPENгҖҒFETCH NEXTгҖҒWHILE @@FETCH_STATUS еҫӘзҺҜжёёж ҮпјӣGaussDB PL/pgSQL жҺЁиҚҗдҪҝз”Ё FOR rec IN SELECT ... LOOP ... END LOOP зҡ„ж–№ејҸйҒҚеҺҶз»“жһңйӣҶпјҢзңҒеҺ»жёёж Үз®ЎзҗҶгҖӮ

**@@ROWCOUNT иҪ¬жҚў**:
SQL Serverзҡ„@@ROWCOUNTиҺ·еҸ–дёҠдёҖжқЎDMLеҪұе“ҚиЎҢж•°пјҢGaussDB PL/pgSQLдёӯдҪҝз”ЁGET DIAGNOSTICSпјҡ
-- SQL Server: SET @RowsUpdated = @@ROWCOUNT;
-- GaussDB: GET DIAGNOSTICS RowsUpdated = ROW_COUNT;

**CREATE PROCEDURE**:
еҠҹиғҪжҸҸиҝ°: еҲӣе»әдёҖдёӘж–°зҡ„еӯҳеӮЁиҝҮзЁӢгҖӮ
жіЁж„ҸдәӢйЎ№: 
еҰӮжһңеҲӣе»әеӯҳеӮЁиҝҮзЁӢж—¶еҸӮж•°жҲ–иҝ”еӣһеҖјеёҰжңүзІҫеәҰпјҢдёҚиҝӣиЎҢзІҫеәҰжЈҖжөӢгҖӮ
еҲӣе»әеӯҳеӮЁиҝҮзЁӢж—¶пјҢеӯҳеӮЁиҝҮзЁӢе®ҡд№үдёӯеҜ№иЎЁеҜ№иұЎзҡ„ж“ҚдҪңе»әи®®йғҪжҳҫзӨәжҢҮе®ҡжЁЎејҸгҖӮ
еңЁеҲӣе»әеӯҳеӮЁиҝҮзЁӢж—¶пјҢеӯҳеӮЁиҝҮзЁӢеҶ…йғЁйҖҡиҝҮSETиҜӯеҸҘи®ҫзҪ®current_schemaе’Ңsearch_pathж— ж•ҲгҖӮ
еӯҳеӮЁиҝҮзЁӢжҢҮе®ҡpackageеұһжҖ§ж—¶ж”ҜжҢҒйҮҚиҪҪгҖӮдёҚиғҪеҲӣе»әд»…еҪўеҸӮеҗҚеӯ—дёҚеҗҢпјҲеӯҳеӮЁиҝҮзЁӢеҗҚе’ҢеҸӮж•°еҲ—иЎЁзұ»еһӢйғҪдёҖж ·пјүзҡ„йҮҚиҪҪеӯҳеӮЁиҝҮзЁӢгҖӮ
йҮҚиҪҪзҡ„еӯҳеӮЁиҝҮзЁӢеңЁи°ғз”Ёж—¶еҸҳйҮҸйңҖиҰҒжҳҺзЎ®е…·дҪ“зҡ„зұ»еһӢгҖӮдёҚиғҪеҲӣе»әдёҺеҮҪж•°жӢҘжңүзӣёеҗҢеҗҚз§°е’ҢеҸӮж•°еҲ—иЎЁзҡ„еӯҳеӮЁиҝҮзЁӢгҖӮ
дёҚж”ҜжҢҒд»…й»ҳи®ӨеҖјдёҚеҗҢзҡ„еӯҳеӮЁиҝҮзЁӢйҮҚиҪҪгҖӮ
еӯҳеӮЁиҝҮзЁӢд»…INгҖҒOUTгҖҒINOUTиҝҷдёүз§Қзұ»еһӢдёҚеҗҢзҡ„еҸӮж•°пјҢжү“ејҖGUCеҸӮж•°behavior_compat_optionsпјҲproc_outparam_override'пјүеҗҺпјҢдёҚе…Ғи®ёйҮҚиҪҪгҖӮ
еңЁеӯҳеӮЁиҝҮзЁӢеҶ…йғЁдҪҝз”ЁжңӘеЈ°жҳҺзҡ„еҸҳйҮҸпјҢеӯҳеӮЁиҝҮзЁӢиў«и°ғз”Ёж—¶дјҡжҠҘй”ҷгҖӮ
еңЁеӯҳеӮЁиҝҮзЁӢеҶ…йғЁи°ғз”Ёе…¶е®ғж— еҸӮж•°зҡ„еӯҳеӮЁиҝҮзЁӢж—¶пјҢеҸҜд»ҘзңҒз•ҘжӢ¬еҸ·гҖӮ
еӯҳеӮЁиҝҮзЁӢй»ҳи®ӨдёәSECURITY INVOKERжқғйҷҗгҖӮ
иў«жҺҲдәҲCREATE ANY FUNCTIONжқғйҷҗзҡ„з”ЁжҲ·пјҢеҸҜд»ҘеңЁз”ЁжҲ·жЁЎејҸдёӢеҲӣе»ә/жӣҝжҚўеӯҳеӮЁиҝҮзЁӢгҖӮ
out/inoutеҸӮж•°еҝ…йЎ»дј е…ҘеҸҳйҮҸпјҢдёҚиғҪеӨҹдј е…ҘеёёйҮҸгҖӮ
еӯҳеӮЁиҝҮзЁӢеҲӣе»әж—¶дҫқиө–жңӘе®ҡд№үеҜ№иұЎиЎҢдёәеҸ—behavior_compat_options='plpgsql_dependency'еҸӮж•°еҪұе“ҚгҖӮ
еҪ“жү“ејҖдёүжқғеҲҶз«Ӣж—¶пјҢеҜ№дәҺе®ҡд№үиҖ…жқғйҷҗзҡ„еӯҳеӮЁиҝҮзЁӢпјҢеҸӘиғҪз”ұжң¬з”ЁжҲ·иҮӘе·ұйҮҚе»әгҖӮ
и°ғз”ЁеёҰoutеҮәеҸӮзҡ„еӯҳеӮЁиҝҮзЁӢпјҢи®ҫзҪ®GUCеҸӮж•°set behavior_compat_options 'proc_outparam_transfer_length'еҗҺеҸҜд»Ҙдј йҖ’еҸӮж•°й•ҝеәҰгҖӮ
дёҚе»әи®®з”ЁжҲ·еңЁеӯҳеӮЁиҝҮзЁӢдҪ“дёӯиҝӣиЎҢж¶үеҸҠеҜҶз ҒжҲ–еҜҶй’Ҙзӯүж•Ҹж„ҹдҝЎжҒҜзҡ„зӣёе…іж“ҚдҪңгҖӮ
иҜӯжі•: CREATE [ OR REPLACE ] PROCEDURE procedure_name [ ( {[ argname ] [ argmode ] argtype [ { DEFAULT $| : = | = }$ expression ]}[,...]) ] { IMMUTABLE | STABLE | VOLATILE } | { SHIPPABLE | NOT SHIPPABLE } | {PACKAGE} | [ NOT ] LEAKPROOF | { CALLED ON NULL INPUT | RETURNS NULL ON NULL INPUT | STRICT } | {[ EXTERNAL ] SECURITY INVOKER | [ EXTERNAL ] SECURITY DEFINER | AUTHID DEFINER | AUTHID CURRENT_USER} | COST execution_cost | SET configuration_parameter ${ \ [ \ \mathsf { TO } \ | = ]$ value | FROM CURRENT } ][ ... ] { IS | AS } plsql_body;
еҸӮж•°иҜҙжҳҺ: 
OR REPLACE: еҪ“еӯҳеңЁеҗҢеҗҚзҡ„еӯҳеӮЁиҝҮзЁӢж—¶пјҢжӣҝжҚўеҺҹжқҘзҡ„е®ҡд№үгҖӮ
procedure_name: еҲӣе»әзҡ„еӯҳеӮЁиҝҮзЁӢеҗҚз§°пјҢеҸҜд»ҘеёҰжңүжЁЎејҸеҗҚгҖӮ
argmode: еҸӮж•°зҡ„жЁЎејҸ (IN, OUT, INOUT, VARIADIC)гҖӮзјәзңҒеҖјжҳҜINгҖӮ
argname: еҸӮж•°зҡ„еҗҚз§°гҖӮ
argtype: еҸӮж•°зҡ„ж•°жҚ®зұ»еһӢгҖӮеҸҜд»ҘдҪҝз”Ё%TYPEжҲ–%ROWTYPEгҖӮ
expression: еҸӮж•°зҡ„й»ҳи®ӨиЎЁиҫҫејҸгҖӮ
configuration_parameter value: жҠҠжҢҮе®ҡзҡ„й…ҚзҪ®еҸӮж•°и®ҫзҪ®дёәз»ҷе®ҡзҡ„еҖјгҖӮ
IMMUTABLE | STABLE | VOLATILE etc.: иЎҢдёәзәҰжқҹеҸҜйҖүйЎ№гҖӮ
plsql_body: PL/SQLеӯҳеӮЁиҝҮзЁӢдҪ“гҖӮ

**CREATE FUNCTION**:
иҜӯжі•ж јејҸ
е…је®№PostgreSQLйЈҺж јзҡ„еҲӣе»әиҮӘе®ҡд№үеҮҪж•°иҜӯжі•гҖӮ
CREATE [ OR REPLACE  ] FUNCTION function_name 
    [ ( [  { argname [ argmode  ] argtype [  { DEFAULT  | :=  | =  } expression  ]}  [, ...]  ] ) ]
    [ RETURNS rettype [ DETERMINISTIC  ]  | RETURNS TABLE (  { column_name column_type  }  [, ...] )]
    LANGUAGE lang_name 
    [ 
       {IMMUTABLE  | STABLE  | VOLATILE }
        | {SHIPPABLE | NOT SHIPPABLE}
        | WINDOW
        | [ NOT  ] LEAKPROOF  
        | {CALLED ON NULL INPUT  | RETURNS NULL ON NULL INPUT | STRICT } 
        | {[ EXTERNAL  ] SECURITY INVOKER | [ EXTERNAL  ] SECURITY DEFINER | AUTHID DEFINER  | AUTHID CURRENT_USER} 
        | {fenced | not fenced}
        | {PACKAGE}
        | COST execution_cost
        | ROWS result_rows
        | SET configuration_parameter { {TO | =} value | FROM CURRENT }}
     ][...]
    {
        AS 'definition'
    }

еҸӮж•°иҜҙжҳҺ
1. **е‘ҪеҗҚи§„еҲҷ**
   - еҮҪж•°еҗҚ/еҸӮж•°еҗҚпјҡвүӨ63еӯ—з¬ҰпјҲи¶…й•ҝиҮӘеҠЁжҲӘж–ӯпјүпјҢйңҖз¬ҰеҗҲж ҮиҜҶз¬Ұи§„иҢғгҖӮ

2. **еҸӮж•°жЁЎејҸпјҲ`argmode`пјү**
   - ж”ҜжҢҒжЁЎејҸпјҡ`IN`пјҲй»ҳи®ӨпјүгҖҒ`OUT`гҖҒ`INOUT`гҖҒ`VARIADIC`гҖӮ
   - **ејәеҲ¶йҷҗеҲ¶**пјҡ
     - `OUT` еҗҺд»…е…Ғи®ёи·ҹ `VARIADIC`гҖӮ
     - `RETURNS TABLE` еҮҪж•°**зҰҒжӯў**дҪҝз”Ё `OUT/INOUT` еҸӮж•°гҖӮ
     - `INOUT` жЁЎејҸеңЁзү№е®ҡзүҲжң¬ (`10c` + `s2`) дёӢ**дёҚж”ҜжҢҒй»ҳи®ӨеҖј**гҖӮ

3. **й»ҳи®ӨеҸӮж•°пјҲ`expression`пјү**
   - йқһй»ҳи®ӨеҸӮж•°еҝ…йЎ»еңЁеүҚпјҢй»ҳи®ӨеҸӮж•°еңЁеҗҺгҖӮ
   - и°ғз”Ёж—¶йқһй»ҳи®ӨеҸӮж•°зјәеӨұдјҡжҠҘй”ҷпјҲйҷӨйқһеҗҜз”Ё `proc_uncheck_default_param` еҸӮж•°пјүгҖӮ

4. **иҝ”еӣһеҖјпјҲ`rettype`пјү**
   - еӯҳеңЁ `OUT/INOUT` еҸӮж•°ж—¶еҸҜзңҒз•Ҙ `RETURNS` еӯҗеҸҘгҖӮ
   - `SETOF` иЎЁзӨәиҝ”еӣһйӣҶеҗҲгҖӮ
5. RETURNS TABLE
   - еҸӘеҢ…еҗ«column_name column_typeпјҢдёҚиғҪи®ҫзҪ®defaultзӯүе…¶д»–еұһжҖ§

### **еҮҪж•°иЎҢдёәжҺ§еҲ¶**
- **жқғйҷҗиҰҒжұӮ**пјҡ
  - `internal` еҮҪж•°д»…йҷҗ `sysadmin` з”ЁжҲ·еҲӣе»әпјҢдё”йңҖеҢ№й…ҚеҶ…йғЁеҮҪж•°зӯҫеҗҚгҖӮ
- **зӘ—еҸЈеҮҪж•°**пјҡ
  - д»…ж”ҜжҢҒ `internal` иҜӯиЁҖпјҢдё”еҶ…йғЁеҮҪж•°еҝ…йЎ»жҳҜзӘ—еҸЈеҮҪж•°гҖӮ
- **зЁіе®ҡжҖ§ж Үзӯҫ**пјҡ
  - `IMMUTABLE`пјҲжҒ’е®ҡпјүгҖҒ`STABLE`пјҲзЁіе®ҡпјүгҖҒ`VOLATILE`пјҲжҳ“еҸҳпјүпјҢеҪұе“ҚжҹҘиҜўдјҳеҢ–гҖӮ
- **з©әеҖјеӨ„зҗҶ**пјҡ
  - `RETURNS NULL ON NULL INPUT` жҲ– `STRICT`пјҡеҸӮж•°дёә `NULL` ж—¶зӣҙжҺҘиҝ”еӣһ `NULL`гҖӮ
- **жү§иЎҢжқғйҷҗ**пјҡ
  - `SECURITY INVOKER`пјҲи°ғз”ЁиҖ…жқғйҷҗпјҢй»ҳи®Өпјү vs `SECURITY DEFINER`пјҲе®ҡд№үиҖ…жқғйҷҗпјүгҖӮ

### **йҮҚиҰҒйҷҗеҲ¶дёҺиӯҰе‘Ҡ**
1. **зҰҒжӯўж“ҚдҪң**пјҡ
   - еҮҪж•°дҪ“еҶ…**йҒҝе…Қж¶үеҸҠеҜҶз Ғ/еҜҶй’ҘжҳҺж–Үж“ҚдҪң**пјҲзі»з»ҹиЎЁеҸҜиғҪи®°еҪ•ж•Ҹж„ҹдҝЎжҒҜпјүгҖӮ
2. **е…је®№жҖ§иҜҙжҳҺ**пјҡ
   - `PACKAGE` еҮҪж•°дёҚж”ҜжҢҒ `VARIADIC` еҸӮж•°пјҢдё”дёҚеҸҜдҝ®ж”№ `PACKAGE` еұһжҖ§гҖӮ
   - `%TYPE` еңЁ `PACKAGE` еӨ–дёҚеҸҜеј•з”Ё `PACKAGE` еҸҳйҮҸзұ»еһӢгҖӮ
3. **е…¶д»–зәҰжқҹ**пјҡ
   - еҲӣе»әеҮҪж•°ж—¶дёҚеҸҜдҝ®ж”№ `WINDOW` еұһжҖ§гҖӮ
   - `LEAKPROOF` д»…йҷҗз®ЎзҗҶе‘ҳи®ҫзҪ®гҖӮ

### **жҖ§иғҪдёҺй…ҚзҪ®**
- **жү§иЎҢжҲҗжң¬**пјҡ
  - `COST`пјҡи®ҫзҪ®еҮҪж•° CPU жҲҗжң¬дј°еҖјпјҲеҚ•дҪҚпјҡ`cpu_operator_cost`пјүгҖӮ
- **иҝ”еӣһиЎҢж•°**пјҡ
  - `ROWS`пјҡйў„дј°иҝ”еӣһйӣҶеҗҲзҡ„иЎҢж•°пјҲй»ҳи®Ө 1000пјүгҖӮ
- **дјҡиҜқеҸӮж•°**пјҡ
  - `SET` еҸҜеңЁеҮҪж•°дёӯй…ҚзҪ®дјҡиҜқзә§еҸӮж•°пјҲеҰӮ `SET key TO value`пјүгҖӮ

### **иҜӯиЁҖиҜҙжҳҺ**
- й»ҳи®Өе®һзҺ°иҜӯиЁҖдёә `plpgsql`пјҲе…је®№ `A` ж•°жҚ®еә“йЈҺж јпјүгҖӮ
- `LANGUAGE SQL` е…Ғи®ёеҮҪж•°дҪ“дёә SQL жҹҘиҜўгҖӮ

жіЁж„ҸдәӢйЎ№пјҡ
### **еҲӣе»әдёҺе®ҡд№үжіЁж„ҸдәӢйЎ№**
- еҸӮж•°/иҝ”еӣһеҖјзІҫеәҰдёҚжЈҖжөӢпјҢе®ҡд№үж—¶йңҖжҳҫејҸжҢҮе®ҡиЎЁеҜ№иұЎжЁЎејҸпјҲйҒҝе…Қжү§иЎҢејӮеёёпјүгҖӮ
- еҲӣе»әж—¶д»…еҜ№еӯҳеӮЁиҝҮзЁӢеҠ еҶҷй”ҒпјҢжү§иЎҢж—¶еҜ№еҮҪж•°еҸҠдҫқиө–PACKAGEеҠ иҜ»й”ҒгҖӮ
- еҮҪж•°еҶ…`SET current_schema/search_path`ж— ж•ҲпјҢжү§иЎҢеҗҺжҒўеӨҚеҺҹеҖјгҖӮ
- дёҚж”ҜжҢҒеҮҪж•°иҮӘиә«дҪңдёәе…ҘеҸӮй»ҳи®ӨеҖјпјҢеҲӣе»әж—¶дёҚжЈҖжҹҘиҝ”еӣһеҖјзұ»еһӢгҖӮ

### **йҮҚиҪҪи§„еҲҷ**
- д»…ж”ҜжҢҒPostgreSQLйЈҺж јжҲ–PACKAGEеҮҪж•°йҮҚиҪҪпјҢзҰҒжӯўд»ҘдёӢжғ…еҶөпјҡ
  - д»…еҪўеҸӮеҗҚдёҚеҗҢ
  - дёҺеӯҳеӮЁиҝҮзЁӢеҗҢеҗҚеҗҢеҸӮ
  - д»…ref cursorзұ»еһӢдёҚеҗҢ
  - д»…иҝ”еӣһзұ»еһӢ/й»ҳи®ӨеҖјдёҚеҗҢ
- REPLACEж—¶иӢҘеҸӮж•°/иҝ”еӣһеҖјеҸҳеҢ–дјҡж–°е»әеҮҪж•°иҖҢйқһжӣҝжҚўгҖӮ
- и°ғз”ЁйҮҚиҪҪеҮҪж•°йңҖжҳҺзЎ®еҸҳйҮҸзұ»еһӢпјҢжңӘеЈ°жҳҺеҸҳйҮҸдјҡжҠҘй”ҷгҖӮ

### **еҮәеҸӮеӨ„зҗҶе…ій”®**
- **з”ҹж•ҲжқЎд»¶**пјҡ
  - еҝ…йЎ»жү“ејҖ`proc_outparam_override`еҸӮж•°
  - и°ғз”Ёж—¶йңҖеңЁеҮәеҸӮдҪҚзҪ®жҸҗдҫӣе®һеҸӮ
- **йҷҗеҲ¶**пјҡ
  - дёҚејҖеҗҜж—¶пјҡOUT/INOUTзҰҒз”ЁеӨҚеҗҲзұ»еһӢпјҢRETURNеҖјдјҡиў«иҜҶеҲ«дёәз¬¬дёҖдёӘеҮәеҸӮ
  - ејҖеҗҜеҗҺпјҡеҗҢдёҖSchema/PACKAGEзҰҒжӯўеҗҢеҗҚOUTеҮҪж•°пјҢSETOFиҝ”еӣһж—¶еҮәеҸӮж— ж•Ҳ
  - зҰҒжӯўеөҢеҘ—и°ғз”ЁпјҲйңҖжӢҶеҲҶдёәдёӨжӯҘпјү
- **зү№ж®Ҡж”ҜжҢҒ**пјҡ
  - `proc_outparam_transfer_length`еҸҜдј йҖ’еӯ—з¬Ұзұ»еһӢеҸӮж•°й•ҝеәҰ
  - `tableof_elem_constraints`ж”ҜжҢҒйӣҶеҗҲзұ»еһӢе…ғзҙ й•ҝеәҰдј йҖ’

### **еҮҪж•°и°ғз”ЁзәҰжқҹ**
- еёҰOUTеҸӮж•°зҡ„еҮҪж•°пјҡ
  - дёҚиғҪеңЁSQLиҜӯеҸҘдёӯдҪҝз”Ё
  - зҰҒз”ЁSELECT INTOи°ғз”Ё
  - зҰҒжӯўеөҢеҘ—и°ғз”Ё
- ж— еҸӮеҮҪж•°и°ғз”ЁеҸҜзңҒз•ҘжӢ¬еҸ·
- иөӢеҖјиЎЁиҫҫејҸдёӯи°ғз”ЁеёҰеҮәеҸӮеҮҪж•°йңҖжҸҗеүҚе®ҡд№үжҺҘж”¶еҸҳйҮҸ
- DMLиҜӯеҸҘ/иЎЁиҫҫејҸдёӯзҡ„outеҸӮж•°дёҚз”ҹж•Ҳ

### **жқғйҷҗдёҺе®үе…Ё**
- й»ҳи®ӨжҺҲдәҲPUBLICжү§иЎҢжқғйҷҗпјҲе»әи®®дәӢеҠЎдёӯеҲӣе»әе№¶еӣһж”¶пјү
- `CREATE ANY FUNCTION`жқғйҷҗз”ЁжҲ·еҸҜеңЁд»»ж„ҸжЁЎејҸеҲӣе»әеҮҪж•°
- е®ҡд№үиҖ…жқғйҷҗеҮҪж•°еҲӣе»әеҲ°е…¶д»–з”ЁжҲ·SchemaеӯҳеңЁи¶ҠжқғйЈҺйҷ©
- иҝҗз»ҙз®ЎзҗҶе‘ҳSchemaд»…е…Ғи®ёеұһдё»еҲӣе»әеҜ№иұЎ

### **дҫқиө–з®ЎзҗҶ**
- `plpgsql_dependency`ејҖеҗҜж—¶пјҡ
  - дҫқиө–жңӘе®ҡд№үеҜ№иұЎеҸҜеҲӣе»әпјҲWARNINGжҸҗзӨәпјү
  - еөҢеҘ—и°ғз”ЁпјҲеҰӮfuncA(funcB())пјүд»…е»әз«ӢfuncAдҫқиө–
  - иў«и§Ҷеӣҫдҫқиө–зҡ„еҮҪж•°йҮҚе»әеҗҺи§Ҷеӣҫд»ҚеҸҜи®ҝй—®
- жңӘејҖеҗҜж—¶дҫқиө–жңӘе®ҡд№үеҜ№иұЎеҲҷеҲӣе»әеӨұиҙҘ

### **е…¶д»–иҰҒзӮ№**
- ж”ҜжҢҒOracleйЈҺж јеҮҪж•°зҡ„еҸӮж•°жіЁйҮҠеҜје…ҘеҜјеҮә
- `plsql_security_definer`еҸҜе°Ҷй»ҳи®Өжқғйҷҗж”№дёәе®ҡд№үиҖ…жқғйҷҗ
- йғЁеҲҶиЎЁиҫҫејҸеңәжҷҜoutеҸӮж•°дёҚз”ҹж•ҲпјҲEXECUTE IMMEDIATE/SELECT INTOзӯүпјү

**INTEGER**:
жҸҸиҝ°: еёёз”Ёзҡ„ж•ҙж•°пјҢеҲ«еҗҚдёә INT4гҖӮ
еӯҳеӮЁз©әй—ҙ: 4еӯ—иҠӮ
иҢғеӣҙ: -2,147,483,648 ~ +2,147,483,647
иҜҙжҳҺ: TINYINTгҖҒSMALLINTгҖҒINTEGERгҖҒBIGINTе’ҢINT16зұ»еһӢеӯҳеӮЁеҗ„з§ҚиҢғеӣҙзҡ„ж•°еӯ—пјҢд№ҹе°ұжҳҜж•ҙж•°гҖӮеҰӮжһңеӯҳеӮЁи¶…еҮәиҢғеӣҙд»ҘеӨ–зҡ„ж•°еҖје°ҶдјҡеҜјиҮҙй”ҷиҜҜгҖӮеёёз”Ёзҡ„зұ»еһӢжҳҜINTEGERпјҢеӣ дёәе®ғжҸҗдҫӣдәҶеңЁиҢғеӣҙгҖҒеӯҳеӮЁз©әй—ҙгҖҒжҖ§иғҪд№Ӣй—ҙзҡ„жңҖдҪіе№іиЎЎгҖӮдёҖиҲ¬еҸӘжңүеҸ–еҖјиҢғеӣҙзЎ®е®ҡдёҚи¶…иҝҮSMALLINTзҡ„жғ…еҶөдёӢпјҢжүҚдјҡдҪҝз”ЁSMALLINTзұ»еһӢгҖӮиҖҢеҸӘжңүеңЁINTEGERзҡ„иҢғеӣҙдёҚеӨҹзҡ„ж—¶еҖҷжүҚдҪҝз”ЁBIGINTпјҢеӣ дёәINTEGERзҡ„еӨ„зҗҶйҖҹеәҰзӣёеҜ№еҝ«еҫ—еӨҡгҖӮ

**INTEGER (еёҰзІҫеәҰ)**:
жҸҸиҝ°: зІҫеәҰpеҸ–еҖјиҢғеӣҙдёә[1,1000]пјҢж ҮеәҰsеҸ–еҖјиҢғеӣҙдёә[0,p]гҖӮеңЁжңӘжҢҮе®ҡзІҫеәҰе’Ңж ҮеәҰзҡ„жғ…еҶөдёӢпјҢй»ҳи®ӨзІҫеәҰpдёә10пјҢж ҮеәҰsдёә0пјҢиҜҘзұ»еһӢжҳ е°„дёәINTEGERгҖӮжҢҮе®ҡзІҫеәҰе’Ңж ҮеәҰзҡ„жғ…еҶөдёӢпјҢиҜҘзұ»еһӢжҳ е°„дёәNUMERICгҖӮ
еӯҳеӮЁз©әй—ҙ: з”ЁжҲ·еЈ°жҳҺзІҫеәҰгҖӮжҜҸеӣӣдҪҚпјҲеҚҒиҝӣеҲ¶дҪҚпјүеҚ з”ЁдёӨдёӘеӯ—иҠӮпјҢз„¶еҗҺеңЁж•ҙдёӘж•°жҚ®дёҠеҠ дёҠе…«дёӘеӯ—иҠӮзҡ„йўқеӨ–ејҖй”Җ (еҪ“жҳ е°„дёәNUMERICж—¶)пјӣ4еӯ—иҠӮ (еҪ“жҳ е°„дёәINTEGERж—¶)гҖӮ
иҢғеӣҙ: еңЁзІҫеәҰе’Ңж ҮеәҰжҢҮе®ҡжңҖеӨ§зҡ„жғ…еҶөдёӢпјҢе°Ҹж•°зӮ№еүҚжңҖеӨ§131,072дҪҚпјҢе°Ҹж•°зӮ№еҗҺжңҖеӨ§16,383дҪҚ (еҪ“жҳ е°„дёәNUMERICж—¶)гҖӮжңӘжҢҮе®ҡзІҫеәҰе’Ңж ҮеәҰзҡ„жғ…еҶөдёӢпјҢиҢғеӣҙжҳҜ-2,147,483,648 ~ +2,147,483,647 (еҪ“жҳ е°„дёәINTEGERж—¶)гҖӮ
иҜҙжҳҺ: иҝҷжҳҜеҜ№INTEGERзұ»еһӢзҡ„дёҖз§Қзү№ж®ҠеЈ°жҳҺж–№ејҸпјҢж №жҚ®жҳҜеҗҰжҢҮе®ҡзІҫеәҰе’Ңж ҮеәҰпјҢе…¶иЎҢдёәдјҡеғҸINTEGERжҲ–NUMERICгҖӮ

