WITH operations AS (SELECT inp_no, visit_id AS times, string_agg(operation_code, ',' ORDER BY operation_no) AS operation_codes FROM emr_temp_ip_patient_operation GROUP BY inp_no, visit_id), diagnosis_agg AS (SELECT inp_no, visit_id, type, diagnosis_type_name, string_agg(diagnosis_code, ',' ORDER BY diagnosis_no) FILTER (WHERE diagnosis_flag = '1') AS diagnosis_codes, string_agg(diagnosis_code, ',' ORDER BY diagnosis_no) FILTER (WHERE diagnosis_flag = '0') AS chinese_diagnosis_codes, string_agg(diagnosis_name, ',' ORDER BY diagnosis_no) FILTER (WHERE diagnosis_flag = '0') AS chinese_diagnosis_names, MIN(CASE WHEN type = '病历诊断' AND diagnosis_type_name = '最后诊断' THEN 1 WHEN type = '病历诊断' AND diagnosis_type_name = '初步诊断' THEN 2 WHEN type = '首页诊断' AND diagnosis_type_name = '出院诊断' THEN 1 WHEN type = '首页诊断' AND diagnosis_type_name = '门诊诊断' THEN 2 ELSE 3 END) AS priority FROM emr_temp_ip_patient_diagnosis WHERE file_visit_type = '2' GROUP BY inp_no, visit_id, type, diagnosis_type_name), diagnosis_end AS (SELECT inp_no, visit_id AS times, type, diagnosis_type_name, diagnosis_codes, chinese_diagnosis_codes, chinese_diagnosis_names FROM (SELECT *, ROW_NUMBER() OVER (PARTITION BY inp_no, visit_id, type ORDER BY priority) AS rn FROM diagnosis_agg) t WHERE rn = 1) SELECT a.register_no AS patientid, a.inpatient_name AS patientname, a.age, a.sex AS gender, a.in_date::date AS indate, a.out_date::date AS outdate, a.times AS inhospitaltimes, a.person_type AS persontype, a.patient_no AS serialno, b.total_cost AS medicalcost, 'doctor' AS entrymode, 'remind' AS defaulttab, a.current_dept_code AS deptcode, '440100' AS citycode, d.type, d.diagnosis_codes AS diagnosiscode, o.operation_codes AS operationcode, d.chinese_diagnosis_codes AS chinesediagnosiscode, d.chinese_diagnosis_names AS chinesediagnosename FROM his_temp_ip_patient_info a LEFT JOIN his_temp_ip_settle b ON a.register_no = b.register_no AND a.times = b.times LEFT JOIN diagnosis_end d ON a.register_no = d.inp_no AND a.times = d.times LEFT JOIN operations o ON a.register_no = o.inp_no AND a.times = o.times WHERE a.out_date >= '2025-01-02'::timestamp ORDER BY a.out_date DESC

