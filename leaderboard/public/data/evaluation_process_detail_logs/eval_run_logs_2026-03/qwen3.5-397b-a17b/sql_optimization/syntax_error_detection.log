## SQL:
WITH user_orders AS (SELECT u.user_id, u.username, o.order_id, o.order_date FROM users u JOIN orders o ON u.user_id = o.user_id WHERE u.status = 'active' AND o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 3 YEAR)), metrics AS (SELECT uo.user_id, uo.username, COUNT(uo.order_id) AS total_orders, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS total_spent, AVG(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS avg_order_value, MAX(uo.order_date) AS last_order_date FROM user_orders uo LEFT JOIN order_items oi ON uo.order_id = oi.order_id GROUP BY uo.user_id, uo.username), top_products AS (SELECT user_id, GROUP_CONCAT(product_name ORDER BY product_name SEPARATOR ', ') AS top_products FROM (SELECT uo.user_id, p.product_name, ROW_NUMBER() OVER (PARTITION BY uo.user_id ORDER BY SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) DESC) AS rn FROM user_orders uo JOIN order_items oi ON uo.order_id = oi.order_id JOIN products p ON oi.product_id = p.product_id GROUP BY uo.user_id, p.product_id, p.product_name) ranked WHERE rn <= 3 GROUP BY user_id) SELECT m.user_id, m.username, m.total_orders, m.total_spent, m.avg_order_value, m.last_order_date, t.top_products FROM metrics m LEFT JOIN top_products t ON m.user_id = t.user_id ORDER BY m.total_spent DESC

