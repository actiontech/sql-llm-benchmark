(SELECT departamento, subdepartamento, clase, subclase, proveedor, estilo, tipo_articulo FROM catalogos.maestro_estilos me WHERE me.proveedor = 1162 AND me.estilo = 'C21031101') me LEFT JOIN catalogos.ranking_tda_jerarquia rj ON c.tienda = rj.id_tienda AND rj.departamento = me.departamento AND rj.subdepartamento = me.subdepartamento AND rj.clase = me.clase AND rj.subclase = me.subclase LEFT JOIN catalogos.control_asignacion_matrices cam ON rj.ranking = cam.clasificacion LEFT JOIN otr_agg otr ON otr.id_tienda = c.tienda AND otr.id_departamento = me.departamento AND otr.id_subdepartamento = me.subdepartamento AND otr.id_clase = me.clase AND otr.id_subclase = me.subclase AND otr.tipo_articulo = me.tipo_articulo WHERE c.centro_comercial = 1 AND c.clima LIKE '%calor todo el tiempo%' AND c.tienda = 3064

