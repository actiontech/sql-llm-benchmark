WITH trans_agg AS (SELECT A.tenant_id, A.gl_account_id, B.acctg_period, SUM(A.base_posted_dr) AS base_posted_dr1, SUM(A.base_posted_cr) AS base_posted_cr1 FROM acctg_trans_detail A JOIN acctg_trans B ON A.master_voucher_id = B.id AND A.tenant_id = B.tenant_id WHERE A.tenant_id = 1065587309019136 AND (A.voucher_status_enum IS NULL OR A.voucher_status_enum != 'CANCELLED') AND (B.bo_name IS NULL OR B.bo_name != 'DraftAcctgTrans') GROUP BY A.tenant_id, A.gl_account_id, B.acctg_period) SELECT T.tenant_id, T.gl_account_id, AC.code, T.acctg_period, B.base_posted_dr, B.base_posted_cr, T.base_posted_dr1, T.base_posted_cr1 FROM trans_agg T LEFT JOIN gl_account_balance B ON T.gl_account_id = B.gl_account_id AND T.acctg_period = B.acctg_period AND T.tenant_id = B.tenant_id LEFT JOIN gl_account AC ON T.gl_account_id = AC.id AND T.tenant_id = AC.tenant_id WHERE B.id IS NULL OR (T.base_posted_dr1 != IFNULL(B.base_posted_dr, 0) OR T.base_posted_cr1 != IFNULL(B.base_posted_cr, 0)) UNION ALL SELECT B.tenant_id, B.gl_account_id, AC.code, B.acctg_period, B.base_posted_dr, B.base_posted_cr, T.base_posted_dr1, T.base_posted_cr1 FROM gl_account_balance B LEFT JOIN trans_agg T ON B.gl_account_id = T.gl_account_id AND B.acctg_period = T.acctg_period AND B.tenant_id = T.tenant_id LEFT JOIN gl_account AC ON B.gl_account_id = AC.id AND B.tenant_id = AC.tenant_id WHERE T.gl_account_id IS NULL AND (B.base_posted_dr != 0 OR B.base_posted_cr != 0) AND B.tenant_id = 1065587309019136 AND B.acctg_period NOT LIKE '%00' LIMIT 50001

