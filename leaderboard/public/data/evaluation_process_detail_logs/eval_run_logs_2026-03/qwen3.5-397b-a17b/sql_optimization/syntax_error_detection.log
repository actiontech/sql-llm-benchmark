SELECT A.ID AS id, A.PRAMARYID AS primaryId, A.OPERCODE AS operCode, A.OPERNAME AS operName, A.OPERDEPT AS operDept, A.OPERDATE AS operDate, A.MARK AS mark, C.BACKREASON AS mark1, A.MARK2 AS mark2, A.MARK3 AS mark3, A.MARK4 AS mark4, A.OPERTYPE AS operType, A.NEXTOPERTYPE AS nextOperType, A.PREOPERTYPE AS preOperType, A.VALID AS valid, A.CONFIRMUSER AS confirmUser, A.CONFIRMDEPT AS confirmDept, A.VERSIONNUMBER AS versionNumber, P.IN_TIMES AS inTimes, P.NAME AS patient, P.IN_DATE AS inDate, P.OUT_DATE AS outDate, P.OUT_DEPT AS outDept, P.RECORD_STATE AS recordState FROM (SELECT B.ID, B.IN_TIMES, B.NAME, B.IN_DATE, B.OUT_DATE, B.OUT_DEPT, B.RECORD_STATE, ROW_NUMBER() OVER (ORDER BY B.IN_DATE DESC) rn FROM mrtrecordinfo B WHERE B.ID LIKE '%' || 'ABC' || '%' AND EXISTS (SELECT 1 FROM mrtopration x WHERE x.ID = B.ID)) P JOIN mrtopration A ON P.ID = A.ID LEFT JOIN mrtrecordregresses C ON P.ID = C.RECODE_NO AND A.OPERDATE = C.OPER_DATE AND A.OPERCODE = C.OPERID WHERE P.rn <= 10 ORDER BY A.OPERDATE DESC

