WITH a1 AS (SELECT setl_id, listagg(distinct MEDINS_LIST_CODG, ',') within group (order by MEDINS_LIST_CODG) b_medins_list_codg, listagg(distinct medins_list_name, ',') within group (order by medins_list_name) b_medins_list_name, listagg(distinct f.hilist_code, ',') within group (order by f.hilist_code) b_hilist_code, listagg(distinct hilist_name, ',') within group (order by hilist_name) b_hilist_name, listagg(distinct MED_CHRGITM_TYPE_NAME, ',') within group (order by MED_CHRGITM_TYPE_NAME) MED_CHRGITM_TYPE, listagg(distinct CHRGITM_LV_NAME, ',') within group (order by CHRGITM_LV_NAME) CHRGITM_LV, listagg(distinct BILG_DEPT_NAME, ',') within group (order by BILG_DEPT_NAME) BILG_DEPT_NAME, listagg(distinct BILG_DR_NAME, ',') within group (order by BILG_DR_NAME) BILG_DR_NAME, listagg(distinct ACORD_DEPT_NAME, ',') within group (order by ACORD_DEPT_NAME) ACORD_DEPT_NAME, listagg(distinct ACORD_DR_NAME, ',') within group (order by ACORD_DR_NAME) ACORD_DR_NAME, sum(f.cnt) as b_cnt, sum(f.det_item_fee_sumamt) as b_fee, min(f.pric) as min_pric, min(abs(f.inscp_amt / f.cnt)) as min_amt FROM FEE_LIST_D f WHERE f.cnt <> 0 AND f.CHRGITM_LV_NAME in ('甲类','乙类') GROUP BY f.setl_id) SELECT s.fixmedins_code 医院代码，s.fixmedins_name 医院名称，s.HOSP_LV_NAME 医院级别，s.setl_id 结算单据号，s.mdtrt_id 就诊 ID, s.ipt_otp_no 住院号，s.psn_no 个人编号，s.psn_name 姓名，s.certno 身份证号，s.GEND_NAME 性别，s.brdy 出生日期，s.age 年龄，s.insu_admdvs 统筹区，s.INSUTYPE_NAME 险种类型，s.PSN_TYPE_NAME 医疗人员类别，s.SP_PSN_TYPE_NAME 特殊人员身份类别，s.med_type_name 就医类型，s.PAY_LOC_NAME 支付地点类别，s.setl_time 结算日期，s.adm_dept_name 入院科室，s.dscg_dept_name 出院科室，s.begntime 入院日期，s.endtime 出院日期，s.IPT_DAYS 天数，s.chfpdr_name 主治医生，s.adm_diag_dscr 入院诊断，s.dscg_maindiag_name 出院诊断，s.DIAG_NAME 其他诊断，s.dise_no 病种编码，s.dise_name 病种名称，s.OPRN_NAME 手术及操作名称，s.medfee_sumamt 总金额，concat(to_char(s.pool_prop_selfpay * 100), '%') 基本医疗统筹支付比例，s.hifp_pay 基本医保支付，s.hifmi_pay 大病报销，s.maf_pay 医疗救助，s.cvlserv_pay 公务员补充，s.othfund_pay 其他支付，s.acct_pay 个人帐户支付，s.cash_payamt 个人现金支付，s.fund_pay_sumamt 基金支付总额，fl.MED_