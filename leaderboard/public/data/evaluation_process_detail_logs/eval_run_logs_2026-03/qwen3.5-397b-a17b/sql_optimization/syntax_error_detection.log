WITH first_trans AS (SELECT tran_account_no, tran_subacc_no, MIN(tran_seqno) first_tran_seq, MIN(tran_date) first_tran_date FROM transactions WHERE tran_amount_cr IS NOT NULL AND tran_trans_code IN ('RIC','RSAV') AND tran_date BETWEEN IN_FUND_FROM_DATE AND IN_FUND_TO_DATE AND tran_pay_method NOT IN ('C','CQ') GROUP BY tran_account_no, tran_subacc_no), onhold_accounts AS (SELECT DISTINCT audh_key1, audh_key2, audh_date FROM audit_header JOIN audit_detail ON audh_seqno = audd_audh_seqno WHERE audh_table_prefix = 'ACC' AND audd_col_sufix = 'PROCESS_STATUS' AND audh_change_type = 'I' AND audd_old_value IS NULL AND audd_new_value = '1'), base_accounts AS (SELECT acc.acc_account_no, acc.acc_subacc_no, acc.acc_incep_date, acc.acc_act_code, ah.acch_title, ah.acch_brn_code, at.act_long_name, ft.first_tran_seq, ft.first_tran_date FROM accounts acc JOIN account_headers ah ON ah.acch_account_no = acc.acc_account_no JOIN account_types at ON at.act_code = acc.acc_act_code JOIN first_trans ft ON ft.tran_account_no = acc.acc_account_no AND ft.tran_subacc_no = acc.acc_subacc_no WHERE acc.acc_gact_type IN ('S', 'IC') AND acc.acc_incep_date BETWEEN IN_INCEP_FROM_DATE AND IN_INCEP_TO_DATE) SELECT DISTINCT ba.acc_account_no, ba.acc_subacc_no, ba.acch_title, TO_CHAR(ba.acc_incep_date,'DD/MM/YYYY'), htax.ACCTAX_EFF_DATE_FROM, TO_CHAR(oha.audh_date, 'DD-MON-YYYY'), ba.act_long_name, t.tran_amount_cr, t.tran_create_by, CASE WHEN (TRUNC(ba.acc_incep_date) - TRUNC(oha.audh_date)) < 0 THEN 0 ELSE (TRUNC(ba.acc_incep_date) - TRUNC(oha.audh_date)) END, ba.acch_brn_code FROM base_accounts ba JOIN onhold_accounts oha ON ba.acc_account_no = oha.audh_key1 AND ba.acc_subacc_no = oha.audh_key2 JOIN transactions t ON t.tran_seqno = ba.first_tran_seq JOIN ACCOUNT_LINKS al ON al.accl_account_no = ba.acc_account_no AND al.accl_subacc_no = ba.acc_subacc_no AND al.accl_holder_pos = 1 JOIN SUMMIT.ACCOUNT_HOLDING_TAX htax ON htax.ACCTAX_ACCOUNT_NO = al.ACCL_ACCOUNT_NO AND htax.ACCTAX_SUBACC_NO = al.ACCL_SUBACC_NO AND htax.ACCTAX_CUST_SEQNO = al.ACCL_CUST_SEQNO

