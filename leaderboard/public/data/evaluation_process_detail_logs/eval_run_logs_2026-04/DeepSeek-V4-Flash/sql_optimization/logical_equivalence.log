SELECT temp.*, r.STORE_NAME, l.LOCATION_NAME, s.STANDARD_NAME, c.COLUMN_NAME AS STEEL_GRADE_NAME, si.SEND_ID AS CONNECT_ID, sid.SEND_PRODUCT_DETAIL_ID AS CONNECT_DETAIL_ID, IF(sid.SPOT_TYPE = '40', IFNULL(sid.WEIGHT,0), IFNULL(sid.NUMBER,0)) AS SEND_NUMBER, IF(sid.SPOT_TYPE = '40', IFNULL(rd.WEIGHT,0), IFNULL(rd.NUMBER,0)) AS RETURN_NUMBER FROM (SELECT COALESCE(v.PACKAGE_NO,v.MATERIAL_NO) AS MIXED_NO, '30' AS SPOT_TYPE, v.MATERIAL_NO, v.PACKAGE_NO, v.PSR_ID, v.CUSTOMER_ID, v.CONTRACT_ID, v.CONTRACT_NO, v.NUMBER, v.NET_WEIGHT, v.GROSS_WT, v.STORE_ID, v.LOCATION_ID, v.STANDARD_ID, v.STEEL_GRADE, v.SURFACE_GROUP_DESC, v.CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, IF(v.LENGTH IS NOT NULL AND v.LENGTH != 0, CONCAT(v.THICK,'*',v.WIDTH,'*',v.LENGTH), CONCAT(v.THICK,'*',v.WIDTH,'*C')) AS specs, SUM(IF(cd.BUY_UNIT='10', cd.TAX_PRICE*v.NET_WEIGHT, cd.TAX_PRICE*IFNULL(cd.NUMBER,1))) AS PRICE FROM v_pre_product_material v LEFT JOIN t_dgm_send_plan_detail m ON v.MATERIAL_NO = m.MATERIAL_NO LEFT JOIN t_dgm_send_plan_detail p ON v.PACKAGE_NO = p.PACKAGE_NO LEFT JOIN t_mao_contract_delivery_subkey dk ON dk.CONTRACT_DELIVERY_ID = v.CONTRACT_DELIVERY_ID LEFT JOIN t_sam_contract_detail cd ON dk.CONTRACT_DETAIL_ID = cd.CONTRACT_DETAILS_ID WHERE v.IS_ISSUED='1' AND v.IS_SPOT_RESOURCE='0' AND v.NI36_TAG='0' AND v.MATERIAL_STATE!='110' AND v.CONTRACT_TYPE!='60' AND NOT EXISTS (SELECT 1 FROM v_pre_product_material v2 WHERE (v2.PACKAGE_NO=v.PACKAGE_NO OR v2.MATERIAL_NO=v.MATERIAL_NO) AND v2.IS_ISSUED!='1') GROUP BY COALESCE(v.PACKAGE_NO,v.MATERIAL_NO) UNION ALL SELECT cd.CONTRACT_DETAILS_ID AS PRODUCE_MATERIAL_ID, cd.PRODUCT_MATERIAL_NO AS MIXED_NO, '10' AS SPOT_TYPE, cd.PRODUCT_MATERIAL_NO AS MATERIAL_NO, NULL AS PACKAGE_NO, bc.COLUMN_NAME AS PSR_ID, c.CUSTOMER_ID, c.CONTRACT_ID, c.CONTRACT_NO, 1 AS NUMBER, i.NEW_WEIGHT AS NET_WEIGHT, i.GROSS_WT, i.STORE_ID, i.LOCATION_ID, NULL AS STANDARD_ID, i.STEEL_GRADE, NULL AS SURFACE_GROUP_DESC, cd.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, i.VARIETY_ID, IF(i.MATERIAL_LENGTH IS NOT NULL AND i.MATERIAL_LENGTH!=0, CONCAT_WS('*',i.MATERIAL_THICK,i.MATERIAL_WIDTH,i.MATERIAL_LENGTH), CONCAT_WS('*',i.MATERIAL_THICK,i.MATERIAL_WIDTH,'C')) AS specs, cd.IN_TAX_TOTAL AS PRICE FROM t_sam_contract_detail cd JOIN t_sam_contract c ON c.CONTRACT_ID=cd.CONTRACT_ID JOIN t_inm_store_info i ON i.MATERIAL_NO=cd.PRODUCT_MATERIAL_NO LEFT JOIN zjjs_mpm.t_bdm_column bc ON i.VARIETY_ID=bc.COLUMN_ID WHERE c.CONTRACT_TYPE='20' AND cd.IS_DELETE='0' AND c.IS_DELETE='0' AND cd.SPOT_TYPE='10' AND i.STOCK_ID IS NOT NULL AND c.CONTRACT_STATE IN ('40','50','70') GROUP BY cd.PRODUCT_MATERIAL_NO UNION ALL SELECT p.PRODUCE_MATERIAL_ID, cd.PRODUCT_MATERIAL_NO AS MIXED_NO, '30' AS SPOT_TYPE, cd.PRODUCT_MATERIAL_NO AS MATERIAL_NO, p.PACKAGE_NO, p.PSR_ID, c.CUSTOMER_ID, c.CONTRACT_ID, c.CONTRACT_NO, p.NUMBER, p.NET_WEIGHT, p.GROSS_WT, p.STORE_ID, p.LOCATION_ID, p.STANDARD_ID, p.STEEL_GRADE, p.SURFACE_GROUP_DESC, cd.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, IF(p.LENGTH IS NOT NULL AND p.LENGTH!=0, CONCAT(p.THICK,'*',p.WIDTH,'*',p.LENGTH), CONCAT(p.THICK,'*',p.WIDTH,'*C')) AS specs, cd.IN_TAX_TOTAL AS PRICE FROM t_sam_contract_detail cd JOIN t_sam_contract c ON c.CONTRACT_ID=cd.CONTRACT_ID JOIN t_pre_product_material p ON p.PACKAGE_NO=cd.PRODUCT_MATERIAL_NO OR p.MATERIAL_NO=cd.PRODUCT_MATERIAL_NO WHERE c.CONTRACT_TYPE='20' AND cd.IS_DELETE='0' AND c.IS_DELETE='0' AND cd.SPOT_TYPE IN ('20','30') AND c.CONTRACT_STATE IN ('40','50','70') GROUP BY cd.PRODUCT_MATERIAL_NO UNION ALL SELECT cd.SCRAP_INFO_ID AS PRODUCE_MATERIAL_ID, s.BATCH_NO AS MIXED_NO, cd.SPOT_TYPE, s.BATCH_NO AS MATERIAL_NO, s.BATCH_NO AS PACKAGE_NO, s.PRODUCT_NAME AS PSR_ID, c.CUSTOMER_ID, c.CONTRACT_ID, c.CONTRACT_NO, NULL AS NUMBER, s.WEIGHT AS NET_WEIGHT, NULL AS GROSS_WT, '/' AS STORE_ID, '/' AS LOCATION_ID, NULL AS STANDARD_ID, s.STEEL_GRADE, NULL AS SURFACE_GROUP_DESC, cd.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, NULL AS specs, s.WEIGHT * cd.TAX_PRICE AS PRICE FROM t_sam_contract_detail cd JOIN t_sam_contract c ON c.CONTRACT_ID=cd.CONTRACT_ID JOIN t_pre_scrap s ON s.SCRAP_INFO_ID=cd.SCRAP_INFO_ID WHERE c.CONTRACT_TYPE='20' AND cd.IS_DELETE='0' AND c.IS_DELETE='0' AND cd.SPOT_TYPE='40' AND c.CONTRACT_STATE IN ('40','50','70') GROUP BY s.BATCH_NO) temp JOIN t_dgm_send_info_detail sid ON sid.MIXED_NO=temp.MIXED_NO JOIN t_dgm_send_info si ON si.SEND_ID=sid.SEND_ID AND si.SEND_STATE='70' LEFT JOIN t_dgm_send_info_return_detail rd ON rd.CONNECT_DETAIL_ID=sid.SEND_PRODUCT_DETAIL_ID LEFT JOIN zjjs_rmm.t_rmm_store r ON r.STORE_ID=temp.STORE_ID LEFT JOIN zjjs_rmm.t_rmm_location l ON l.LOCATION_ID=temp.LOCATION_ID LEFT JOIN zjjs_qdm.t_qdm_standard s ON s.STANDARD_ID=temp.STANDARD_ID LEFT JOIN zjjs_mpm.t_bdm_column c ON c.COLUMN_ID=temp.STEEL_GRADE WHERE temp.CUSTOMER_ID='1930921074703462401' GROUP BY temp.MIXED_NO HAVING SEND_NUMBER > RETURN_NUMBER LIMIT 100

