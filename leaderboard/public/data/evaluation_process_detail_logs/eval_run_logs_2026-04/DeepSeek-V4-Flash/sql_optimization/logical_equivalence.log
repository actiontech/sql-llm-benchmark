## Original SQL:
select
  count(*)
from
  (
  select
   tt.jobid,
   tt.tellercode,
   tt.jobname,
   tt.jobstatus,
   tt.jobstartpersname,
   tt.jobpriorpersname,
   tt.jobtype,
   tt.createtime,
   tt.tranname,
   tt.issucc,
   tt.tranprop,
   tt.trandata,
   tt.jbjg,
   tt.jbgy,
   tt.ldlcid
  from
   (
  select
  t3.jobid,
  t3.tellercode,
  t3.jobname,
  t3.jobstatus,
  t3.jobstartpersname,
  t3.jobpriorpersname,
  t3.jobtype,
  t3.createtime,
  t3.tranname,
  t3.issucc,
  t3.tranprop,
  t3.trandata,
  t3.jbjg,
  t3.jbgy,
  t3.ldlcid,
  row_number() over (
   partition by
  t3.jobid
   order by
  t3.createtime desc
  ) as rn
  from
  jobinfo_his t3
  where
  exists (
   select
  t2.jobid
   from
  jobinfo_his t2
   where
  t2.jobid = t3.jobid
  and exists (
  select
   t1.jobid
  from
   jobinfo_his t1
  where
   t1.jobid = t2.jobid
   and t1.jobstatus = 'O'
   and substr(jobid, 0, 1) = 'A'
  )
   group by
  t2.jobid
   having
  count(decode(t2.jobstatus, 'N', 1, null)) = 0
  )
   ) tt
  where
   tt.rn = 1
  union all
  select
   t.jobid,
   t.tellercode,
