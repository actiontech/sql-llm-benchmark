SELECT u.user_id, u.username, COUNT(DISTINCT o.order_id) AS total_orders, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS total_spent, AVG(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS avg_order_value, MAX(o.order_date) AS last_order_date, COALESCE(t.top_products, '') AS top_products FROM users u INNER JOIN orders o ON u.user_id = o.user_id AND o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 3 YEAR) LEFT JOIN order_items oi ON o.order_id = oi.order_id LEFT JOIN (SELECT o3.user_id, GROUP_CONCAT(DISTINCT p.product_name ORDER BY p.product_name SEPARATOR ', ') AS top_products FROM (SELECT o3.user_id, p.product_name, SUM(oi2.quantity * oi2.unit_price * (1 - oi2.discount / 100)) AS product_total FROM order_items oi2 INNER JOIN orders o3 ON oi2.order_id = o3.order_id AND o3.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 3 YEAR) INNER JOIN products p ON oi2.product_id = p.product_id GROUP BY o3.user_id, p.product_name ORDER BY o3.user_id, product_total DESC) AS ranked WHERE (@rownum := IF(@prev_user = user_id, @rownum + 1, 1)) <= 3 AND (@prev_user := user_id) IS NOT NULL GROUP BY user_id) t ON u.user_id = t.user_id WHERE u.status = 'active' GROUP BY u.user_id, u.username HAVING total_orders > 0 ORDER BY total_spent DESC

