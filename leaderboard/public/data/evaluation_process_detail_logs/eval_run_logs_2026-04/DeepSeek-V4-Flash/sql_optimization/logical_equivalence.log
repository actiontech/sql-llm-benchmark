WITH avg_cust_rate AS (
    SELECT vehicle_type, booking_status, payment_method, AVG(COALESCE(ride_distance, 0)) as avg_v
    FROM ride_bookings
    GROUP BY vehicle_type, booking_status, payment_method
),
ranked AS (
    SELECT b.vehicle_type, b.booking_status, b.payment_method, b.ride_distance,
           COALESCE(b.ride_distance, 0) - COALESCE(a.avg_v, 0) as rate,
           ROW_NUMBER() OVER (PARTITION BY b.vehicle_type ORDER BY ABS(COALESCE(b.ride_distance, 0) - COALESCE(a.avg_v, 0)) DESC) as rank_num
    FROM ride_bookings b
    JOIN avg_cust_rate a ON b.vehicle_type = a.vehicle_type AND b.booking_status = a.booking_status AND b.payment_method = a.payment_method
    WHERE ABS(COALESCE(b.ride_distance, 0) - COALESCE(a.avg_v, 0)) >= 1
)
SELECT * FROM ranked WHERE rank_num <= 5;
