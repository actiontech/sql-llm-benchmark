  `oldTitle` varchar(500) DEFAULT NULL COMMENT '旧标题，非模板命名规则文档使用',
  `appId` bigint(20) DEFAULT NULL COMMENT '应用ID，即AppToken.id',
  `ownerPassword` varchar(20) DEFAULT NULL COMMENT '编辑密码',
  PRIMARY KEY (`id`) USING BTREE,
