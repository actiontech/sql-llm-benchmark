  `readOnlyDocumentId` bigint(20) DEFAULT NULL COMMENT '隐藏非只读参数文档id',
  `jsonKey` varchar(100) DEFAULT NULL COMMENT 'json在文件服务器标识',
  `transientDocumentId` varchar(1024) DEFAULT NULL COMMENT 'Adobe文件id',
