CREATE TABLE `inn_inns` (
  `ID` varchar(64) NOT NULL COMMENT ' 酒店ID和第三方酒店ID',
  `CHAIN_CODE` varchar(64) DEFAULT NULL COMMENT '用于兼容7天酒店ID,所以保留',
