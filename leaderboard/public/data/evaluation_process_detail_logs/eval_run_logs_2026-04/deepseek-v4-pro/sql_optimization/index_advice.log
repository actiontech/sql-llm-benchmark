  KEY `IDX_MERGEDOCID` (`mergeDocId`),
  KEY `IDX_DOC_FILEKEY` (`fileKey`),
  KEY `ix_02` (`businessId`,`createTime`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='文档信息表'

