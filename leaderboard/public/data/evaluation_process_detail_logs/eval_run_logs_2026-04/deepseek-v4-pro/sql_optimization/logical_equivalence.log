talogos.maestro_estilos me2 WHERE me2.proveedor = 1162 AND me2.estilo = 'C21031101' AND oc.id_departamento = me2.departamento AND oc.id_subdepartamento = me2.subdepartamento AND oc.id_clase = me2.clase AND oc.id_subclase = me2.subclase AND oc.tipo_articulo = me2.tipo_articulo) GROUP BY oc.id_tienda, oc.id_departamento, oc.id_subdepartamento, oc.id_clase, oc.id_subclase, oc.tipo_articulo) otr ON otr.id_tienda = c.tienda AND otr.id_departamento = me.departamento AND otr.id_subdepartamento = me.subdepartamento AND otr.id_clase = me.clase AND otr.id_subclase = me.subclase AND otr.tipo_articulo = me.tipo_articulo WHERE c.centro_comercial = 1 AND c.clima LIKE '%calor todo el tiempo%' AND c.tienda = 3064

