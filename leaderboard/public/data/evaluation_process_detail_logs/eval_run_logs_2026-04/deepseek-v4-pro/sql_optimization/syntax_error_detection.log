WITH pag AS (SELECT * FROM (SELECT B.*, ROW_NUMBER() OVER (ORDER BY B.IN_DATE DESC) rn FROM mrtrecordinfo B WHERE B.ID LIKE :"SYS_B_0" || :1 || :" SYS_B_1") WHERE rn BETWEEN :2 + :"SYS_B_2" AND :3 + :4) SELECT A.ID AS id, A.PRAMARYID AS primaryId, A.OPERCODE AS operCode, A.OPERNAME AS operName, A.OPERDEPT AS operDept, A.OPERDATE AS operDate, A.MARK AS mark, C.BACKREASON AS mark1, A.MARK2 AS mark2, A.MARK3 AS mark3, A.MARK4 AS mark4, A.OPERTYPE AS operType, A.NEXTOPERTYPE AS nextOperType, A.PREOPERTYPE AS preOperType, A.VALID AS valid, A.CONFIRMUSER AS confirmUser, A.CONFIRMDEPT AS confirmDept, A.VERSIONNUMBER AS versionNumber, pag.IN_TIMES AS inTimes, pag.NAME AS patient, pag.IN_DATE AS inDate, pag.OUT_DATE AS outDate, pag.OUT_DEPT AS outDept, pag.RECORD_STATE AS recordState FROM pag INNER JOIN mrtopration A ON A.ID = pag.ID LEFT JOIN mrtrecordregresses C ON pag.ID = C.RECODE_NO AND A.OPERDATE = C.OPER_DATE AND A.OPERCODE = C.OPERID ORDER BY A.OPERDATE DESC

