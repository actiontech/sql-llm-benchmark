SELECT c.inst_id, m.end_time AS checktime, c.conn, c.activeconn, m.sqlthroughput, m.sqlavgtime, m.user_commits, m.user_rollbacks, m.user_commits+m.user_rollbacks AS transactioncount, m.transactionavgtime FROM (SELECT inst_id, COUNT(*) conn, COUNT(CASE WHEN status='ACTIVE' THEN 1 END) activeconn FROM gv$session WHERE TYPE='USER' GROUP BY inst_id) c, (SELECT * FROM (SELECT inst_id, end_time, metric_name, CASE WHEN metric_name IN ('Executions Per Sec','User Commits Per Sec','User Rollbacks Per Sec') THEN ROUND(VALUE,2) WHEN metric_name IN ('SQL Service Response Time','Response Time Per Txn') THEN ROUND(VALUE*10,2) END VALUE FROM gv$sysmetric WHERE intsize_csec BETWEEN 5950 AND 6049 AND metric_name IN ('Executions Per Sec','User Commits Per Sec','User Rollbacks Per Sec','SQL Service Response Time','Response Time Per Txn')) PIVOT (AVG(VALUE) FOR metric_name IN ('Executions Per Sec' AS sqlthroughput,'SQL Service Response Time' AS sqlavgtime,'User Commits Per Sec' AS user_commits,'User Rollbacks Per Sec' AS user_rollbacks,'Response Time Per Txn' AS transactionavgtime))) m WHERE c.inst_id = m.inst_id ORDER BY c.inst_id

