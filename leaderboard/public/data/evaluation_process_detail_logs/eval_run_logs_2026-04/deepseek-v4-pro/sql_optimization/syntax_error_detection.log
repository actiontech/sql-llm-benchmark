SELECT COUNT(1) stockNum, COUNT(c.FIRST_IN_HOSTSTOCK_DATE) hostStockNum -- , -- DATE_FORMAT( Max(mpd.INSTORE_TIME), '%Y-%m-%d %H:%i:%s') maxStoreTime FROM t_mdm_dlr_car_store c LEFT JOIN t_mdm_dlr_car CAR ON car.CAR_ID = c.CAR_ID LEFT JOIN t_ve_bu_sale_order_d SOD ON SOD.SALE_PLAN_CODE = c.SALES_PLAN_CODE LEFT JOIN t_ve_bu_sale_order SO ON SOD.SALE_ORDER_ID = SO.SALE_ORDER_ID LEFT JOIN t_mdm_ve_car_config con ON con.CAR_CONFIG_ID = car.CAR_CONFIG_ID LEFT JOIN t_ve_bu_inv_apply_d iad ON SO.sale_order_id = iad.link_order_id AND iad.is_Enable='1' LEFT JOIN (SELECT MOVESTOCK_ORDER_CODE, CAR_ID, AUDIT_STATUS, NEW_HOUSE_ID, NEW_DLR_ID FROM (SELECT MOVESTOCK_ORDER_CODE, CAR_ID, AUDIT_STATUS, NEW_HOUSE_ID, NEW_DLR_ID, ROW_NUMBER() OVER (PARTITION BY VIN ORDER BY MOVESTOCK_ORDER_CODE DESC) rn FROM t_ve_bu_movestock_order) t WHERE rn=1) mo ON mo.CAR_ID = c.CAR_ID LEFT JOIN t_ve_bu_month_plan_d mpd ON mpd.SALES_PLAN_CODE = c.SALES_PLAN_CODE LEFT JOIN t_usc_mdm_org_dlr tumod ON c.DLR_ID = tumod.DLR_ID LEFT JOIN T_USC_MDM_ORG_CITY CI ON CI.CITY_ID = tumod.CITY_ID LEFT JOIN t_ve_db_zb_stock tvdzs ON tvdzs.ZB_STOCK_ID = c.CAR_STOCK_HOUSE_ID LEFT JOIN t_ve_db_car_stock_house tvdcsh ON tvdcsh.CAR_STOCK_HOUSE_ID = c.CAR_STOCK_HOUSE_ID LEFT JOIN T_VE_DB_CAR_STOCK_HOUSE SHd ON SHd.CAR_STOCK_HOUSE_ID = c.CAR_SALE_HOUSE_ID LEFT JOIN t_mdm_ve_car_optionalpag optionl ON CAR.OPTIONAL_PAG_ID = optionl.OPTIONAL_PAG_ID LEFT JOIN t_mdm_car_color cols ON CAR.CAR_COLOR_ID = cols.CAR_COLOR_ID LEFT JOIN t_mdm_car_incolor incol ON CAR.CAR_INCOLOR_ID = incol.CAR_INCOLOR_ID LEFT JOIN t_ve_db_car_stock_house oge ON oge.CAR_HOUSE_CODE = SOD.DELIVERY_FAC_HW_CODE LEFT JOIN t_ve_finance_wholesale_purchase_order ord ON ord.SALES_PLAN_CODE = c.SALES_PLAN_CODE LEFT JOIN t_ve_bu_invoice_info_upload tvbiiu ON ord.WHOLESALE_PURCHASE_ORDER_CODE = tvbiiu.WHOLESALE_PURCHASE_ORDER_CODE AND tvbiiu.IS_ENABLE = '1' LEFT JOIN t_prc_mds_lookup_value v5 ON v5.LOOKUP_VALUE_CODE = ord.ORDER_STATUS AND v5.LOOKUP_TYPE_CODE = 'VE1414' LEFT JOIN (SELECT PURCHASE_ORDER_CODE, SALE_PLAN_CODE FROM (SELECT PURCHASE_ORDER_CODE, SALE_PLAN_CODE, ROW_NUMBER() OVER (PARTITION BY SALE_PLAN_CODE ORDER BY PURCHASE_ORDER_CODE DESC) rn FROM t_ve_bu_purchase_order) t WHERE rn=1) purchase ON purchase.SALE_PLAN_CODE = c.SALES_PLAN_CODE WHERE c.IS_ENABLE = '1'

