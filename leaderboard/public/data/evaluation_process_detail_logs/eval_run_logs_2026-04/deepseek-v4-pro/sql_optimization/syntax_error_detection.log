## SQL:
WITH active_users AS (SELECT user_id, username FROM users WHERE status = 'active'), recent_orders AS (SELECT o.order_id, o.user_id, o.order_date FROM orders o INNER JOIN active_users u ON o.user_id = u.user_id WHERE o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 3 YEAR)), top_products AS (SELECT user_id, GROUP_CONCAT(product_name ORDER BY product_name SEPARATOR ', ') AS top_products FROM (SELECT o.user_id, p.product_name, ROW_NUMBER() OVER (PARTITION BY o.user_id ORDER BY SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) DESC) AS rn FROM recent_orders o INNER JOIN order_items oi ON o.order_id = oi.order_id INNER JOIN products p ON oi.product_id = p.product_id GROUP BY o.user_id, p.product_name) t WHERE rn <= 3 GROUP BY user_id) SELECT u.user_id, u.username, COUNT(DISTINCT o.order_id) AS total_orders, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS total_spent, AVG(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS avg_order_value, MAX(o.order_date) AS last_order_date, tp.top_products FROM active_users u INNER JOIN recent_orders o ON u.user_id = o.user_id LEFT JOIN order_items oi ON o.order_id = oi.order_id LEFT JOIN top_products tp ON u.user_id = tp.user_id GROUP BY u.user_id, u.username, tp.top_products HAVING COUNT(DISTINCT o.order_id) > 0 ORDER BY total_spent DESC;

