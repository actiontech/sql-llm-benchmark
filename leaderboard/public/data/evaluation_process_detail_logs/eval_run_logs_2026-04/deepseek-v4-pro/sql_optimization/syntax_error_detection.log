WITH cte AS (SELECT *, ROW_NUMBER() OVER (PARTITION BY CASE WHEN claim_folder_id IS NULL THEN id ELSE claim_folder_id END ORDER BY id DESC) AS rn FROM claim) SELECT cte.id, cte.sap_code, cte.claim_folder_id, DATEDIFF(day, cte.repair_date, GETDATE()) AS DATE_REPAIR_DIFF, cte.claim_status_id AS status, cte.is_e2e AS e2e FROM cte LEFT JOIN serie ON serie.id = cte.serie_id WHERE cte.rn = 1 AND (serie.sap_code = @P0 OR serie.sap_code = CONCAT('4000', @P1)) AND cte.serial_number = @P2 AND cte.production_code = @P3 AND cte.serial_number NOT IN (@P8) AND cte.production_code NOT IN (@P9, @P10, @P11) UNION SELECT cte.id, cte.sap_code, cte.claim_folder_id, DATEDIFF(day, cte.repair_date, GETDATE()) AS DATE_REPAIR_DIFF, cte.claim_status_id AS status, cte.is_e2e AS e2e FROM cte LEFT JOIN serie exchange_serie ON exchange_serie.id = cte.exchange_serie_id WHERE cte.rn = 1 AND (exchange_serie.sap_code = @P4 OR exchange_serie.sap_code = CONCAT('4000', @P5)) AND cte.exchange_serial_number = @P6 AND cte.exchange_production_code = @P7 AND cte.serial_number NOT IN (@P8) AND cte.production_code NOT IN (@P9, @P10, @P11) ORDER BY id DESC

