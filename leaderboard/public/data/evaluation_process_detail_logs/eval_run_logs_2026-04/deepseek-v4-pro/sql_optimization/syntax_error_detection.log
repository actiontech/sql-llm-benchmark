SELECT grouped.*, s.STORE_NAME, l.LOCATION_NAME, q.STANDARD_NAME, c.COLUMN_NAME AS STEEL_GRADE_NAME FROM (SELECT temp.*, t1.SEND_ID AS CONNECT_ID, td.SEND_PRODUCT_DETAIL_ID AS CONNECT_DETAIL_ID, IF(td.SPOT_TYPE='40', IFNULL(td.WEIGHT,0), IFNULL(td.NUMBER,0)) AS SEND_NUMBER, IF(td.SPOT_TYPE='40', IFNULL(ret.WEIGHT,0), IFNULL(ret.NUMBER,0)) AS RETURN_NUMBER FROM t_dgm_send_info_detail td LEFT JOIN t_dgm_send_info t1 ON t1.SEND_ID = td.SEND_ID LEFT JOIN t_dgm_send_info_return_detail ret ON ret.CONNECT_DETAIL_ID = td.SEND_PRODUCT_DETAIL_ID LEFT JOIN (SELECT v.PRODUCE_MATERIAL_ID, IFNULL(v.PACKAGE_NO, v.MATERIAL_NO) AS MIXED_NO, '30' AS SPOT_TYPE, v.MATERIAL_NO, v.PACKAGE_NO, v.PSR_ID, v.CUSTOMER_ID, v.CONTRACT_ID, v.CONTRACT_NO, v.NUMBER, v.NET_WEIGHT, v.GROSS_WT, v.STORE_ID, v.LOCATION_ID, v.STANDARD_ID, v.STEEL_GRADE, v.SURFACE_GROUP_DESC, v.CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, IF((v.LENGTH IS NOT NULL) AND (v.LENGTH != 0), CONCAT(v.THICK,'*',v.WIDTH,'*',v.LENGTH), CONCAT(v.THICK,'*',v.WIDTH,'*C')) AS specs, SUM(IF(d.BUY_UNIT='10', d.TAX_PRICE * v.NET_WEIGHT, d.TAX_PRICE * IFNULL(d.NUMBER,1))) AS PRICE FROM v_pre_product_material v LEFT JOIN t_dgm_send_plan_detail material ON v.MATERIAL_NO = material.MATERIAL_NO LEFT JOIN t_dgm_send_plan_detail package ON v.PACKAGE_NO = package.PACKAGE_NO LEFT JOIN t_mao_contract_delivery_subkey md ON md.CONTRACT_DELIVERY_ID = v.CONTRACT_DELIVERY_ID LEFT JOIN t_sam_contract_detail d ON md.CONTRACT_DETAIL_ID = d.CONTRACT_DETAILS_ID WHERE v.IS_ISSUED = '1' AND v.IS_SPOT_RESOURCE = '0' AND v.NI36_TAG = '0' AND v.MATERIAL_STATE != '110' AND v.CONTRACT_TYPE != '60' AND v.CUSTOMER_ID = '1930921074703462401' AND NOT EXISTS (SELECT 1 FROM v_pre_product_material v2 WHERE (v2.PACKAGE_NO = v.PACKAGE_NO OR v2.MATERIAL_NO = v.MATERIAL_NO) AND v2.IS_ISSUED != '1') GROUP BY COALESCE(v.PACKAGE_NO, v.MATERIAL_NO) UNION ALL SELECT d.CONTRACT_DETAILS_ID AS PRODUCE_MATERIAL_ID, d.PRODUCT_MATERIAL_NO AS MIXED_NO, '10' AS SPOT_TYPE, d.PRODUCT_MATERIAL_NO AS MATERIAL_NO, NULL AS PACKAGE_NO, col.COLUMN_NAME AS PSR_ID, sc.CUSTOMER_ID, sc.CONTRACT_ID, sc.CONTRACT_NO, 1 AS NUMBER, si.NEW_WEIGHT AS NET_WEIGHT, si.GROSS_WT AS GROSS_WT, si.STORE_ID, si.LOCATION_ID, NULL AS STANDARD_ID, si.STEEL_GRADE, NULL AS SURFACE_GROUP_DESC, d.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, si.VARIETY_ID, IF((si.MATERIAL_LENGTH IS NOT NULL AND si.MATERIAL_LENGTH != 0), CONCAT_WS('*',si.MATERIAL_THICK,si.MATERIAL_WIDTH,si.MATERIAL_LENGTH), CONCAT_WS('*',si.MATERIAL_THICK,si.MATERIAL_WIDTH,'C')) AS specs, d.IN_TAX_TOTAL AS PRICE FROM t_sam_contract_detail d LEFT JOIN t_sam_contract sc ON sc.CONTRACT_ID = d.CONTRACT_ID LEFT JOIN t_inm_store_info si ON si.MATERIAL_NO = d.PRODUCT_MATERIAL_NO LEFT JOIN zjjs_mpm.t_bdm_column col ON si.VARIETY_ID = col.COLUMN_ID WHERE sc.CONTRACT_TYPE = '20' AND d.IS_DELETE = '0' AND sc.IS_DELETE = '0' AND d.SPOT_TYPE = '10' AND si.STOCK_ID IS NOT NULL AND sc.CONTRACT_STATE IN ('40','50','70') AND sc.CUSTOMER_ID = '1930921074703462401' GROUP BY d.PRODUCT_MATERIAL_NO UNION ALL SELECT p.PRODUCE_MATERIAL_ID AS PRODUCE_MATERIAL_ID, d.PRODUCT_MATERIAL_NO AS MIXED_NO, '30' AS SPOT_TYPE, d.PRODUCT_MATERIAL_NO AS MATERIAL_NO, p.PACKAGE_NO AS PACKAGE_NO, p.PSR_ID, sc.CUSTOMER_ID, sc.CONTRACT_ID, sc.CONTRACT_NO, p.NUMBER, p.NET_WEIGHT, p.GROSS_WT, p.STORE_ID, p.LOCATION_ID, p.STANDARD_ID, p.STEEL_GRADE, p.SURFACE_GROUP_DESC, d.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, IF((p.LENGTH IS NOT NULL) AND (p.LENGTH != 0), CONCAT(p.THICK,'*',p.WIDTH,'*',p.LENGTH), CONCAT(p.THICK,'*',p.WIDTH,'*C')) AS specs, d.IN_TAX_TOTAL AS PRICE FROM t_sam_contract_detail d LEFT JOIN t_sam_contract sc ON sc.CONTRACT_ID = d.CONTRACT_ID LEFT JOIN t_pre_product_material p ON (d.PRODUCT_MATERIAL_NO = p.PACKAGE_NO OR d.PRODUCT_MATERIAL_NO = p.MATERIAL_NO) WHERE sc.CONTRACT_TYPE = '20' AND d.IS_DELETE = '0' AND sc.IS_DELETE = '0' AND d.SPOT_TYPE IN ('20','30') AND p.PRODUCE_MATERIAL_ID IS NOT NULL AND sc.CONTRACT_STATE IN ('40','50','70') AND sc.CUSTOMER_ID = '1930921074703462401' GROUP BY d.PRODUCT_MATERIAL_NO UNION ALL SELECT d.SCRAP_INFO_ID AS PRODUCE_MATERIAL_ID, s.BATCH_NO AS MIXED_NO, d.SPOT_TYPE AS SPOT_TYPE, s.BATCH_NO AS MATERIAL_NO, s.BATCH_NO AS PACKAGE_NO, s.PRODUCT_NAME AS PSR_ID, sc.CUSTOMER_ID, sc.CONTRACT_ID, sc.CONTRACT_NO, NULL AS NUMBER, s.WEIGHT AS NET_WEIGHT, NULL AS GROSS_WT, '/' AS STORE_ID, '/' AS LOCATION_ID, NULL AS STANDARD_ID, s.STEEL_GRADE, NULL AS SURFACE_GROUP_DESC, d.CONTRACT_DETAILS_ID AS CONTRACT_DETAIL_ID, NULL AS VARIETY_ID, NULL AS specs, s.WEIGHT * d.TAX_PRICE AS PRICE FROM t_sam_contract_detail d LEFT JOIN t_sam_contract sc ON sc.CONTRACT_ID = d.CONTRACT_ID LEFT JOIN t_pre_scrap s ON s.SCRAP_INFO_ID = d.SCRAP_INFO_ID WHERE sc.CONTRACT_TYPE = '20' AND d.IS_DELETE = '0' AND sc.IS_DELETE = '0' AND d.SPOT_TYPE = '40' AND sc.CONTRACT_STATE IN ('40','50','70') AND sc.CUSTOMER_ID = '1930921074703462401' GROUP BY s.BATCH_NO) temp ON temp.MIXED_NO = td.MIXED_NO WHERE t1.SEND_STATE = '70' AND temp.CUSTOMER_ID = '1930921074703462401' GROUP BY temp.MIXED_NO HAVING SEND_NUMBER > RETURN_NUMBER LIMIT 100) grouped LEFT JOIN zjjs_rmm.t_rmm_store s ON s.STORE_ID = grouped.STORE_ID LEFT JOIN zjjs_rmm.t_rmm_location l ON l.LOCATION_ID = grouped.LOCATION_ID LEFT JOIN zjjs_qdm.t_qdm_standard q ON q.STANDARD_ID = grouped.STANDARD_ID LEFT JOIN zjjs_mpm.t_bdm_column c ON c.COLUMN_ID = grouped.STEEL_GRADE

