n_detail.CONNECT_DETAIL_ID = t_dgm_send_info_detail.SEND_PRODUCT_DETAIL_ID LEFT JOIN zjjs_rmm.t_rmm_store t_rmm_store ON t_rmm_store.STORE_ID = temp.STORE_ID LEFT JOIN zjjs_rmm.t_rmm_location t_rmm_location ON t_rmm_location.LOCATION_ID = temp.LOCATION_ID LEFT JOIN zjjs_qdm.t_qdm_standard t_qdm_standard ON t_qdm_standard.STANDARD_ID = temp.STANDARD_ID LEFT JOIN zjjs_mpm.t_bdm_column t_bdm_column ON t_bdm_column.COLUMN_ID = temp.STEEL_GRADE WHERE t_dgm_send_info.SEND_STATE = '70' GROUP BY temp.MIXED_NO HAVING SEND_NUMBER > RETURN_NUMBER LIMIT 100

