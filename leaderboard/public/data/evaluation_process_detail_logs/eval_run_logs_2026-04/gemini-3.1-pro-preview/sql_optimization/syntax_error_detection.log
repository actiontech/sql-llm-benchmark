;WITH rank_general AS (SELECT ta.TIENDA AS id, ROW_NUMBER() OVER (ORDER BY SUM(v.MERCANCIASINIVA) DESC) AS actual_rank_global FROM catalogos.tiendas ta LEFT JOIN flashdeventas.vetas_y_formas_de_pago v ON v.TIENDA = ta.TIENDA WHERE ta.tipo = 'S' AND ta.estatus = 'A' AND ta.marca = 30 GROUP BY ta.TIENDA) SELECT rg.actual_rank_global, t.nombre, vw_r.nombre AS regional, vw_s.nombre AS supervisor, t.estado, 'RUTA' AS ruta, t.m2 AS tienda_m2, 'TAMAÑO' AS tamanio, rj.ranking AS rank_jerarquia_n4, t.ciudad, cam.matrices_min AS propuesta, otr.abierto_otr AS abierto_otr, c.* FROM clusters.tienda_atributos c LEFT JOIN catalogos.tiendas t ON c.tienda = t.tienda LEFT JOIN catalogos.vw_supervisores vw_s ON c.tienda = vw_s.tienda LEFT JOIN catalogos.vw_regionales vw_r ON c.tienda = vw_r.tienda LEFT JOIN rank_general rg ON c.tienda = rg.id CROSS JOIN (SELECT departamento, subdepartamento, clase, subclase, proveedor, estilo, tipo_articulo FROM catalogos.maestro_estilos WHERE proveedor = 1162 AND estilo = 'C21031101') me LEFT JOIN catalogos.ranking_tda_jerarquia rj ON c.tienda = rj.id_tienda AND rj.departamento = me.departamento AND rj.subdepartamento = me.subdepartamento AND rj.clase = me.clase AND rj.subclase = me.subclase LEFT JOIN catalogos.control_asignacion_matrices cam ON rj.ranking = cam.clasificacion OUTER APPLY (SELECT SUM(CASE WHEN m.n >= MONTH(GETDATE()) THEN ISNULL(m.val, 0) ELSE 0 END) AS abierto_otr FROM otr.otr_consulta oc CROSS APPLY (VALUES (1, oc.mes1_compra_adicional), (2, oc.mes2_compra_adicional), (3, oc.mes3_compra_adicional), (4, oc.mes4_compra_adicional), (5, oc.mes5_compra_adicional), (6, oc.mes6_compra_adicional), (7, oc.mes7_compra_adicional), (8, oc.mes8_compra_adicional), (9, oc.mes9_compra_adicional), (10, oc.mes10_compra_adicional), (11, oc.mes11_compra_adicional), (12, oc.mes12_compra_adicional)) m(n, val) WHERE oc.id_tienda = c.tienda AND oc.id_departamento = me.departamento AND oc.id_subdepartamento = me.subdepartamento AND oc.id_clase = me.clase AND oc.id_subclase = me.subclase AND oc.tipo_articulo = me.tipo_articulo) otr WHERE c.centro_comercial = 1 AND c.clima LIKE '%calor todo el tiempo%' AND c.tienda = 3064

