SELECT c.inst_id, m.end_time AS checktime, c.conn, c.activeconn, m.sqlthroughput, m.sqlavgtime, m.user_commits, m.user_rollbacks, m.user_commits + m.user_rollbacks AS transactioncount, m.transactionavgtime FROM (SELECT inst_id, COUNT(*) AS conn, COUNT(CASE WHEN status = 'ACTIVE' THEN 1 END) AS activeconn FROM gv$session WHERE TYPE = 'USER' GROUP BY inst_id) c JOIN (SELECT inst_id, end_time, AVG(CASE WHEN metric_name = 'Executions Per Sec' THEN ROUND(VALUE, 2) END) AS sqlthroughput, AVG(CASE WHEN metric_name = 'SQL Service Response Time' THEN ROUND(VALUE * 10, 2) END) AS sqlavgtime, AVG(CASE WHEN metric_name = 'User Commits Per Sec' THEN ROUND(VALUE, 2) END) AS user_commits, AVG(CASE WHEN metric_name = 'User Rollbacks Per Sec' THEN ROUND(VALUE, 2) END) AS user_rollbacks, AVG(CASE WHEN metric_name = 'Response Time Per Txn' THEN ROUND(VALUE * 10, 2) END) AS transactionavgtime FROM gv$sysmetric WHERE intsize_csec >= 5950 AND intsize_csec < 6050 AND metric_name IN ('Executions Per Sec', 'SQL Service Response Time', 'User Commits Per Sec', 'User Rollbacks Per Sec', 'Response Time Per Txn') GROUP BY inst_id, end_time) m ON c.inst_id = m.inst_id ORDER BY c.inst_id

