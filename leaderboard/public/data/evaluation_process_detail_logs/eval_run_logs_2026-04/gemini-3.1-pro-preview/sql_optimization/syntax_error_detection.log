WITH StudentStats AS (SELECT s_id, COUNT(DISTINCT c_id) AS course_count, AVG(s_score) AS avg_score, SUM(CASE WHEN s_score > 90 THEN 1 ELSE 0 END) AS excellent_course_count FROM Score GROUP BY s_id HAVING AVG(s_score) > 80 AND SUM(CASE WHEN s_score > 90 THEN 1 ELSE 0 END) >= 2) SELECT s.s_id, s.s_name, s.s_sex, ss.course_count, ss.avg_score, ss.excellent_course_count, RANK() OVER (PARTITION BY s.s_sex ORDER BY ss.avg_score DESC) AS gender_rank FROM StudentStats ss JOIN Student s ON ss.s_id = s.s_id ORDER BY ss.avg_score DESC;

