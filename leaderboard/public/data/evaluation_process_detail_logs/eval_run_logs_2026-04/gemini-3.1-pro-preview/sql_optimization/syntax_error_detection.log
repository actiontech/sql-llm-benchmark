SELECT a.register_no AS patientid, a.inpatient_name AS patientname, a.age, a.sex AS gender, date(a.in_date) AS indate, date(a.out_date) AS outdate, a.times AS inhospitaltimes, d.type, d.diagnosis_codes AS diagnosiscode, o.operation_codes AS operationcode, b.total_cost AS medicalcost, a.person_type AS persontype, 'doctor' AS entrymode, a.patient_no AS serialno, 'remind' AS defaulttab, d.chinese_diagnosis_codes AS chinesediagnosiscode, d.chinese_diagnosis_names AS chinesediagnosename, a.current_dept_code AS deptcode, '440100' AS citycode FROM his_temp_ip_patient_info a LEFT JOIN his_temp_ip_settle b ON a.register_no = b.register_no AND a.times = b.times LEFT JOIN LATERAL (SELECT type, diagnosis_codes, chinese_diagnosis_codes, chinese_diagnosis_names FROM (SELECT type, string_agg(CASE WHEN diagnosis_flag = '1' THEN diagnosis_code END, ',' ORDER BY diagnosis_no) AS diagnosis_codes, string_agg(CASE WHEN diagnosis_flag = '0' THEN diagnosis_code END, ',' ORDER BY diagnosis_no) AS chinese_diagnosis_codes, string_agg(CASE WHEN diagnosis_flag = '0' THEN diagnosis_name END, ',' ORDER BY diagnosis_no) AS chinese_diagnosis_names, row_number() OVER (PARTITION BY type ORDER BY CASE WHEN type = '病历诊断' AND diagnosis_type_name = '最后诊断' THEN 1 WHEN type = '病历诊断' AND diagnosis_type_name = '初步诊断' THEN 2 WHEN type = '首页诊断' AND diagnosis_type_name = '出院诊断' THEN 1 WHEN type = '首页诊断' AND diagnosis_type_name = '门诊诊断' THEN 2 ELSE 3 END) AS rn FROM emr_temp_ip_patient_diagnosis d_inner WHERE d_inner.inp_no = a.register_no AND d_inner.visit_id = a.times AND d_inner.file_visit_type = '2' GROUP BY type, diagnosis_type_name) sub WHERE rn = 1) d ON true LEFT JOIN LATERAL (SELECT string_agg(operation_code, ',' ORDER BY operation_no) AS operation_codes FROM emr_temp_ip_patient_operation o_inner WHERE o_inner.inp_no = a.register_no AND o_inner.visit_id = a.times) o ON true WHERE a.out_date >= '2025-01-02' ORDER BY a.out_date DESC;

