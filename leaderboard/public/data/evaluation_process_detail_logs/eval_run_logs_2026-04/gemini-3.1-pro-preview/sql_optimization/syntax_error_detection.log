SELECT A.ID AS id, A.PRAMARYID AS primaryId, A.OPERCODE AS operCode, A.OPERNAME AS operName, A.OPERDEPT AS operDept, A.OPERDATE AS operDate, A.MARK AS mark, C.BACKREASON AS mark1, A.MARK2 AS mark2, A.MARK3 AS mark3, A.MARK4 AS mark4, A.OPERTYPE AS operType, A.NEXTOPERTYPE AS nextOperType, A.PREOPERTYPE AS preOperType, A.VALID AS valid, A.CONFIRMUSER AS confirmUser, A.CONFIRMDEPT AS confirmDept, A.VERSIONNUMBER AS versionNumber, B.IN_TIMES AS inTimes, B.NAME AS patient, B.IN_DATE AS inDate, B.OUT_DATE AS outDate, B.OUT_DEPT AS outDept, B.RECORD_STATE AS recordState FROM mrtopration A INNER JOIN mrtrecordinfo B ON A.ID = B.ID LEFT JOIN mrtrecordregresses C ON B.ID = C.RECODE_NO AND A.OPERDATE = C.OPER_DATE AND A.OPERCODE = C.OPERID WHERE A.ID IN (SELECT bid FROM (SELECT B.ID AS bid, ROW_NUMBER() OVER (ORDER BY B.IN_DATE DESC) AS rn FROM mrtopration A INNER JOIN mrtrecordinfo B ON A.ID = B.ID WHERE TO_CHAR(B.ID) LIKE :"SYS_B_0" || :1 || :" SYS_B_1") WHERE rn BETWEEN :2 + :"SYS_B_2" AND :3 + :4) ORDER BY A.OPERDATE DESC

