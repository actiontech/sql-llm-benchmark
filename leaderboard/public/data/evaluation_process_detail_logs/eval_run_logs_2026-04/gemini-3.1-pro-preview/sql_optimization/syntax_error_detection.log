_GET_DESC_CHINA(EE.IS_OVERDUE) AS IS_OVERDUE_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.WARRANTY_GRADE_ID) AS WARRANTY_GRADE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.IS_OUTMAINTENANCE_ID) AS IS_OUTMAINTENANCE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.ASSETS_RECEIVE_TYPE_ID) AS ASSETS_RECEIVE_TYPE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.ENTITY_CREATE_SOURCE_ID) AS ENTITY_CREATE_SOURCE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.SOURCE_SYSTEM_ID) AS SOURCE_SYSTEM_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.CHECK_RESULT_ID) AS CHECK_RESULT_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.SERVICE_STATE_ID) AS SERVICE_STATE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.IS_MONITOR_ID) AS IS_MONITOR_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.MONITOR_STYLE_ID) AS MONITOR_STYLE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.IS_UPLOAD_PHOTO) AS IS_UPLOAD_PHOTO_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.STORAGE_STATE_ID) AS STORAGE_STATE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.IS_STORAGE) AS IS_STORAGE_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.RES_FROM_PROJBUILDTYPE_ID) AS RES_FROM_PROJBUILDTYPE_ID_TEXT, RES_ENTITY.SF_GET_DESC_CHINA(EE.SPLIT_MERGE_REASON_ID) AS SPLIT_MERGE_REASON_ID_TEXT, EE.SOURCE_RES_NO AS SOURCE_RES_NO_TEXT, (SELECT ENTITY_NAME FROM res_entity.ent_entity WHERE ENTITY_ID=EE.ROOM_ID and res_type_id='205' and delete_state='0') AS ROOM_ID_TEXT, (SELECT RES_TYPE FROM RES_SYS.PUB_DIC_RES_TYPE WHERE RES_TYPE_ID=EE.RES_TYPE_ID and delete_state='0') AS RES_TYPE_ID_TEXT, (SELECT EQP_TYPE FROM RES_SYS.PUB_DIC_EQP_TYPE WHERE EQP_TYPE_ID=EE.DEV_TYPE_ID and delete_state='0') AS DEV_TYPE_ID_TEXT, (SELECT EQP_MODEL FROM RES_SYS.PUB_RME_EQP_MODEL WHERE EQP_MODEL_ID=EE.DEV_MODEL_ID and delete_state='0') AS DEV_MODEL_ID_TEXT, (SELECT EQP_MODEL FROM RES_SYS.PUB_RME_EQP_MODEL WHERE EQP_MODEL_ID=EE.OLD_DEV_MODEL_ID and delete_state='0') AS OLD_DEV_MODEL_ID_TEXT, (SELECT MFR FROM RES_SYS.PUB_MFR WHERE MFR_ID=EE.MFR_ID and delete_state='0') AS MFR_ID_TEXT, (SELECT MFR FROM RES_SYS.PUB_MFR WHERE MFR_ID=EE.DW_MFR_ID and delete_state='0') AS DW_MFR_ID_TEXT, (SELECT MFR FROM RES_SYS.PUB_MFR WHERE MFR_ID=EE.OLD_DW_MFR_ID and delete_state='0') AS OLD_DW_MFR_ID_TEXT, (SELECT MFR FROM RES_SYS.PUB_MFR WHERE MFR_ID=EE.MNT_MFR_ID and delete_state='0') AS MNT_MFR_ID_TEXT, RES_ENTITY.SF_GET_STAFF_NAME(EE.MODIFY_OP) AS MODIFY_OP_TEXT, RES_ENTITY.SF_GET_STAFF_NAME(EE.CREATE_OP) AS CREATE_OP_TEXT, RES_ENTITY.SF_GET_STAFF_NAME(EE.CHECK_PERSON) AS CHECK_PERSON_TEXT, ST.DISTRICT_PROVINCE_ID, ST.DISTRICT_REGION_ID, ST.DISTRICT_COUNTY_ID, ST.STATION_NAME, ST.STATION_NAME AS STATION_ID_TEXT, D.APP_REGION_ID, (SELECT REGION_NAME FROM res_entity.REG_MANAGE WHERE REGION_ID = D.APP_REGION_ID AND delete_state = '0') AS APP_REGION_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_PROVINCE_ID) AS DISTRICT_PROVINCE_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_REGION_ID) AS DISTRICT_REGION_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_COUNTY_ID) AS DISTRICT_COUNTY_ID_TEXT, res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_PROVINCE_ID) || res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_REGION_ID) || res_entity.SF_GET_DISTRICT_NAME(ST.DISTRICT_COUNTY_ID) AS REGION_ID_TEXT FROM RES_ENTITY.ENT_ENTITY EE INNER JOIN (SELECT DISTINCT STATION_CODE FROM res_entity.sta_biz_info WHERE REGION_ID IN (SELECT REGION_ID FROM res_entity.reg_manage CONNECT BY PRIOR REGION_ID = SUPER_REGION_ID AND NVL(delete_state, '0') = '0' START WITH region_id IN ('000102000000000000370100'))) V_STA ON EE.STATION_CODE = V_STA.STATION_CODE LEFT JOIN RES_ENTITY.ENT_ROOM B ON B.ENTITY_ID = EE.ENTITY_ID LEFT JOIN RES_ENTITY.STA_STATION ST ON ST.STATION_CODE = EE.STATION_CODE LEFT JOIN RES_ENTITY.STA_APP_INFO D ON ST.STATION_ID=D.STATION_ID WHERE EE.DELETE_STATE = '0' AND EE.RES_TYPE_ID=205) t where ROWNUM <= 10) where rn > 0;

