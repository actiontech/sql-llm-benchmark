SELECT DISTINCT a.acc_account_no, a.acc_subacc_no, ah.acch_title, TO_CHAR(a.acc_incep_date, 'DD/MM/YYYY') AS acc_incep_date, htax.acctax_eff_date_from, TO_CHAR(aud.audh_date, 'DD-MON-YYYY') AS approved_date, aty.act_long_name, t.tran_amount_cr, t.tran_create_by, CASE WHEN (TRUNC(a.acc_incep_date) - TRUNC(aud.audh_date)) < 0 THEN 0 ELSE (TRUNC(a.acc_incep_date) - TRUNC(aud.audh_date)) END AS time_on_approved, ah.acch_brn_code FROM accounts a JOIN account_headers ah ON ah.acch_account_no = a.acc_account_no JOIN account_types aty ON aty.act_code = a.acc_act_code JOIN (SELECT tran_account_no, tran_subacc_no, MIN(tran_amount_cr) KEEP (DENSE_RANK FIRST ORDER BY tran_seqno) AS tran_amount_cr, MIN(tran_create_by) KEEP (DENSE_RANK FIRST ORDER BY tran_seqno) AS tran_create_by FROM transactions WHERE tran_amount_cr IS NOT NULL AND tran_trans_code IN ('RIC', 'RSAV') AND tran_date BETWEEN IN_FUND_FROM_DATE AND IN_FUND_TO_DATE AND tran_pay_method NOT IN ('C', 'CQ') GROUP BY tran_account_no, tran_subacc_no) t ON t.tran_account_no = a.acc_account_no AND t.tran_subacc_no = a.acc_subacc_no JOIN audit_header aud ON aud.audh_key1 = a.acc_account_no AND aud.audh_key2 = a.acc_subacc_no JOIN audit_detail audd ON audd.audd_audh_seqno = aud.audh_seqno JOIN account_links al ON al.accl_account_no = a.acc_account_no AND al.accl_subacc_no = a.acc_subacc_no JOIN SUMMIT.account_holding_tax htax ON htax.acctax_account_no = al.accl_account_no AND htax.acctax_subacc_no = al.accl_subacc_no AND htax.acctax_cust_seqno = al.accl_cust_seqno WHERE a.acc_gact_type IN ('S', 'IC') AND a.acc_incep_date BETWEEN IN_INCEP_FROM_DATE AND IN_INCEP_TO_DATE AND aud.audh_table_prefix = 'ACC' AND aud.audh_change_type = 'I' AND audd.audd_col_sufix = 'PROCESS_STATUS' AND audd.audd_old_value IS NULL AND audd.audd_new_value = '1' AND al.accl_holder_pos = 1

