## SQL:
WITH cte_users AS (SELECT u.user_id, u.username, COUNT(DISTINCT o.order_id) AS total_orders, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS total_spent, AVG(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS avg_order_value, MAX(o.order_date) AS last_order_date FROM users u JOIN orders o ON u.user_id = o.user_id LEFT JOIN order_items oi ON o.order_id = oi.order_id WHERE u.status = 'active' AND o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL '3' YEAR) GROUP BY u.user_id, u.username HAVING COUNT(DISTINCT o.order_id) > 0), cte_top_products AS (SELECT oi2.user_id, GROUP_CONCAT(DISTINCT oi2.product_name ORDER BY oi2.product_name SEPARATOR ', ') AS top_products FROM (SELECT o3.user_id, p.product_name, ROW_NUMBER() OVER (PARTITION BY o3.user_id ORDER BY SUM(oi2.quantity * oi2.unit_price * (1 - oi2.discount / 100)) DESC) AS rank_num FROM order_items oi2 JOIN products p ON oi2.product_id = p.product_id JOIN orders o3 ON o3.order_id = oi2.order_id JOIN cte_users cu ON o3.user_id = cu.user_id GROUP BY o3.user_id, p.product_name) oi2 WHERE oi2.rank_num <= 3 GROUP BY oi2.user_id) SELECT cu.user_id, cu.username, cu.total_orders, cu.total_spent, cu.avg_order_value, cu.last_order_date, tp.top_products FROM cte_users cu LEFT JOIN cte_top_products tp ON cu.user_id = tp.user_id ORDER BY cu.total_spent DESC;

