WITH trans_agg AS (SELECT A.tenant_id, A.gl_account_id, B.acctg_period, SUM(A.base_posted_dr) AS base_posted_dr1, SUM(A.base_posted_cr) AS base_posted_cr1 FROM acctg_trans_detail A LEFT JOIN acctg_trans B ON A.master_voucher_id = B.id AND A.tenant_id = B.tenant_id WHERE A.tenant_id = 1065587309019136 AND (A.voucher_status_enum IS NULL OR A.voucher_status_enum != 'CANCELLED') AND (B.id IS NULL OR (B.tenant_id = 1065587309019136 AND (B.bo_name IS NULL OR B.bo_name != 'DraftAcctgTrans'))) GROUP BY A.tenant_id, A.gl_account_id, B.acctg_period) SELECT t.tenant_id, t.gl_account_id, ac.code, t.acctg_period, b.base_posted_dr, b.base_posted_cr, t.base_posted_dr1, t.base_posted_cr1 FROM trans_agg t LEFT JOIN gl_account_balance b ON b.gl_account_id = t.gl_account_id AND b.acctg_period = t.acctg_period AND b.tenant_id = t.tenant_id LEFT JOIN gl_account ac ON ac.id = t.gl_account_id AND ac.tenant_id = t.tenant_id WHERE b.id IS NULL OR t.base_posted_dr1 != IFNULL(b.base_posted_dr, 0) OR t.base_posted_cr1 != IFNULL(b.base_posted_cr, 0) UNION ALL SELECT b.tenant_id, b.gl_account_id, ac.code, b.acctg_period, b.base_posted_dr, b.base_posted_cr, t.base_posted_dr1, t.base_posted_cr1 FROM gl_account_balance b LEFT JOIN trans_agg t ON t.gl_account_id = b.gl_account_id AND t.acctg_period = b.acctg_period AND t.tenant_id = b.tenant_id LEFT JOIN gl_account ac ON ac.id = b.gl_account_id AND ac.tenant_id = b.tenant_id WHERE b.tenant_id = 1065587309019136 AND b.acctg_period NOT LIKE '%00' AND t.gl_account_id IS NULL AND (b.base_posted_dr != IFNULL(t.base_posted_dr1, 0) OR b.base_posted_cr != IFNULL(t.base_posted_cr1, 0)) LIMIT 50001;

