  AND MANDT = '500'
  AND BUZEI = '002'
  AND WAERS = 'INR'
  AND MONAT = '01'
  AND BLDAT = '20240401'
  ) b
  JOIN SAPR3.BKPF k
   ON b.BELNR = k.BELNR
  AND b.GJAHR = k.GJAHR
  AND b.BUKRS = k.BUKRS
) t
ORDER BY t.age;

