  `ADDRESS` text,
  `LEGAL_ADDRESS` text,
  `SHORT_DESCRIPTION` varchar(512) DEFAULT NULL,
  `DESCRIPTION` longtext,
  `DESCRIPTION_TEXT` longtext,
  `SPECIAL_POLICY` longtext,
  `SALUTATORY` longtext,
  `EXTEND` longtext,
  `LANG_TYPE` int(11) DEFAULT NULL COMMENT '[LANG_TYPE] 0 中文 1 英文 2 法文',
  `REMARK` longtext,
  `GUIDE` longtext COMMENT '到店指引',
