STAFF_NAME(EE.MODIFY_OP) AS MODIFY_OP_TEXT,RES_ENTITY.SF_GET_STAFF_NAME(EE.CREATE_OP) AS CREATE_OP_TEXT,RES_ENTITY.SF_GET_STAFF_NAME(EE.CHECK_PERSON) AS CHECK_PERSON_TEXT,ST.DISTRICT_PROVINCE_ID,ST.DISTRICT_REGION_ID,ST.DISTRICT_COUNTY_ID,ST.STATION_NAME,ST.STATION_NAME AS STATION_ID_TEXT,D.APP_REGION_ID,APPREG.REGION_NAME AS APP_REGION_ID_TEXT,RES_ENTITY.SF_GET_DISTRICT_NAME(ST.DISTRICT_PROVINCE_ID) AS DISTRICT_PROVINCE_ID_TEXT,RES_ENTITY.SF_GET_DISTRICT_NAME(ST.DISTRICT_REGION_ID) AS DISTRICT_REGION_ID_TEXT,RES_ENTITY.SF_GET_DISTRICT_NAME(ST.DISTRICT_COUNTY_ID) AS DISTRICT_COUNTY_ID_TEXT,RES_ENTITY.SF_GET_DISTRICT_NAME(ST.DISTRICT_PROVINCE_ID)||RES_ENTITY.SF_GET_DISTRICT_NAME(ST.DISTRICT_REGION_ID)||RES_ENTITY.SF_GET_DISTRICT_NAME(ST.DISTRICT_COUNTY_ID) AS REGION_ID_TEXT FROM L JOIN RES_ENTITY.ENT_ENTITY EE ON EE.ROWID=L.EE_RID LEFT JOIN RES_ENTITY.ENT_ROOM B ON B.ROWID=L.B_RID LEFT JOIN RES_ENTITY.STA_STATION ST ON ST.STATION_ID=L.ST_ID LEFT JOIN RES_ENTITY.STA_APP_INFO D ON D.ROWID=L.D_RID LEFT JOIN RES_SYS.PUB_MFR PM_AC ON PM_AC.MFR_ID=B.INTEG_CABINET_AC_MFR_ID AND PM_AC.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_EQP_TYPE CAT ON CAT.EQP_TYPE_ID=B.CATEGORY_IDENT_RESULT_ID AND CAT.DELETE_STATE='0' LEFT JOIN RES_ENTITY.ENT_ENTITY ROOM_E ON ROOM_E.ENTITY_ID=EE.ROOM_ID AND ROOM_E.RES_TYPE_ID=205 AND ROOM_E.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_RES_TYPE RT ON RT.RES_TYPE_ID=EE.RES_TYPE_ID AND RT.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_DIC_EQP_TYPE DEVT ON DEVT.EQP_TYPE_ID=EE.DEV_TYPE_ID AND DEVT.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_RME_EQP_MODEL DM ON DM.EQP_MODEL_ID=EE.DEV_MODEL_ID AND DM.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_RME_EQP_MODEL ODM ON ODM.EQP_MODEL_ID=EE.OLD_DEV_MODEL_ID AND ODM.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR PM ON PM.MFR_ID=EE.MFR_ID AND PM.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR DWM ON DWM.MFR_ID=EE.DW_MFR_ID AND DWM.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR ODWM ON ODWM.MFR_ID=EE.OLD_DW_MFR_ID AND ODWM.DELETE_STATE='0' LEFT JOIN RES_SYS.PUB_MFR MNTM ON MNTM.MFR_ID=EE.MNT_MFR_ID AND MNTM.DELETE_STATE='0' LEFT JOIN RES_ENTITY.REG_MANAGE APPREG ON APPREG.REGION_ID=D.APP_REGION_ID AND APPREG.DELETE_STATE='0') Q) WHERE RN>0

