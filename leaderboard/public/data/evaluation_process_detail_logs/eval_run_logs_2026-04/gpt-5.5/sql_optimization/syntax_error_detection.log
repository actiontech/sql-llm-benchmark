SELECT DISTINCT a.acc_account_no, a.acc_subacc_no, ah.acch_title, TO_CHAR(a.acc_incep_date,'DD/MM/YYYY') acc_incep_date, htax.acctax_eff_date_from, TO_CHAR(oh.audh_date,'DD-MON-YYYY') approved_date, aty.act_long_name, ft.tran_amount_cr, ft.tran_create_by, CASE WHEN (TRUNC(a.acc_incep_date) - TRUNC(oh.audh_date)) < 0 THEN 0 ELSE (TRUNC(a.acc_incep_date) - TRUNC(oh.audh_date)) END time_on_approved, ah.acch_brn_code FROM accounts a JOIN account_headers ah ON ah.acch_account_no = a.acc_account_no JOIN account_types aty ON aty.act_code = a.acc_act_code CROSS APPLY (SELECT t.tran_amount_cr, t.tran_create_by FROM transactions t WHERE t.tran_account_no = a.acc_account_no AND t.tran_subacc_no = a.acc_subacc_no AND t.tran_amount_cr IS NOT NULL AND t.tran_trans_code IN ('RIC','RSAV') AND t.tran_date BETWEEN IN_FUND_FROM_DATE AND IN_FUND_TO_DATE AND t.tran_pay_method NOT IN ('C','CQ') ORDER BY t.tran_seqno FETCH FIRST 1 ROW ONLY) ft JOIN audit_header oh ON oh.audh_key1 = a.acc_account_no AND oh.audh_key2 = a.acc_subacc_no AND oh.audh_table_prefix = 'ACC' AND oh.audh_change_type = 'I' AND EXISTS (SELECT 1 FROM audit_detail od WHERE od.audd_audh_seqno = oh.audh_seqno AND od.audd_col_sufix = 'PROCESS_STATUS' AND od.audd_old_value IS NULL AND od.audd_new_value = '1') JOIN account_links al ON al.accl_account_no = a.acc_account_no AND al.accl_subacc_no = a.acc_subacc_no AND al.accl_holder_pos = 1 JOIN summit.account_holding_tax htax ON htax.acctax_account_no = al.accl_account_no AND htax.acctax_subacc_no = al.accl_subacc_no AND htax.acctax_cust_seqno = al.accl_cust_seqno WHERE a.acc_gact_type IN ('S','IC') AND a.acc_incep_date BETWEEN IN_INCEP_FROM_DATE AND IN_INCEP_TO_DATE

