## SQL:
WITH fp AS MATERIALIZED (SELECT a.register_no AS patientid,a.inpatient_name AS patientname,a.age,a.sex AS gender,date(a.in_date) AS indate,date(a.out_date) AS outdate,a.times AS inhospitaltimes,a.person_type AS persontype,a.patient_no AS serialno,b.total_cost AS medicalcost,'doctor' AS entrymode,'remind' AS defaulttab,a.current_dept_code AS deptcode,'440100' AS citycode FROM his_temp_ip_patient_info a LEFT JOIN his_temp_ip_settle b ON b.register_no=a.register_no AND b.times=a.times WHERE a.out_date>=TIMESTAMP '2025-01-02'), fp_keys AS MATERIALIZED (SELECT DISTINCT patientid,inhospitaltimes FROM fp), diagnosis AS MATERIALIZED (SELECT d.inp_no,d.visit_id AS times,d.type,d.diagnosis_type_name,string_agg(d.diagnosis_code,',' ORDER BY d.diagnosis_no) FILTER (WHERE d.diagnosis_flag='1') AS diagnosis_codes,string_agg(d.diagnosis_code,',' ORDER BY d.diagnosis_no) FILTER (WHERE d.diagnosis_flag='0') AS chinese_diagnosis_codes,string_agg(d.diagnosis_name,',' ORDER BY d.diagnosis_no) FILTER (WHERE d.diagnosis_flag='0') AS chinese_diagnosis_names FROM emr_temp_ip_patient_diagnosis d JOIN fp_keys k ON k.patientid=d.inp_no AND k.inhospitaltimes=d.visit_id WHERE d.file_visit_type='2' GROUP BY d.inp_no,d.visit_id,d.type,d.diagnosis_type_name), diagnosis_end AS (SELECT inp_no,times,type,diagnosis_type_name,diagnosis_codes,chinese_diagnosis_codes,chinese_diagnosis_names FROM (SELECT d.*,row_number() OVER (PARTITION BY d.inp_no,d.times,d.type ORDER BY CASE WHEN d.type='病历诊断' AND d.diagnosis_type_name='最后诊断' THEN 1 WHEN d.type='病历诊断' AND d.diagnosis_type_name='初步诊断' THEN 2 WHEN d.type='首页诊断' AND d.diagnosis_type_name='出院诊断' THEN 1 WHEN d.type='首页诊断' AND d.diagnosis_type_name='门诊诊断' THEN 2 ELSE 3 END) AS rn FROM diagnosis d) x WHERE rn=1), operations AS MATERIALIZED (SELECT o.inp_no,o.visit_id AS times,string_agg(o.operation_code,',' ORDER BY o.operation_no) AS operation_codes FROM emr_temp_ip_patient_operation o JOIN fp_keys k ON k.patientid=o.inp_no AND k.inhospitaltimes=o.visit_id GROUP BY o.inp_no,o.visit_id) SELECT t.patientid,t.patientname,t.age,t.gender,t.indate,t.outdate,t.inhospitaltimes,d.type,d.diagnosis_codes AS diagnosiscode,o.operation_codes AS operationcode,t.medicalcost,t.persontype,t.entrymode,t.serialno,t.defaulttab,d.chinese_diagnosis_codes AS chinesediagnosiscode,d.chinese_diagnosis_names AS chinesediagnosename,t.deptcode,t.citycode FROM fp t LEFT JOIN diagnosis_end d ON d.inp_no=t.patientid AND d.times=t.inhospitaltimes LEFT JOIN operations o ON o.inp_no=t.patientid AND o.times=t.inhospitaltimes ORDER BY t.outdate DESC

