## SQL:
WITH q AS (SELECT c.id,c.sap_code,c.claim_folder_id,DATEDIFF(day,c.repair_date,GETDATE()) AS DATE_REPAIR_DIFF,c.claim_status_id AS status,c.is_e2e AS e2e FROM claim c INNER JOIN serie s ON s.id=c.serie_id AND s.sap_code IN (@P0,CONCAT('4000',@P1)) WHERE c.serial_number=@P2 AND c.production_code=@P3 AND c.serial_number NOT IN (@P8) AND c.production_code NOT IN (@P9,@P10,@P11) AND (c.claim_folder_id IS NULL OR NOT EXISTS (SELECT 1 FROM claim c2 WHERE c2.claim_folder_id=c.claim_folder_id AND c2.id>c.id)) UNION SELECT c.id,c.sap_code,c.claim_folder_id,DATEDIFF(day,c.repair_date,GETDATE()) AS DATE_REPAIR_DIFF,c.claim_status_id AS status,c.is_e2e AS e2e FROM claim c INNER JOIN serie es ON es.id=c.exchange_serie_id AND es.sap_code IN (@P4,CONCAT('4000',@P5)) WHERE c.exchange_serial_number=@P6 AND c.exchange_production_code=@P7 AND c.serial_number NOT IN (@P8) AND c.production_code NOT IN (@P9,@P10,@P11) AND (c.claim_folder_id IS NULL OR NOT EXISTS (SELECT 1 FROM claim c2 WHERE c2.claim_folder_id=c.claim_folder_id AND c2.id>c.id))) SELECT id,sap_code,claim_folder_id,DATE_REPAIR_DIFF,status,e2e FROM q ORDER BY id DESC

