TEG_CABINET_AC_NUM_ID) AS INTEG_CABINET_AC_NUM_ID_TEXT,B.INTEG_CABINET_AC_MFR_ID,B.INTEG_CABINET_AC_MODEL,PM_AC.MFR AS INTEG_CABINET_AC_MFR_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(EE.TIME_TO_OVERDUE) AS TIME_TO_OVERDUE_TEXT,CAT.EQP_TYPE AS CATEGORY_IDENT_RESULT_ID_TEXT,RES_ENTITY.SF_GET_STAFF_NAME(B.AGENT_MNT_CONTACT) AS AGENT_MNT_CONTACT_TEXT,CASE WHEN B.IS_VR_FULLSCENE_ID=1 THEN '有' WHEN B.IS_VR_FULLSCENE_ID=0 THEN '无' END AS IS_VR_FULLSCENE_ID_TEXT,CASE WHEN B.AIRBLAST_STYLE=1 THEN '下送风' WHEN B.AIRBLAST_STYLE=0 THEN '上送风' END AS AIRBLAST_STYLE_TEXT,CASE WHEN B.WNG_STYLE=1 THEN '上走线' WHEN B.WNG_STYLE=0 THEN '下走线' END AS WNG_STYLE_STYLE_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.IS_SHARE) AS IS_SHARE_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.SHARE_UNIT_ID) AS SHARE_UNIT_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.AUDIT_FLOW_RESULT_ID) AS AUDIT_FLOW_RESULT_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.ENT_AUDIT_RESULT_ID) AS ENT_AUDIT_RESULT_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.PRODUCT_TYPE) AS PRODUCT_TYPE_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.IS_OIL_MACH_ROOM) AS IS_OIL_MACH_ROOM_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.IS_HAVE_WALL) AS IS_HAVE_WALL_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.STRUCTURE_ID) AS STRUCTURE_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.VACANT_CABLE_SEAT) AS VACANT_CABLE_SEAT_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.STATION_ROAD_ID) AS STATION_ROAD_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.DEGREE_ARRIVAL_ID) AS DEGREE_ARRIVAL_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.IS_ARRIVEL) AS IS_ARRIVEL_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.IS_POWER) AS IS_POWER_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.INOUT_MODE) AS INOUT_MODE_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.IS_EXPAND_OIL_ROOM) AS IS_EXPAND_OIL_ROOM_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.SECURITY_ENVIRONMENT_ID) AS SECURITY_ENVIRONMENT_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.WNG_STYLE) AS WNG_STYLE_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(B.ROOM_GRADE_ID) AS ROOM_GRADE_ID_TEXT,RES_ENTITY.SF_GET_DESC_CHINA(EE.CHECK_MODE_ID) AS CHECK_MODE_ID_TEXT,RES_ENTITY.SF_GET_DESC_