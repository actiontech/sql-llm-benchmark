WITH s_filtered AS (SELECT /*+ MATERIALIZE */ * FROM SETL_D_MERGED WHERE FUND_PAY_SUMAMT <> 0), fl AS (SELECT f.setl_id, LISTAGG(DISTINCT f.MEDINS_LIST_CODG, ',') WITHIN GROUP (ORDER BY f.MEDINS_LIST_CODG) b_medins_list_codg, LISTAGG(DISTINCT f.medins_list_name, ',') WITHIN GROUP (ORDER BY f.medins_list_name) b_medins_list_name, LISTAGG(DISTINCT f.hilist_code, ',') WITHIN GROUP (ORDER BY f.hilist_code) b_hilist_code, LISTAGG(DISTINCT f.hilist_name, ',') WITHIN GROUP (ORDER BY f.hilist_name) b_hilist_name, LISTAGG(DISTINCT f.MED_CHRGITM_TYPE_NAME, ',') WITHIN GROUP (ORDER BY f.MED_CHRGITM_TYPE_NAME) MED_CHRGITM_TYPE, LISTAGG(DISTINCT f.CHRGITM_LV_NAME, ',') WITHIN GROUP (ORDER BY f.CHRGITM_LV_NAME) CHRGITM_LV, LISTAGG(DISTINCT f.BILG_DEPT_NAME, ',') WITHIN GROUP (ORDER BY f.BILG_DEPT_NAME) BILG_DEPT_NAME, LISTAGG(DISTINCT f.BILG_DR_NAME, ',') WITHIN GROUP (ORDER BY f.BILG_DR_NAME) BILG_DR_NAME, LISTAGG(DISTINCT f.ACORD_DEPT_NAME, ',') WITHIN GROUP (ORDER BY f.ACORD_DEPT_NAME) ACORD_DEPT_NAME, LISTAGG(DISTINCT f.ACORD_DR_NAME, ',') WITHIN GROUP (ORDER BY f.ACORD_DR_NAME) ACORD_DR_NAME, SUM(f.cnt) b_cnt, SUM(f.det_item_fee_sumamt) b_fee, MIN(f.pric) min_pric, MIN(ABS(f.inscp_amt / f.cnt)) min_amt FROM FEE_LIST_D f JOIN s_filtered s ON s.setl_id = f.setl_id WHERE f.cnt <> 0 AND f.CHRGITM_LV_NAME IN ('甲类','乙类') GROUP BY f.setl_id HAVING SUM(f.cnt) > MAX(s.ipt_days * 12 + 24)) SELECT s.fixmedins_code 医院代码, s.fixmedins_name 医院名称, s.HOSP_LV_NAME 医院级别, s.setl_id 结算单据号, s.mdtrt_id 就诊ID, s.ipt_otp_no 住院号, s.psn_no 个人编号, s.psn_name 姓名, s.certno 身份证号, s.GEND_NAME 性别, s.brdy 出生日期, s.age 年龄, s.insu_admdvs 统筹区, s.INSUTYPE_NAME 险种类型, s.PSN_TYPE_NAME 医疗人员类别, s.SP_PSN_TYPE_NAME 特殊人员身份类别, s.med_type_name 就医类型, s.PAY_LOC_NAME 支付地点类别, s.setl_time 结算日期, s.adm_dept_name 入院科室, s.dscg_dept_name 出院科室, s.begntime 入院日期, s.endtime 出院日期, s.IPT_DAYS 天数, s.chfpdr_name 主治医生, s.adm_diag_dscr 入院诊断, s.dscg_maindiag_name 出院诊断, s.DIAG_NAME 其他诊断, s.dise_no 病种编码, s.dise_name 病种名称, s.OPRN_NAME 手术及操作名称, s.me