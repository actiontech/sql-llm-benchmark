SELECT s.s_id, s.s_name, s.s_sex, st.course_count, st.avg_score, st.excellent_course_count, RANK() OVER (PARTITION BY s.s_sex ORDER BY st.avg_score DESC) AS gender_rank FROM Student s JOIN (SELECT s_id, COUNT(DISTINCT c_id) AS course_count, AVG(s_score) AS avg_score, COUNT(*) FILTER (WHERE s_score > 90) AS excellent_course_count FROM Score GROUP BY s_id HAVING AVG(s_score) > 80 AND COUNT(*) FILTER (WHERE s_score > 90) >= 2) st ON st.s_id = s.s_id ORDER BY st.avg_score DESC;

