WITH tiendas_filtradas AS (SELECT TIENDA FROM catalogos.tiendas WHERE tipo='S' AND estatus='A' AND marca=30), ventas_tienda AS (SELECT tf.TIENDA AS id,SUM(v.MERCANCIASINIVA) AS total_venta FROM tiendas_filtradas tf LEFT JOIN flashdeventas.vetas_y_formas_de_pago v ON v.TIENDA=tf.TIENDA GROUP BY tf.TIENDA), rank_general AS (SELECT id,ROW_NUMBER() OVER (ORDER BY total_venta DESC) AS actual_rank_global FROM ventas_tienda), filtered_c AS (SELECT * FROM clusters.tienda_atributos WHERE tienda=3064 AND centro_comercial=1 AND clima LIKE '%calor todo el tiempo%'), me AS (SELECT departamento,subdepartamento,clase,subclase,proveedor,estilo,tipo_articulo FROM catalogos.maestro_estilos WHERE proveedor=1162 AND estilo='C21031101') SELECT rg.actual_rank_global,t.nombre,t.nombre AS regional,t.nombre AS supervisor,t.estado,'RUTA' AS ruta,t.m2 AS tienda_m2,'TAMAÑO' AS tamanio,rj.ranking AS rank_jerarquia_n4,t.ciudad,cam.matrices_min AS propuesta,otr.abierto_otr AS abierto_otr,c.* FROM filtered_c c LEFT JOIN catalogos.tiendas t ON c.tienda=t.tienda LEFT JOIN rank_general rg ON c.tienda=rg.id CROSS JOIN me LEFT JOIN catalogos.ranking_tda_jerarquia rj ON c.tienda=rj.id_tienda AND rj.departamento=me.departamento AND rj.subdepartamento=me.subdepartamento AND rj.clase=me.clase AND rj.subclase=me.subclase LEFT JOIN catalogos.control_asignacion_matrices cam ON rj.ranking=cam.clasificacion CROSS JOIN (SELECT MONTH(GETDATE()) AS m) mo OUTER APPLY (SELECT SUM((CASE WHEN mo.m<=1 THEN ISNULL(oc.mes1_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=2 THEN ISNULL(oc.mes2_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=3 THEN ISNULL(oc.mes3_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=4 THEN ISNULL(oc.mes4_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=5 THEN ISNULL(oc.mes5_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=6 THEN ISNULL(oc.mes6_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=7 THEN ISNULL(oc.mes7_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=8 THEN ISNULL(oc.mes8_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=9 THEN ISNULL(oc.mes9_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=10 THEN ISNULL(oc.mes10_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=11 THEN ISNULL(oc.mes11_compra_adicional,0) ELSE 0 END)+(CASE WHEN mo.m<=12 THEN ISNULL(oc.mes12_compra_adicional,0) ELSE 0 END)) AS abierto_otr FROM otr.otr_consulta oc WHERE oc.id_tienda=c.tienda AND oc.id_departamento=me.departamento AND oc.id_subdepartamento=me.subdepartamento AND oc.id_clase=me.clase AND oc.id_subclase=me.subclase AND oc.tipo_articulo=me.tipo_articulo) otr

