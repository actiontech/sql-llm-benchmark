OUP BY o.inp_no,o.visit_id) SELECT t.patientid,t.patientname,t.age,t.gender,t.indate,t.outdate,t.inhospitaltimes,d.type,d.diagnosis_codes AS diagnosiscode,o.operation_codes AS operationcode,t.medicalcost,t.persontype,t.entrymode,t.serialno,t.defaulttab,d.chinese_diagnosis_codes AS chinesediagnosiscode,d.chinese_diagnosis_names AS chinesediagnosename,t.deptcode,t.citycode FROM fp t LEFT JOIN diagnosis_end d ON d.inp_no=t.patientid AND d.times=t.inhospitaltimes LEFT JOIN operations o ON o.inp_no=t.patientid AND o.times=t.inhospitaltimes ORDER BY t.outdate DESC

