## SQL:
WITH active_users AS (SELECT user_id, username FROM users FORCE INDEX (idx_users_status) WHERE status = 'active'), recent_orders AS (SELECT o.order_id, o.user_id, o.order_date FROM active_users u JOIN orders o FORCE INDEX (idx_orders_user_id_order_date) ON o.user_id = u.user_id AND o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 3 YEAR)), order_stats AS (SELECT user_id, COUNT(*) AS total_orders, MAX(order_date) AS last_order_date FROM recent_orders GROUP BY user_id), item_stats AS (SELECT ro.user_id, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS total_spent, AVG(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS avg_order_value FROM recent_orders ro JOIN order_items oi FORCE INDEX (idx_order_items_order_id) ON oi.order_id = ro.order_id GROUP BY ro.user_id), product_sales AS (SELECT o.user_id, p.product_name, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS product_spent FROM order_stats os JOIN orders o FORCE INDEX (idx_orders_user_id) ON o.user_id = os.user_id JOIN order_items oi FORCE INDEX (idx_order_items_order_id) ON oi.order_id = o.order_id JOIN products p ON p.product_id = oi.product_id GROUP BY o.user_id, p.product_name), ranked_products AS (SELECT user_id, product_name, ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY product_spent DESC) AS rank_num FROM product_sales), top_products AS (SELECT user_id, GROUP_CONCAT(product_name ORDER BY product_name SEPARATOR ', ') AS top_products FROM ranked_products WHERE rank_num <= 3 GROUP BY user_id) SELECT au.user_id, au.username, os.total_orders, its.total_spent, its.avg_order_value, os.last_order_date, tp.top_products FROM order_stats os JOIN active_users au ON au.user_id = os.user_id LEFT JOIN item_stats its ON its.user_id = os.user_id LEFT JOIN top_products tp ON tp.user_id = os.user_id ORDER BY its.total_spent DESC;

