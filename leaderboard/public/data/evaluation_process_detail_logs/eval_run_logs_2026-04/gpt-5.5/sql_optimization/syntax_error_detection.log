WITH acctg AS (SELECT d.tenant_id,d.gl_account_id,t.acctg_period,SUM(d.base_posted_dr) AS base_posted_dr1,SUM(d.base_posted_cr) AS base_posted_cr1 FROM acctg_trans_detail d LEFT JOIN acctg_trans t ON t.id=d.master_voucher_id AND t.tenant_id=d.tenant_id WHERE d.tenant_id=1065587309019136 AND (d.voucher_status_enum IS NULL OR d.voucher_status_enum<>'CANCELLED') AND (t.bo_name IS NULL OR t.bo_name<>'DraftAcctgTrans') GROUP BY d.tenant_id,d.gl_account_id,t.acctg_period) SELECT acctg.tenant_id,acctg.gl_account_id,ac.code,acctg.acctg_period,b.base_posted_dr,b.base_posted_cr,acctg.base_posted_dr1,acctg.base_posted_cr1 FROM acctg LEFT JOIN gl_account_balance b ON b.tenant_id=acctg.tenant_id AND b.gl_account_id=acctg.gl_account_id AND b.acctg_period=acctg.acctg_period LEFT JOIN gl_account ac ON ac.id=acctg.gl_account_id AND ac.tenant_id=1065587309019136 WHERE acctg.base_posted_dr1<>IFNULL(b.base_posted_dr,0) OR acctg.base_posted_cr1<>IFNULL(b.base_posted_cr,0) OR b.base_posted_dr<>IFNULL(acctg.base_posted_dr1,0) OR b.base_posted_cr<>IFNULL(acctg.base_posted_cr1,0) UNION ALL SELECT b.tenant_id,b.gl_account_id,ac.code,b.acctg_period,b.base_posted_dr,b.base_posted_cr,NULL AS base_posted_dr1,NULL AS base_posted_cr1 FROM gl_account_balance b LEFT JOIN gl_account ac ON ac.id=b.gl_account_id AND ac.tenant_id=1065587309019136 WHERE b.tenant_id=1065587309019136 AND b.acctg_period NOT LIKE '%00' AND (b.base_posted_dr<>0 OR b.base_posted_cr<>0) AND NOT EXISTS (SELECT 1 FROM acctg WHERE acctg.tenant_id=b.tenant_id AND acctg.gl_account_id=b.gl_account_id AND acctg.acctg_period=b.acctg_period) LIMIT 50001;

