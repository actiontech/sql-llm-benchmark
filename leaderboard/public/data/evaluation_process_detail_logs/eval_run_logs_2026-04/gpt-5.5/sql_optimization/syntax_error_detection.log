WITH page_ids AS (SELECT bid FROM (SELECT B.ID AS bid, ROW_NUMBER() OVER (ORDER BY B.IN_DATE DESC) AS rn FROM mrtrecordinfo B WHERE TO_CHAR(B.ID) LIKE :"SYS_B_0" || :1 || :" SYS_B_1" AND EXISTS (SELECT 1 FROM mrtopration A2 WHERE A2.ID = B.ID)) WHERE rn BETWEEN (:2 + :"SYS_B_2") AND (:3 + :4)) SELECT A.ID AS id, A.PRAMARYID AS primaryId, A.OPERCODE AS operCode, A.OPERNAME AS operName, A.OPERDEPT AS operDept, A.OPERDATE AS operDate, A.MARK AS mark, C.BACKREASON AS mark1, A.MARK2 AS mark2, A.MARK3 AS mark3, A.MARK4 AS mark4, A.OPERTYPE AS operType, A.NEXTOPERTYPE AS nextOperType, A.PREOPERTYPE AS preOperType, A.VALID AS valid, A.CONFIRMUSER AS confirmUser, A.CONFIRMDEPT AS confirmDept, A.VERSIONNUMBER AS versionNumber, B.IN_TIMES AS inTimes, B.NAME AS patient, B.IN_DATE AS inDate, B.OUT_DATE AS outDate, B.OUT_DEPT AS outDept, B.RECORD_STATE AS recordState FROM page_ids P JOIN mrtopration A ON A.ID = P.bid JOIN mrtrecordinfo B ON B.ID = A.ID LEFT JOIN mrtrecordregresses C ON C.RECODE_NO = B.ID AND C.OPER_DATE = A.OPERDATE AND C.OPERID = A.OPERCODE ORDER BY A.OPERDATE DESC

