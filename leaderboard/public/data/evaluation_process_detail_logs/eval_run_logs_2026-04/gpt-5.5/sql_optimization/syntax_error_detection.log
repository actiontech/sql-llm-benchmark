SELECT temp.*,st.STORE_NAME,loc.LOCATION_NAME,std.STANDARD_NAME,sg.COLUMN_NAME AS STEEL_GRADE_NAME,si.SEND_ID AS CONNECT_ID,sid.SEND_PRODUCT_DETAIL_ID AS CONNECT_DETAIL_ID,CASE WHEN sid.SPOT_TYPE='40' THEN IFNULL(sid.WEIGHT,0) ELSE IFNULL(sid.NUMBER,0) END AS SEND_NUMBER,CASE WHEN sid.SPOT_TYPE='40' THEN IFNULL(rd.RETURN_WEIGHT,0) ELSE IFNULL(rd.RETURN_NUMBER,0) END AS RETURN_NUMBER FROM t_dgm_send_info si JOIN t_dgm_send_info_detail sid ON sid.SEND_ID=si.SEND_ID AND si.SEND_STATE='70' JOIN (SELECT v.PRODUCE_MATERIAL_ID,IFNULL(v.PACKAGE_NO,v.MATERIAL_NO) AS MIXED_NO,'30' AS SPOT_TYPE,v.MATERIAL_NO,v.PACKAGE_NO,v.PSR_ID,v.CUSTOMER_ID,v.CONTRACT_ID,v.CONTRACT_NO,v.NUMBER,v.NET_WEIGHT,v.GROSS_WT,v.STORE_ID,v.LOCATION_ID,v.STANDARD_ID,v.STEEL_GRADE,v.SURFACE_GROUP_DESC,v.CONTRACT_DETAIL_ID,NULL AS VARIETY_ID,CASE WHEN v.LENGTH IS NOT NULL AND v.LENGTH<>0 THEN CONCAT(v.THICK,'*',v.WIDTH,'*',v.LENGTH) ELSE CONCAT(v.THICK,'*',v.WIDTH,'*C') END AS specs,SUM(CASE WHEN cd.BUY_UNIT='10' THEN cd.TAX_PRICE*v.NET_WEIGHT ELSE cd.TAX_PRICE*IFNULL(cd.NUMBER,1) END) AS PRICE FROM v_pre_product_material v LEFT JOIN t_mao_contract_delivery_subkey dsk ON dsk.CONTRACT_DELIVERY_ID=v.CONTRACT_DELIVERY_ID LEFT JOIN t_sam_contract_detail cd ON cd.CONTRACT_DETAILS_ID=dsk.CONTRACT_DETAIL_ID WHERE v.CUSTOMER_ID='1930921074703462401' AND v.IS_ISSUED='1' AND v.IS_SPOT_RESOURCE='0' AND v.NI36_TAG='0' AND v.MATERIAL_STATE<>'110' AND v.CONTRACT_TYPE<>'60' AND NOT EXISTS (SELECT 1 FROM v_pre_product_material v2 WHERE (v2.PACKAGE_NO=v.PACKAGE_NO OR v2.MATERIAL_NO=v.MATERIAL_NO) AND v2.IS_ISSUED<>'1') GROUP BY COALESCE(v.PACKAGE_NO,v.MATERIAL_NO) UNION ALL SELECT cd.CONTRACT_DETAILS_ID AS PRODUCE_MATERIAL_ID,cd.PRODUCT_MATERIAL_NO AS MIXED_NO,'10' AS SPOT_TYPE,cd.PRODUCT_MATERIAL_NO AS MATERIAL_NO,NULL AS PACKAGE_NO,var.COLUMN_NAME AS PSR_ID,c.CUSTOMER_ID,c.CONTRACT_ID,c.CONTRACT_NO,1 AS NUMBER,isi.NEW_WEIGHT AS NET_WEIGHT,isi.GROSS_WT,isi.STORE_ID,isi.LOCATION_ID,NULL AS STANDARD_ID,isi.STEEL_GRADE,NU