WITH TopProducts AS (SELECT o3.user_id, GROUP_CONCAT(DISTINCT p.product_name ORDER BY p.product_name SEPARATOR ', ') AS GROUP_CONCAT_ FROM (SELECT o3.user_id, p.product_name, ROW_NUMBER() OVER (PARTITION BY o3.user_id ORDER BY SUM(oi2.quantity * oi2.unit_price * (1 - oi2.discount / 100)) DESC) AS rank_num FROM users u INNER JOIN orders o3 ON u.user_id = o3.user_id INNER JOIN order_items oi2 ON o3.order_id = oi2.order_id INNER JOIN products p ON oi2.product_id = p.product_id WHERE u.status = 'active' GROUP BY o3.user_id, p.product_name) AS ranked WHERE ranked.rank_num <= 3 GROUP BY ranked.user_id) SELECT u.user_id, u.username, COUNT(DISTINCT o.order_id) AS total_orders, SUM(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS total_spent, AVG(oi.quantity * oi.unit_price * (1 - oi.discount / 100)) AS avg_order_value, MAX(o.order_date) AS last_order_date, tp.GROUP_CONCAT_ AS top_products FROM users u INNER JOIN orders o ON u.user_id = o.user_id LEFT JOIN order_items oi ON o.order_id = oi.order_id LEFT JOIN TopProducts tp ON tp.user_id = u.user_id WHERE u.status = 'active' AND o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 3 YEAR) GROUP BY u.user_id, u.username ORDER BY total_spent DESC;

