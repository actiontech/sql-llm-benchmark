WITH avg_cust_rate AS (SELECT vehicle_type, booking_status, payment_method, IFNULL(AVG(ride_distance), 0) AS avg_v FROM ride_bookings GROUP BY vehicle_type, booking_status, payment_method) SELECT vehicle_type, booking_status, payment_method, ride_distance, rate, rank_num FROM (SELECT base.vehicle_type, base.booking_status, base.payment_method, base.ride_distance, IFNULL(base.ride_distance, 0) - avg.avg_v AS rate, ROW_NUMBER() OVER (PARTITION BY base.vehicle_type ORDER BY ABS(IFNULL(base.ride_distance, 0) - avg.avg_v) DESC) AS rank_num FROM ride_bookings base JOIN avg_cust_rate avg ON base.vehicle_type = avg.vehicle_type AND base.booking_status = avg.booking_status AND base.payment_method = avg.payment_method WHERE ABS(IFNULL(base.ride_distance, 0) - avg.avg_v) >= 1) fn WHERE rank_num <= 5;
