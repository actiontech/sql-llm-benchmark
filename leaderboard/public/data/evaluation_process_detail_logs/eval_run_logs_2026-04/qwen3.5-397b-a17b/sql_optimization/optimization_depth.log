## Original SQL:
WITH StudentStats AS (

  SELECT 

  s.s_id,

  s.s_name,

  s.s_sex,

  COUNT(DISTINCT sc.c_id) AS course_count,

  AVG(sc.s_score) AS avg_score,

  SUM(CASE WHEN sc.s_score > 90 THEN 1 ELSE 0 END) AS excellent_course_count

  FROM Student s

  JOIN Score sc ON s.s_id = sc.s_id

  GROUP BY s.s_id, s.s_name, s.s_sex

  HAVING AVG(sc.s_score) > 80 AND SUM(CASE WHEN sc.s_score > 90 THEN 1 ELSE 0 END) >= 2

)

SELECT 

  ss.s_id,

  ss.s_name,

  ss.s_sex,

  ss.course_count,

  ss.avg_score,

  ss.excellent_course_count,

  RANK() OVER (PARTITION BY ss.s_sex ORDER BY ss.avg_score DESC) AS gender_rank

FROM StudentStats ss

ORDER BY ss.avg_score DESC;

## Optimized SQL:
SELECT ss.s_id, ss.s_name, ss.s_sex, ss.course_count, ss.avg_score, ss.excellent_course_count, RANK() OVER (PARTITION BY ss.s_sex ORDER BY ss.avg_score DESC) AS gender_rank FROM (SELECT s.s_id, s.s_name, s.s_sex, COUNT(DISTINCT sc.c_id) AS course_count, AVG(sc.s_score) AS avg_score, COUNT(*) FILTER (WHERE sc.s_score > 90) AS excellent_course_count FROM Student s JOIN Score sc ON s.s_id = sc.s_id GROUP BY s.s_id HAVING AVG(sc.s_score) > 80 AND COUNT(*) FILTER (WHERE sc.s_score > 90) >= 2) ss ORDER BY ss.avg_score DESC

