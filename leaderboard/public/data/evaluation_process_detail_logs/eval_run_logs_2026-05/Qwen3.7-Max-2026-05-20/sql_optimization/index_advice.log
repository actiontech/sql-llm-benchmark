{"users":{"birthdate":19.876%,"email":100%,"gender":0.006%,"phone":99.912%,"user_id":100%,"username":100%,"vip_level":0.012%}}

## Original SQL:
SELECT user_id, username, email, phone
FROM users
WHERE gender = 1 
  AND birthdate > '1990-01-01' 
  AND vip_level >= 2;

