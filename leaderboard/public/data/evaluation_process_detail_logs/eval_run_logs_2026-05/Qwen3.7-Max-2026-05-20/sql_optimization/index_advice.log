  `TRANSFER_INN_NAME_CN` varchar(512) DEFAULT NULL COMMENT '酒店名称（转品牌转前酒店名称）',
  `PROJECT_ID` varchar(128) DEFAULT NULL COMMENT '项目编码(铂涛酒店)',
  `e_key` varchar(8) DEFAULT 'off' COMMENT '智能钥匙开关：on/off',
