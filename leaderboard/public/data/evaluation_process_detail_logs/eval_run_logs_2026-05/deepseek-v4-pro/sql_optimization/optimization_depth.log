[{"rule_id": "1", "difficulty_level": "3", "rationale": "子查询折叠,通过折叠CTE，将原始SQL中的公共表表达式（StudentStats）与主查询合并，消除了中间结果集的物化开销，提高查询性能。在MySQL 5.7及以下版本效果显著，8.0+版本也能避免优化器选择物化策略的开销。"}]

## Original SQL:
WITH StudentStats AS (
  SELECT 
  s.s_id,
  s.s_name,
  s.s_sex,
  COUNT(DISTINCT sc.c_id) AS course_count,
  AVG(sc.s_score) AS avg_score,
  SUM(CASE WHEN sc.s_score > 90 THEN 1 ELSE 0 END) AS excellent_course_count
  FROM Student s
  JOIN Score sc ON s.s_id = sc.s_id
  GROUP BY s.s_id, s.s_name, s.s_sex
  HAVING AVG(sc.s_score) > 80 AND SUM(CASE WHEN sc.s_score > 90 THEN 1 ELSE 0 END) >= 2
)
SELECT 
  ss.s_id,
  ss.s_name,
  ss.s_sex,
  ss.course_count,
  ss.avg_score,
  ss.excellent_course_count,
  RANK() OVER (PARTITION BY ss.s_sex ORDER BY ss.avg_score DESC) AS gender_rank
FROM StudentStats ss
ORDER BY ss.avg_score DESC;

## Optimized SQL:
WITH filtered AS (SELECT s_id, AVG(s_score) AS avg_score, SUM(CASE WHEN s_score > 90 THEN 1 ELSE 0 END) AS excellent_course_count, COUNT(DISTINCT c_id) AS course_count FROM Score GROUP BY s_id HAVING AVG(s_score) > 80 AND SUM(CASE WHEN s_score > 90 THEN 1 ELSE 0 END) >= 2) SELECT s.s_id, s.s_name, s.s_sex, f.course_count, f.avg_score, f.excellent_course_count, RANK() OVER (PARTITION BY s.s_sex ORDER BY f.avg_score DESC) AS gender_rank FROM Student s JOIN filtered f ON s.s_id = f.s_id ORDER BY f.avg_score DESC;

