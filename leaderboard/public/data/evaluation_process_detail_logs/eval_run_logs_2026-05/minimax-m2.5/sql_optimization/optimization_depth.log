SELECT DISTINCT acc_account_no, acc_subacc_no, acch_title, to_char(acc_incep_date,'DD/MM/YYYY') acc_incep_date, htax.ACCTAX_EFF_DATE_FROM, to_char(onhold_accounts.audh_date, 'DD-MON-YYYY') approved_date, act_long_name, tran_amount_cr, tran_create_by, CASE WHEN (trunc(acc_incep_date) - trunc(onhold_accounts.audh_date)) < 0 THEN 0 ELSE (trunc(acc_incep_date) - trunc(onhold_accounts.audh_date)) END time_on_approved, acch_brn_code FROM (SELECT accounts.acc_account_no, acch_title, accounts.acc_subacc_no, acc_incep_date, act_long_name, tran_amount_cr, transactions.tran_create_by, first_tran_date, acch_brn_code FROM accounts JOIN account_headers ON account_headers.acch_account_no = accounts.acc_account_no JOIN account_types ON acc_act_code = act_code JOIN (SELECT tran_account_no, tran_subacc_no, min(tran_seqno) first_tran_seq, min(tran_date) first_tran_date FROM transactions USE INDEX (idx_trans_account_subacc) WHERE tran_amount_cr IS NOT NULL AND tran_trans_code IN ('RIC','RSAV') AND tran_date BETWEEN IN_FUND_FROM_DATE AND IN_FUND_TO_DATE AND tran_pay_method NOT IN ('C','CQ') GROUP BY tran_account_no, tran_subacc_no) first_trans ON tran_account_no = acc_account_no AND tran_subacc_no = acc_subacc_no JOIN transactions ON tran_seqno = first_trans.first_tran_seq WHERE acc_gact_type IN ('S', 'IC') AND acc_incep_date BETWEEN IN_INCEP_FROM_DATE and IN_INCEP_TO_DATE) opened_accounts JOIN (SELECT audh_key1, audh_key2, audh_date FROM audit_header ah WHERE ah.audh_table_prefix = 'ACC' AND ah.audh_change_type = 'I' AND EXISTS (SELECT 1 FROM audit_detail ad USE INDEX (idx_audd_audh_seqno) WHERE ad.audd_audh_seqno = ah.audh_seqno AND ad.audd_col_sufix = 'PROCESS_STATUS' AND ad.audd_old_value IS NULL AND ad.audd_new_value = 1)) onhold_accounts ON opened_accounts.acc_account_no = onhold_accounts.audh_key1 AND opened_accounts.acc_subacc_no = onhold_accounts.audh_key2 JOIN ACCOUNT_LINKS al ON al.accl_account_no = opened_accounts.ACC_ACCOUNT_NO and al.accl_subacc_no = opened_accounts.ACC_SUBACC_NO and al.accl_holder_pos = 1 JOIN SUMMIT.ACCOUNT_HOLDING_TAX htax ON htax.ACCTAX_ACCOUNT_NO = al.ACCL_ACCOUNT_NO AND htax.ACCTAX_SUBACC_NO = al.ACCL_SUBACC_NO AND htax.ACCTAX_CUST_SEQNO = al.ACCL_CUST_SEQNO

