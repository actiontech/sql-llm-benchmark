Y f.setl_id) a1 INNER JOIN (SELECT /*+ INDEX(s IDX_SETL_D_MERGED_FUND_PAY) */ s.* FROM setl_d_merged s WHERE s.fund_pay_sumamt<>0) s ON a1.setl_id=s.setl_id WHERE a1.b_cnt>(s.ipt_days*12+24)) fl

