  m.sqlthroughput,
  m.sqlavgtime,
  m.user_commits,
  m.user_rollbacks,
  m.user_commits + m.user_rollbacks AS transactioncount,
  m.transactionavgtime
FROM
  (
  WITH
   t1 AS (
  SELECT
  inst_id,
  COUNT(*) conn
  FROM
  gv$session
  WHERE
  TYPE = 'USER'
  GROUP BY
  inst_id
   ),
   t2 AS (
  SELECT
  inst_id,
  COUNT(*) activeconn
  FROM
  gv$session
  WHERE
  TYPE = 'USER'
  AND status = 'ACTIVE'
  GROUP BY
  inst_id
   )
  SELECT
   t1.inst_id,
   t1.conn,
   t2.activeconn
