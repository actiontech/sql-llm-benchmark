  `HOTEL_THEME_TYPE` varchar(32) DEFAULT NULL COMMENT '酒店主题类型',
  `MEETING_ROOM` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否有会议室  1-有  0-无',
  PRIMARY KEY (`ID`),
