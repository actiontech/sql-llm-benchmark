SELECT 
    u.user_id,
    u.username,
    COUNT(o.order_id) AS order_count,
    SUM(o.amount) AS total_amount
FROM 
    users u
JOIN 
    orders o ON u.user_id = o.user_id
WHERE 
    u.vip_level > 0
    AND o.pay_time BETWEEN '2025-08-10' AND '2025-08-11'
GROUP BY 
    u.user_id, u.username
ORDER BY 
    total_amount DESC;

