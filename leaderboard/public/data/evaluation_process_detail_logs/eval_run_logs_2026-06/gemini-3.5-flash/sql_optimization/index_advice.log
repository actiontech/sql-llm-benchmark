## Original SQL:
SELECT 
    brand, 
    origin_country, 
    COUNT(*) AS product_count, 
    AVG(price) AS avg_price
FROM 
    products
WHERE 
    is_imported = 1 
    AND stock > 0 
    AND weight < 5
GROUP BY 
    brand, origin_country
ORDER BY 
    product_count DESC;

